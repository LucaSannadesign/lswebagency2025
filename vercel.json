{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://apis.google.com https://vercel.live/_next-live/feedback/feedback.js; style-src 'self' 'unsafe-inline';"
        }
      ]
    }
  ]
}
