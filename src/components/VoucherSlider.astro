<script is:inline>
  (() => {
    document.querySelectorAll('.vs').forEach((root) => {
      const slides = Array.from(root.querySelectorAll('[data-slide]'));
      const bars = Array.from(root.querySelectorAll('[data-bar]'));
      const dots = Array.from(root.querySelectorAll('[data-dot]'));
      const counter = root.querySelector('[data-counter]');
      const DELAY = 4800;
      const prefersReducedMotion =
        window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      /** Allineato alle durate CSS (.vs__slide 0.5s, reduced-motion 0.12s) */
      const SLIDE_MS = prefersReducedMotion ? 120 : 560;
      let current = 0;
      let autoTimer = null;
      let leaveTimer = null;
      const total = slides.length;

      const pad = (n) => String(n + 1).padStart(2, '0');

      function syncBars(active) {
        bars.forEach((bar, i) => {
          const fill = bar.querySelector('.vs__bar-fill');
          bar.classList.remove('is-active', 'is-done');
          fill.classList.remove('is-animating');
          fill.style.width = '';

          if (i < active) {
            bar.classList.add('is-done');
          } else if (i === active) {
            bar.classList.add('is-active');
            if (prefersReducedMotion) {
              fill.style.width = '100%';
            } else {
              requestAnimationFrame(() => {
                requestAnimationFrame(() => fill.classList.add('is-animating'));
              });
            }
          }
        });
      }

      function updateDotsAndCounter() {
        dots.forEach((d, i) => {
          d.classList.toggle('is-active', i === current);
          d.setAttribute('aria-pressed', i === current ? 'true' : 'false');
        });

        if (counter) counter.textContent = `${pad(current)} / ${pad(total - 1)}`;
      }

      function goTo(next) {
        if (!total) return;
        const target = ((next % total) + total) % total;
        if (target === current) return;

        const leaving = slides[current];
        const entering = slides[target];

        if (leaveTimer) {
          window.clearTimeout(leaveTimer);
          leaveTimer = null;
        }

        leaving.classList.remove('is-active');
        leaving.classList.add('is-leaving');
        leaving.setAttribute('aria-hidden', 'true');

        current = target;

        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            entering.classList.add('is-active');
            entering.setAttribute('aria-hidden', 'false');
          });
        });

        leaveTimer = window.setTimeout(() => {
          leaving.classList.remove('is-leaving');
          leaveTimer = null;
        }, SLIDE_MS);

        updateDotsAndCounter();
        syncBars(current);
      }

      function stopAuto() {
        if (autoTimer !== null) {
          window.clearInterval(autoTimer);
          autoTimer = null;
        }

        const fill = bars[current]?.querySelector('.vs__bar-fill');
        if (fill) {
          const computed = window.getComputedStyle(fill).width;
          fill.classList.remove('is-animating');
          fill.style.width = computed;
        }
      }

      function startAuto() {
        if (prefersReducedMotion) return;
        stopAuto();
        syncBars(current);
        autoTimer = window.setInterval(() => goTo(current + 1), DELAY);
      }

      root.querySelectorAll('[data-prev]').forEach((btn) => {
        btn.addEventListener('click', () => {
          stopAuto();
          goTo(current - 1);
          startAuto();
        });
      });

      root.querySelectorAll('[data-next]').forEach((btn) => {
        btn.addEventListener('click', () => {
          stopAuto();
          goTo(current + 1);
          startAuto();
        });
      });

      dots.forEach((dot) => {
        dot.addEventListener('click', () => {
          stopAuto();
          goTo(Number(dot.dataset.dot));
          startAuto();
        });
      });

      bars.forEach((bar) => {
        bar.addEventListener('click', () => {
          stopAuto();
          goTo(Number(bar.dataset.bar));
          startAuto();
        });
      });

      root.addEventListener('mouseenter', stopAuto);
      root.addEventListener('mouseleave', startAuto);
      root.addEventListener('focusin', stopAuto);
      root.addEventListener('focusout', (e) => {
        const next = e.relatedTarget;
        if (next && root.contains(next)) return;
        startAuto();
      });

      updateDotsAndCounter();
      syncBars(0);
      startAuto();
    });
  })();
</script>

<style is:global>
  @property --vs-angle {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }

  @keyframes vs-spin { to { --vs-angle: 360deg; } }
  @keyframes vs-float-up { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
  @keyframes vs-float-down { 0%,100%{transform:translateY(0)} 50%{transform:translateY(8px)} }
  @keyframes vs-pulse { 0%,100%{transform:scale(1)} 50%{transform:scale(1.05)} }

  .vs,
  .vs * {
    box-sizing: border-box;
  }

  .vs {
    position: relative;
    border-radius: 28px;
    background: #0a0d18;
    overflow: hidden;
    --vs-angle: 0deg;
  }

  .vs::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 28px;
    padding: 1px;
    background: conic-gradient(
      from var(--vs-angle),
      rgba(99,102,241,.6),
      rgba(56,189,248,.5),
      rgba(167,139,250,.6),
      rgba(99,102,241,.6)
    );
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    z-index: 10;
    animation: vs-spin 8s linear infinite;
  }

  .vs__nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem 1.4rem 0;
    position: relative;
