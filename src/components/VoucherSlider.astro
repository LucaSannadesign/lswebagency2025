---
const slides = [
  {
    chipLabel: "Voucher digitali",
    title: "Sito, presenza online e conversione",
    text: "Una soluzione per attività e professionisti che vogliono comunicare meglio, trasmettere fiducia e semplificare i contatti.",
    points: ["Messaggio più chiaro", "Pagine strutturate", "Presenza credibile"],
    ctaLabel: "Richiedi una valutazione",
    ctaHref: "/contatti",
    colorKey: "blue"
  },
  {
    chipLabel: "Per chi è utile",
    title: "Imprese, studi e professionisti locali",
    text: "Un sito poco chiaro o datato ha un effetto immediato: meno fiducia, meno richieste, meno opportunità.",
    points: ["Attività locali", "Studi professionali", "Piccole imprese"],
    ctaLabel: "Scopri se fa per te",
    ctaHref: "/contatti",
    colorKey: "green"
  },
  {
    chipLabel: "Cosa si migliora",
    title: "Design, UX, contenuti e struttura",
    text: "Piccoli interventi mirati possono migliorare percezione, leggibilità e qualità dei contatti senza complicare il sito.",
    points: ["Gerarchia visiva", "CTA efficaci", "Navigazione semplice"],
    ctaLabel: "Valuta il tuo sito",
    ctaHref: "/audit-ai",
    colorKey: "purple"
  },
  {
    chipLabel: "Primo passo",
    title: "Analisi chiara, non promesse generiche",
    text: "Ti aiuto a capire priorità, margini di miglioramento e direzione corretta prima di investire budget in modo dispersivo.",
    points: ["Analisi mirata", "Indicazioni concrete", "Approccio sostenibile"],
    ctaLabel: "Contattami",
    ctaHref: "/contatti",
    colorKey: "amber"
  }
];
---

<section class="vs" aria-label="Slider voucher e opportunità digitali">
  <div class="vs__nav">
    <span class="vs__eyebrow">Opportunità digitali</span>

    <div class="vs__nav-arrows">
      <button type="button" class="vs__arrow" data-prev aria-label="Slide precedente">←</button>
      <button type="button" class="vs__arrow" data-next aria-label="Slide successiva">→</button>
    </div>
  </div>

  <div class="vs__progress" aria-hidden="true">
    {slides.map((_, i) => (
      <button class={`vs__bar${i === 0 ? " is-active" : ""}`} data-bar={i} aria-label={`Progress slide ${i + 1}`}>
        <span class="vs__bar-fill"></span>
      </button>
    ))}
  </div>

  <div class="vs__viewport" data-viewport>
    {slides.map((slide, i) => (
      <article
        class={`vs__slide vs__slide--${slide.colorKey}${i === 0 ? " is-active" : ""}`}
        data-slide={i}
        aria-label={`Slide ${i + 1} di ${slides.length}`}
        aria-hidden={i !== 0 ? "true" : "false"}
      >
        <div class="vs__content">
          <div class="vs__chip">
            <span class="vs__chip-dot" aria-hidden="true"></span>
            {slide.chipLabel}
          </div>

          <div class="vs__body">
            <h3 class="vs__title">{slide.title}</h3>
            <p class="vs__text">{slide.text}</p>

            <ul class="vs__points" aria-label="Punti chiave">
              {slide.points.map((p) => <li>{p}</li>)}
            </ul>
          </div>

          <div class="vs__bottom">
            <a class="vs__cta" href={slide.ctaHref}>
              {slide.ctaLabel}
              <span class="vs__cta-arrow" aria-hidden="true">→</span>
            </a>
          </div>
        </div>

        <div class="vs__visual" aria-hidden="true">
          <div class="vs__bignum">{String(i + 1).padStart(2, "0")}</div>
          <div class="vs__glow"></div>

          <div class="vs__art">
            {i === 0 && (
              <svg viewBox="0 0 300 280" fill="none" xmlns="http://www.w3.org/2000/svg">
                <line x1="0" y1="60" x2="300" y2="60" stroke="rgba(99,102,241,.12)" stroke-width=".8"/>
                <line x1="0" y1="120" x2="300" y2="120" stroke="rgba(99,102,241,.12)" stroke-width=".8"/>
                <line x1="0" y1="180" x2="300" y2="180" stroke="rgba(99,102,241,.12)" stroke-width=".8"/>
                <line x1="0" y1="240" x2="300" y2="240" stroke="rgba(99,102,241,.12)" stroke-width=".8"/>
                <line x1="60" y1="0" x2="60" y2="280" stroke="rgba(99,102,241,.12)" stroke-width=".8"/>
                <line x1="120" y1="0" x2="120" y2="280" stroke="rgba(99,102,241,.12)" stroke-width=".8"/>
                <line x1="180" y1="0" x2="180" y2="280" stroke="rgba(99,102,241,.12)" stroke-width=".8"/>
                <line x1="240" y1="0" x2="240" y2="280" stroke="rgba(99,102,241,.12)" stroke-width=".8"/>

                <g class="vs-art-float-up">
