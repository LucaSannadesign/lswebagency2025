---
import { Icon } from 'astro-icon/components';
import ToggleTheme from '~/components/common/ToggleTheme.astro';
import ToggleMenu from '~/components/common/ToggleMenu.astro';
import Button from '~/components/ui/Button.astro';

import { getHomePermalink } from '~/utils/permalinks';
import { trimSlash, getAsset } from '~/utils/permalinks';
import type { CallToAction } from '~/types';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface MenuLink extends Link {
  links?: Array<MenuLink>;
}

export interface Props {
  id?: string;
  links?: Array<MenuLink>;
  actions?: Array<CallToAction>;
  isSticky?: boolean;
  isDark?: boolean;
  isFullWidth?: boolean;
  showToggleTheme?: boolean;
  showRssFeed?: boolean;
  position?: string;
}

const {
  id = 'header',
  links = [
    { text: 'Home', href: '/' },
    { text: 'Chi Siamo', href: '/chi-siamo' },
    {
      text: 'Servizi',
      href: '/servizi',
      links: [
        { text: 'Creazione siti web', href: '/servizi/creazione-siti-web-sassari' },
        { text: 'Realizzazione E-commerce', href: '/servizi/realizzazione-siti-ecommerce' },
        { text: 'Branding e Grafica', href: '/servizi/branding-e-grafica-siti-web' },
        { text: 'Ottimizzazione SEO', href: '/servizi/ottimizzazione-seo-siti-web' },
      ],
    },
    { text: 'Portfolio', href: '/portfolio' },
    { text: 'Blog', href: '/blog' },
    { text: 'Contatti', href: '/contatti' },
  ],
  actions = [],
  isSticky = false,
  isDark = false,
  isFullWidth = false,
  showToggleTheme = false,
  showRssFeed = false,
  position = 'center',
} = Astro.props;

const currentPath = `/${trimSlash(new URL(Astro.url).pathname)}`;
---

<header
  class:list={[
    { sticky: isSticky, relative: !isSticky, dark: isDark },
    'top-0 z-40 flex-none mx-auto w-full border-b border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 transition-[opacity] ease-in-out',
  ]}
  {...isSticky ? { 'data-aw-sticky-header': true } : {}}
  {...id ? { id } : {}}
>
  <div class="absolute inset-0"></div>
  <div
    class="relative text-default py-4 px-4 md:px-6 mx-auto w-full flex justify-between items-center max-w-7xl"
  >
    <a class="flex items-center" href={getHomePermalink()}>
      <img
        src="/images/logo-ls-webdesignagency-2025.svg"
        alt="LS Web Design Agency"
        class="h-10 w-auto dark:hidden"
      />
      <img
        src="/images/logo-ls-webdesignagency-2025-bn.svg"
        alt="LS Web Design Agency"
        class="h-10 w-auto hidden dark:block"
      />
    </a>

    <nav class="hidden md:flex space-x-6 text-default">
      {links.map(({ text, href, links }) => (
        <div class="relative group">
          {links?.length ? (
            <>
              <button class="flex items-center space-x-1 text-default hover:text-primary" data-toggle-menu>
                {text}
                <Icon name="tabler:chevron-down" class="w-4 h-4" />
              </button>
              <ul class="absolute left-0 mt-2 w-48 bg-white dark:bg-gray-800 shadow-lg rounded-md hidden group-hover:block">
                {links.map(({ text: text2, href: href2 }) => (
                  <li>
                    <a href={href2} class="block px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-700 text-default">
                      {text2}
                    </a>
                  </li>
                ))}
              </ul>
            </>
          ) : (
            <a
              href={href}
              class:list={[
                'text-default hover:text-primary px-4 py-2',
                { 'font-bold': href === currentPath },
              ]}
            >
              {text}
            </a>
          )}
        </div>
      ))}
    </nav>

    <div class="hidden md:flex items-center space-x-4">
      {showToggleTheme && <ToggleTheme iconClass="w-6 h-6 md:w-5 md:h-5" />}
      {showRssFeed && (
        <a
          class="text-muted dark:text-gray-400 hover:text-primary transition"
          aria-label="RSS Feed"
          href={getAsset('/rss.xml')}
        >
          <Icon name="tabler:rss" class="w-5 h-5" />
        </a>
      )}
      {actions.length > 0 && (
        <span class="ml-4">
          {actions.map((btnProps) => (
            <Button {...btnProps} class="py-2.5 px-5 font-semibold shadow-none text-sm" />
          ))}
        </span>
      )}
    </div>

    <div class="md:hidden">
      <ToggleMenu />
    </div>
  </div>
</header>

<!-- ✅ SCRIPT PER GESTIRE IL MENU DROPDOWN -->
<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll("[data-toggle-menu]").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.preventDefault();

        // Chiude tutti i menu aperti
        document.querySelectorAll(".dropdown-menu").forEach((menu) => {
          if (menu !== btn.nextElementSibling) {
            menu.classList.add("hidden");
          }
        });

        // Mostra/Nasconde il menu
        const menu = btn.nextElementSibling;
        if (menu && menu.classList.contains("dropdown-menu")) {
          menu.classList.toggle("hidden");
        }
      });
    });

    // Chiudi il menu se si clicca fuori
    document.addEventListener("click", (e) => {
      if (!e.target.closest("[data-toggle-menu]")) {
        document.querySelectorAll(".dropdown-menu").forEach((menu) => {
          menu.classList.add("hidden");
        });
      }
    });
  });
</script>
