---
import { Icon } from 'astro-icon/components';
import ToggleTheme from '@/components/common/ToggleTheme.astro';
import ToggleMenu from '@/components/common/ToggleMenu.astro';
import Button from '@/components/ui/Button.astro';

import { getHomePermalink, trimSlash, getAsset } from '@/utils/permalinks';
import type { CallToAction } from '@/types';
import { headerData as navHeaderData } from '@/navigation';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}
interface MenuLink extends Link {
  links?: Array<MenuLink>;
}

export interface Props {
  id?: string;
  links?: Array<MenuLink>;
  actions?: Array<CallToAction>;
  isSticky?: boolean;
  isDark?: boolean;
  isFullWidth?: boolean;
  showToggleTheme?: boolean;
  showRssFeed?: boolean;
  position?: string;
}

const {
  id = 'header',
  links: linksProp,
  actions: actionsProp,
  isSticky = false,
  isDark = false,
  isFullWidth = false,
  showToggleTheme = true,
  showRssFeed = true,
  position = 'center',
} = Astro.props;

// ✅ Source of truth: src/navigation.ts (override opzionale via props)
const links = (Array.isArray(linksProp) && linksProp.length ? linksProp : navHeaderData.links) as MenuLink[];
const actions = (Array.isArray(actionsProp) && actionsProp.length ? actionsProp : (navHeaderData.actions ?? [])) as CallToAction[];

const currentPath = `/${trimSlash(new URL(Astro.url).pathname)}`;

/* ---------- filtro difensivo: rimuovi Local / Pagamenti ovunque ---------- */
const BLOCKED = new Set(['/local', '/pagamenti']);
function isBlocked(l?: MenuLink) {
  const href = String(l?.href ?? '').trim().toLowerCase();
  const text = String(l?.text ?? '').trim().toLowerCase();
  return BLOCKED.has(href) || text === 'local' || text === 'pagamenti';
}
function sanitize(items: MenuLink[] = []): MenuLink[] {
  return items
    .filter((i) => !isBlocked(i))
    .map((i) => (i?.links?.length ? { ...i, links: sanitize(i.links) } : i));
}
const headerItems = sanitize(links);
---

<header
  class:list={[{ sticky: isSticky, relative: !isSticky, dark: isDark }, 'top-0 z-40 flex-none mx-auto w-full border-b border-gray-50/0 transition-opacity ease-in-out']}
  {...(isSticky ? { 'data-aw-sticky-header': true } : {})}
  {...(id ? { id } : {})}
>
  <div class="absolute inset-0"></div>

  <div
    class:list={[
      'relative text-default py-3 px-3 md:px-6 mx-auto w-full',
      { 'lg:flex lg:justify-between': position !== 'center' },
      { 'lg:grid lg:grid-cols-3 lg:items-center': position === 'center' },
      { 'max-w-7xl': !isFullWidth },
    ]}
  >
    <!-- Left: logo + hamburger -->
    <div class:list={[{ 'mr-auto rtl:mr-0 rtl:ml-auto': position === 'right' }, 'flex items-center justify-between gap-2']}>
      <a class="flex items-center" href={getHomePermalink()} aria-label="Torna alla home">
        <img src="/images/logo-ls-webdesignagency-2025.svg" alt="LS Web Design Agency" class="h-10 w-auto dark:hidden" />
        <img src="/images/logo-ls-webdesignagency-2025-bn.svg" alt="LS Web Design Agency" class="h-10 w-auto hidden dark:block" />
      </a>

      <!-- Mobile: azioni rapide (tema + RSS) + menù -->
      <div class="flex items-center lg:hidden gap-2">
        {showToggleTheme && <ToggleTheme iconClass="w-6 h-6" />}
        {showRssFeed && (
          <a
            href={getAsset('/rss.xml')}
            aria-label="RSS Feed"
            class="text-muted dark:text-gray-300 p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700"
            rel="alternate"
            title="RSS feed"
          >
            <Icon name="tabler:rss" class="w-6 h-6" />
          </a>
        )}
        <ToggleMenu />
      </div>
    </div>

    <!-- Mobile: pannello compatto (nav + CTA) — desktop: lg:contents lascia il grid invariato -->
    <div
      data-aw-mobile-menu-panel
      class="hidden lg:contents max-lg:absolute max-lg:top-full max-lg:right-3 max-lg:mt-2 max-lg:z-50 max-lg:w-[min(22rem,calc(100vw-2rem))] max-lg:max-h-[min(70vh,calc(100dvh-5rem))] max-lg:overflow-y-auto max-lg:rounded-2xl max-lg:border max-lg:border-neutral-200 max-lg:dark:border-neutral-700 max-lg:bg-white/95 max-lg:dark:bg-neutral-900/95 max-lg:shadow-xl max-lg:backdrop-blur-md"
    >
    <!-- Center: nav -->
    <nav
      class="flex flex-col lg:flex lg:flex-row items-stretch lg:items-center w-full lg:w-auto lg:mx-5 text-default lg:overflow-y-visible lg:overflow-x-visible lg:justify-self-center min-w-0 max-lg:py-2"
      aria-label="Main navigation"
    >
      <ul class="flex flex-col lg:flex-row list-none m-0 p-0 text-base lg:text-[0.9375rem] tracking-[0.01rem] font-medium lg:justify-center w-full lg:w-auto">
        {headerItems.map(({ text, href, links }) => (
          <li class={links?.length ? 'dropdown' : ''}>
            {links?.length ? (
              <>
                <div class="flex items-center">
                  <a
                    href={href}
                    class="hover:text-link dark:hover:text-white px-4 py-3 lg:pr-1 flex items-center whitespace-nowrap"
                  >
                    {text}
                  </a>
                  <button
                    type="button"
                    class="hidden lg:inline-flex items-center justify-center self-stretch py-3 pr-3 pl-0.5 text-default hover:text-link dark:hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/40 rounded"
                    aria-expanded="false"
                    aria-haspopup="true"
                    aria-label={`Apri sottomenu ${text}`}
                    data-aw-dropdown-toggle
                  >
                    <Icon name="tabler:chevron-down" class="w-3.5 h-3.5" aria-hidden="true" />
                  </button>
                </div>
                <ul class="dropdown-menu list-none m-0 lg:backdrop-blur-md dark:lg:bg-dark rounded lg:absolute pl-4 lg:pl-0 lg:hidden font-medium lg:bg-white/90 lg:min-w-[200px] drop-shadow-xl">
                  {links.map(({ text: subText, href: subHref }, index) => {
                    if (subText === 'divider') return null;

                    const isTuttiServizi = subText === 'Tutti i servizi';
                    const isOnServiziPage = currentPath === '/servizi';
                    const finalHref =
                      isTuttiServizi && isOnServiziPage ? '#servizi-principali' : subHref;
                    const afterDivider = index > 0 && links[index - 1]?.text === 'divider';

                    return (
                      <li class:list={['list-none', afterDivider && 'border-t border-gray-200 dark:border-gray-700 mt-1 pt-1']}>
                        <a
                          href={finalHref}
                          class:list={[
                            'block py-2 px-5 first:rounded-t last:rounded-b hover:text-link dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-700 whitespace-nowrap',
                            { 'aw-link-active': subHref === currentPath },
                          ]}
                        >
                          {subText}
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </>
            ) : (
              <a
                href={href}
                {...(href === '/blog' ? { 'data-astro-reload': true } : {})}
                class:list={[
                  'hover:text-link dark:hover:text-white px-4 py-3 flex items-center whitespace-nowrap',
                  { 'aw-link-active': href === currentPath },
                ]}
              >
                {text}
              </a>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <!-- Right: azioni (desktop) -->
    <div
      class:list={[
        { 'ml-auto rtl:ml-0 rtl:mr-auto': position === 'left' },
        'flex flex-col lg:flex lg:flex-row items-stretch lg:items-center w-full lg:w-auto justify-end max-lg:border-t max-lg:border-neutral-200 max-lg:dark:border-neutral-700 max-lg:p-3 lg:p-0 lg:justify-self-end',
      ]}
    >
      <div class="hidden lg:flex items-center w-full lg:w-auto justify-between">
        <div class="flex items-center gap-2">
          {showToggleTheme && <ToggleTheme iconClass="w-5 h-5" />}
          {showRssFeed && (
            <a
              href={getAsset('/rss.xml')}
              aria-label="RSS Feed"
              class="text-muted dark:text-gray-300 p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700"
              rel="alternate"
              title="RSS feed"
            >
              <Icon name="tabler:rss" class="w-5 h-5" />
            </a>
          )}
        </div>

        {actions.length > 0 && (
          <span class="ml-4 lg:ml-0">
            {actions.map((btn) => (
              <Button {...btn} class="ml-2 py-2.5 px-5.5 lg:px-6 font-semibold text-sm shadow-none" />
            ))}
          </span>
        )}
      </div>

      {actions.length > 0 && (
        <div class="lg:hidden w-full pt-1">
          {actions.map((btn) => (
            <Button {...btn} class="w-full justify-center py-2.5 px-5.5 font-semibold text-sm shadow-none" />
          ))}
        </div>
      )}
    </div>
    </div>
  </div>
</header>
