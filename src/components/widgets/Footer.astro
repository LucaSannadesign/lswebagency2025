---
import { Icon } from 'astro-icon/components';
import { getHomePermalink, getAsset } from '@/utils/permalinks';

interface Link {
  text?: string;
  href: string;
  ariaLabel?: string;
  icon?: string;
}

export interface Props {
  socialLinks?: Link[];
  secondaryLinks?: Link[];
  footNote?: string;
  theme?: 'light' | 'dark';
}

const {
  socialLinks = [],
  secondaryLinks = [],
  theme = 'light',
  footNote,
} = Astro.props;

/** Navigazione principale footer */
const NAV_MAIN = [
  { text: 'Home', href: '/' },
  { text: 'Chi siamo', href: '/chi-siamo' },
  { text: 'Servizi', href: '/servizi' },
  { text: 'Portfolio', href: '/portfolio' },
  { text: 'Blog', href: '/blog' },
  { text: 'Contatti', href: '/contatti' },
];

/** Link servizi strategici (max 3) */
const NAV_SERVICES = [
  { text: 'Sito web strategico', href: '/servizi/siti-web' },
  { text: 'Ottimizzazione SEO', href: '/servizi/ottimizzazione-seo-siti-web' },
  { text: 'AI e automazioni', href: '/servizi/assistente-ai-sito-whatsapp' },
];

/** Social di default aggiornati */
const DEFAULT_SOCIAL: Link[] = [
  { href: 'https://www.linkedin.com/in/lucasannadesign', icon: 'tabler:brand-linkedin', ariaLabel: 'LinkedIn' },
  { href: 'https://www.instagram.com/ls_web_agency', icon: 'tabler:brand-instagram', ariaLabel: 'Instagram' },
  { href: 'https://www.facebook.com/lswebdesignagency', icon: 'tabler:brand-facebook', ariaLabel: 'Facebook' },
];

const SOCIAL = socialLinks.length ? socialLinks : DEFAULT_SOCIAL;
---

<footer class={`relative border-t border-gray-200 dark:border-slate-800 not-prose ${theme === 'dark' ? 'dark' : ''}`}>
  <div class="dark:bg-dark absolute inset-0 pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 dark:text-gray-200">
    <div class="grid grid-cols-12 gap-x-6 gap-y-6 py-6 md:py-8 lg:gap-y-6">
      <!-- Colonna 1 — Brand -->
      <div class="col-span-12 order-1 lg:col-span-3">
        <a class="inline-flex items-center mb-2" href={getHomePermalink()} aria-label="Torna alla Home">
          <img src="/images/logo-ls-webdesignagency-2025.svg" alt="LS Web Agency" class="h-9 w-auto dark:hidden" />
          <img src="/images/logo-ls-webdesignagency-2025-bn.svg" alt="LS Web Agency" class="h-9 w-auto hidden dark:block" />
        </a>

        <p class="text-sm leading-relaxed text-gray-600 dark:text-gray-400 max-w-xs">
          Siti web strategici, SEO e soluzioni digitali per professionisti e piccole imprese.
        </p>

        {SOCIAL.length > 0 && (
          <div class="mt-3">
            <span class="sr-only">Social</span>
            <div class="flex items-center gap-2.5">
              {SOCIAL.map(({ href, icon, ariaLabel }) => (
                <a
                  href={href}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={ariaLabel}
                  class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-black text-white hover:bg-gray-800 transition focus:outline-none focus-visible:ring-2 focus-visible:ring-white/40 focus-visible:ring-offset-2"
                >
                  {icon && <Icon name={icon} class="w-4 h-4" />}
                </a>
              ))}
              <a
                href={getAsset('/rss.xml')}
                rel="alternate"
                aria-label="Feed RSS del blog"
                title="Feed RSS del blog"
                class="hidden md:inline-flex h-9 w-9 items-center justify-center rounded-full bg-black text-white hover:bg-gray-800 transition focus:outline-none focus-visible:ring-2 focus-visible:ring-white/40 focus-visible:ring-offset-2"
              >
                <Icon name="tabler:rss" class="w-4 h-4" />
              </a>
            </div>
          </div>
        )}
      </div>

      <!-- Colonna 2 — Azienda -->
      <div class="col-span-12 order-4 sm:col-span-6 lg:order-2 lg:col-span-3">
        <div class="font-medium mb-1.5 text-gray-800 dark:text-gray-200">Dove siamo</div>
        <address class="not-italic text-sm leading-relaxed text-gray-600 dark:text-gray-400">
          LS Web Agency di{' '}
          <a
            href="https://www.lucasanna.eu/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-700 dark:text-gray-300 hover:underline hover:text-indigo-700 dark:hover:text-white transition"
          >Luca Sanna</a><br />
          Via Alcide De Gasperi, 3<br />
          07100 Sassari, Sardegna, Italia<br />
          P. IVA: 02929290902
        </address>
      </div>

      <!-- Colonna 3 — Navigazione / Servizi -->
      <div class="col-span-12 order-3 sm:col-span-6 lg:order-3 lg:col-span-3">
        <div class="font-medium mb-1.5 text-gray-800 dark:text-gray-200">Navigazione</div>
        <nav aria-label="Navigazione footer">
          <ul class="space-y-0.5 text-sm">
            {NAV_MAIN.map(({ text, href }) => (
              <li>
                <a
                  href={href}
                  {...(href === '/blog' ? { 'data-astro-reload': true } : {})}
                  class="text-gray-700 dark:text-gray-300 hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-black/20 dark:focus-visible:ring-white/30"
                >
                  {text}
                </a>
              </li>
            ))}
          </ul>
          <p class="mt-3 mb-1 text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">
            Servizi principali
          </p>
          <ul class="space-y-0.5 text-sm">
            {NAV_SERVICES.map(({ text, href }) => (
              <li>
                <a
                  href={href}
                  class="text-gray-600 dark:text-gray-400 hover:underline hover:text-gray-900 dark:hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-black/20 dark:focus-visible:ring-white/30"
                >
                  {text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

      <!-- Colonna 4 — Contatto / CTA -->
      <div class="col-span-12 order-2 lg:order-4 lg:col-span-3">
        <div class="font-medium mb-1.5 text-gray-800 dark:text-gray-200">Richiedi una consulenza</div>
        <p class="text-sm leading-relaxed text-gray-600 dark:text-gray-400">
          Hai un progetto web, SEO o AI? Scrivimi per una prima valutazione.
        </p>
        <p class="mt-2 text-sm">
          <a
            href="mailto:info@lswebagency.com"
            class="font-medium text-gray-800 dark:text-gray-200 hover:underline transition"
          >
            info@lswebagency.com
          </a>
        </p>

        <div class="mt-3 flex items-center gap-2.5">
          <a
            href="https://wa.me/393403223494"
            aria-label="Scrivici su WhatsApp"
            class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-black text-white hover:bg-gray-800 transition focus:outline-none focus-visible:ring-2 focus-visible:ring-white/40 focus-visible:ring-offset-2"
          >
            <Icon name="tabler:brand-whatsapp" class="w-4 h-4" />
          </a>
          <a
            href="https://t.me/lswebagency"
            aria-label="Scrivici su Telegram"
            class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-black text-white hover:bg-gray-800 transition focus:outline-none focus-visible:ring-2 focus-visible:ring-white/40 focus-visible:ring-offset-2"
          >
            <Icon name="tabler:brand-telegram" class="w-4 h-4" />
          </a>
        </div>

        <a
          href="/contatti"
          class="mt-4 inline-flex items-center justify-center min-h-[40px] rounded-full px-4 py-2 text-sm font-semibold bg-violet-600 text-white hover:bg-violet-700 hover:text-white hover:shadow-md dark:bg-violet-600 dark:hover:bg-violet-500 dark:hover:text-white transition focus:outline-none focus-visible:text-white focus-visible:ring-2 focus-visible:ring-violet-500 focus-visible:ring-offset-2"
        >
          Vai al form contatti
        </a>

        {secondaryLinks.length > 0 && (
          <div class="mt-3 flex flex-col space-y-1.5">
            {secondaryLinks.map(({ href, icon, text }) => (
              <a
                href={href}
                rel="noopener noreferrer"
                target="_blank"
                class="flex items-center space-x-2 text-sm text-gray-700 dark:text-gray-300 hover:text-neutral-900 dark:hover:text-white hover:underline transition"
              >
                {icon && <Icon name={icon} class="w-4 h-4" />}
                <span>{text}</span>
              </a>
            ))}
          </div>
        )}
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="py-4 md:py-5 border-t border-gray-200 dark:border-slate-800 max-md:pb-16">
      <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
        <p class="text-sm text-gray-600 dark:text-gray-400">
          © {new Date().getFullYear()} <strong class="text-gray-800 dark:text-gray-200">LS Web Agency</strong>. Tutti i diritti riservati.
        </p>

        <nav
          aria-label="Link legali footer"
          class="text-sm text-gray-700 dark:text-gray-300 flex flex-wrap items-center gap-x-3 gap-y-2 md:justify-end"
        >
          <a href="/privacy" class="hover:underline">Privacy & Cookie Policy</a>
          <span class="select-none hidden md:inline text-gray-400" aria-hidden="true">|</span>
          <a href="/mappa-del-sito" class="hover:underline">Mappa del sito</a>
          <span class="select-none hidden md:inline text-gray-400" aria-hidden="true">|</span>
          <button
            type="button"
            class="hover:underline underline-offset-2 text-left md:text-right"
            onclick="(window.__openConsentBanner ? window.__openConsentBanner() : (location.href='/privacy#cookie'))"
          >
            Gestisci preferenze cookie
          </button>
        </nav>
      </div>

      {footNote && (
        <p class="text-center text-xs text-gray-600 dark:text-gray-400 mt-3">
          {footNote}
        </p>
      )}
    </div>
  </div>
</footer>
