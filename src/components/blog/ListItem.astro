---
import type { ImageMetadata } from 'astro';
import { Icon } from 'astro-icon/components';
import PostTags from '~/components/blog/Tags.astro';

import { APP_BLOG } from 'astrowind:config';
import type { Post } from '~/types';

import { getPermalink } from '~/utils/permalinks';
import { getFormattedDate } from '~/utils/utils';

export interface Props {
  post: Post;
}

const { post } = Astro.props;

// Debug dell'immagine
console.log("🔍 POST IMAGE OBJECT:", post.image);
console.log("🔍 POST IMAGE TYPE:", typeof post.image);

// Controlliamo se l'immagine esiste e ha il formato corretto
const imageUrl = post.image?.src ? post.image.src : '/src/assets/images/hero-image.jpg';
const imageAlt = post.image?.alt || post.title;
const imageWidth = post.image?.width || 1200;
const imageHeight = post.image?.height || 630;
const link = typeof post.permalink === "string" ? getPermalink(post.permalink, 'post') : `/blog/${post.slug}`;
---

<article class="max-w-md mx-auto md:max-w-none grid gap-6 md:gap-8 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade md:grid-cols-2">
  <a class="relative block group" href={link}>
    <div class="relative h-0 pb-[56.25%] md:pb-[75%] md:h-72 lg:pb-[56.25%] overflow-hidden bg-gray-400 dark:bg-slate-700 rounded shadow-lg">
      {imageUrl ? (
        <img 
          src={imageUrl.startsWith("/") ? imageUrl : `/assets/images/${imageUrl}`} 
          alt={imageAlt} 
          width={imageWidth}
          height={imageHeight}
          class="absolute inset-0 object-cover w-full h-full"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="absolute inset-0 flex items-center justify-center text-gray-500 bg-gray-300 dark:bg-slate-700">
          ⚠️ Nessuna immagine disponibile
        </div>
      )}
    </div>
  </a>
  
  <div class="mt-2">
    <header>
      <div class="mb-1">
        <span class="text-sm">
          <Icon name="tabler:clock" class="w-3.5 h-3.5 inline-block -mt-0.5 dark:text-gray-400" />
          <time datetime={String(post.publishDate)} class="inline-block">{getFormattedDate(post.publishDate)}</time>
          {post.author && (
            <>
              {' '}· <Icon name="tabler:user" class="w-3.5 h-3.5 inline-block -mt-0.5 dark:text-gray-400" />
              <span>{post.author.replaceAll('-', ' ')}</span>
            </>
          )}
          {post.category && (
            <>
              {' '}·{' '}
              <a class="hover:underline" href={getPermalink(post.category.slug, 'category')}>
                {post.category.title}
              </a>
            </>
          )}
        </span>
      </div>
      <h2 class="text-xl sm:text-2xl font-bold leading-tight mb-2 font-heading dark:text-slate-300">
        <a class="inline-block hover:text-primary dark:hover:text-blue-700 transition ease-in duration-200" href={link}>
          {post.title}
        </a>
      </h2>
    </header>
    
    {post.excerpt && <p class="flex-grow text-muted dark:text-slate-400 text-lg">{post.excerpt}</p>}
    
    {post.tags && Array.isArray(post.tags) && post.tags.length > 0 ? (
      <footer class="mt-5">
        <PostTags tags={post.tags} />
      </footer>
    ) : null}
  </div>
</article>
