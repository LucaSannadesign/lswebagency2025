---
import { getPermalink } from '~/utils/permalinks';
import { getFormattedDate } from '~/utils/utils';
import type { Post } from '~/types';
import PostTags from '~/components/blog/Tags.astro';

export interface Props {
  post: Post;
}

const { post } = Astro.props;

// Corregge il percorso dell'immagine per puntare a `public/images/`
const imageUrl = post.image 
  ? `/images/${post.image.split('/').pop()}`
  : "/images/placeholder.jpg";

const imageAlt = post.title;
const link = typeof post.permalink === "string" ? getPermalink(post.permalink, 'post') : `/blog/${post.slug}`;
---

<article class="max-w-md mx-auto md:max-w-none grid gap-6 md:gap-8 md:grid-cols-2">
  <a class="relative block group" href={link}>
    <div class="relative h-0 pb-[56.25%] md:pb-[75%] md:h-72 lg:pb-[56.25%] overflow-hidden bg-gray-400 dark:bg-slate-700 rounded shadow-lg">
      <img 
        src={imageUrl} 
        alt={imageAlt} 
        class="absolute inset-0 object-cover w-full h-full"
        loading="lazy"
        decoding="async"
      />
    </div>
  </a>
  
  <div class="mt-2">
    <header>
      <div class="mb-1 text-sm">
        <time datetime={String(post.publishDate)}>{getFormattedDate(post.publishDate)}</time>
        {post.author && <> · <span>{post.author}</span></>}
        {post.category && <> · <a class="hover:underline" href={getPermalink(post.category.slug, 'category')}>{post.category.title}</a></>}
      </div>
      <h2 class="text-xl sm:text-2xl font-bold leading-tight mb-2">
        <a class="inline-block hover:text-primary transition ease-in duration-200" href={link}>
          {post.title}
        </a>
      </h2>
    </header>
    
    {post.excerpt && <p class="text-muted text-lg">{post.excerpt}</p>}
    
    {post.tags?.length > 0 && (
      <footer class="mt-5">
        <PostTags tags={post.tags} />
      </footer>
    )}
  </div>
</article>
