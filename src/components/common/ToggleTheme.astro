---
import { Icon } from "astro-icon/components";

export interface Props {
  iconClass?: string;
}

const { iconClass = 'w-6 h-6 md:w-5 md:h-5 transition-opacity duration-300' } = Astro.props;
---

<button
  type="button"
  class="flex items-center justify-center text-gray-800 dark:text-white hover:text-primary dark:hover:text-primary transition"
  aria-label="Toggle theme"
  data-theme-toggle
>
  <span class="sr-only">Toggle Theme</span>

  <!-- 🌙 Mezzaluna per la modalità Light -->
  <Icon 
    name="tabler:moon" 
    id="icon-moon"
    class={iconClass + " block dark:hidden opacity-100 transition-opacity duration-300"} 
  />

  <!-- ☀️ Sole per la modalità Dark -->
  <Icon 
    name="tabler:sun"
    id="icon-sun"
    class={iconClass + " hidden dark:block opacity-0 transition-opacity duration-300"} 
  />
</button>

<!-- ✅ SCRIPT PER GESTIRE IL TEMA -->
<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const themeToggle = document.querySelector("[data-theme-toggle]");
    const moonIcon = document.getElementById("icon-moon");
    const sunIcon = document.getElementById("icon-sun");

    function setTheme(theme) {
      document.documentElement.classList.toggle("dark", theme === "dark");
      localStorage.setItem("theme", theme);
      
      // Effetto fade sulle icone
      if (theme === "dark") {
        moonIcon.classList.add("opacity-0");
        sunIcon.classList.remove("opacity-0");
      } else {
        moonIcon.classList.remove("opacity-0");
        sunIcon.classList.add("opacity-0");
      }
    }

    function getSavedTheme() {
      return localStorage.getItem("theme") || "light"; // 🔹 Predefinito: Light
    }

    // ✅ Imposta il tema al caricamento
    const savedTheme = getSavedTheme();
    setTheme(savedTheme);

    // ✅ Cambia tema al click
    themeToggle.addEventListener("click", () => {
      const newTheme = document.documentElement.classList.contains("dark") ? "light" : "dark";
      setTheme(newTheme);
    });
  });
</script>
