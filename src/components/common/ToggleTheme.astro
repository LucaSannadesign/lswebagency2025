---
import { Icon } from 'astro-icon/components';

import { UI } from 'astrowind:config';

export interface Props {
  label?: string;
  class?: string;
  iconClass?: string;
  iconName?: string;
}

const {
  label = 'Toggle between Dark and Light mode',
  // Toggle 44×44, radius 12px, bordo lilla e icona viola (design Cloud Design).
  class:
    className =
      'inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-[#DED3EA] bg-white text-primary transition-colors hover:bg-brand-surface focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:ring-offset-2 dark:border-primary/30 dark:bg-white/5 dark:text-violet-300 dark:hover:bg-primary/20 dark:focus-visible:ring-offset-slate-900',
  iconClass = 'w-5 h-5',
  iconName = 'tabler:sun',
} = Astro.props;
---

{
  !(UI.theme && UI.theme.endsWith(':only')) && (
    <button type="button" class={className} aria-label={label} data-aw-toggle-color-scheme>
      <Icon name={iconName} class={iconClass} />
    </button>
  )
}
