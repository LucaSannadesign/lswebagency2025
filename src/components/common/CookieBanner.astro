---
import { useState } from 'preact/hooks';

const [showBanner, setShowBanner] = useState(!localStorage.getItem('cookieConsent'));

const acceptCookies = () => {
  localStorage.setItem('cookieConsent', 'true');
  setShowBanner(false);
};
---

{showBanner && (
  <div class="fixed bottom-4 left-4 right-4 bg-white dark:bg-gray-900 p-4 rounded-lg shadow-md flex justify-between items-center">
    <p class="text-sm text-gray-700 dark:text-gray-300">
      Questo sito utilizza cookie per migliorare l'esperienza. Continuando la navigazione, accetti l'uso dei cookie.
    </p>
    <button class="bg-primary text-white px-3 py-1 rounded-md hover:bg-secondary transition" onClick={acceptCookies}>
      Accetta
    </button>
  </div>
)}
