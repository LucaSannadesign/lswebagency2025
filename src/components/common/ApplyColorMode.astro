---
export interface Props {
  nonce?: string;
}

const { nonce = '' } = Astro.props;
---

<script {nonce ? `nonce=${nonce}` : ''} is:inline>
  function applyTheme(theme) {
    if (theme === 'dark') {
      document.documentElement.classList.add('dark');
      localStorage.setItem('theme', 'dark');
    } else {
      document.documentElement.classList.remove('dark');
      localStorage.setItem('theme', 'light');
    }
  }

  // ✅ Applica il tema salvato in localStorage
  const storedTheme = localStorage.getItem('theme') || 'light';
  applyTheme(storedTheme);

  // ✅ Aggiunge il listener per il pulsante di cambio tema
  document.querySelectorAll('[data-aw-toggle-color-scheme]').forEach(button => {
    button.addEventListener('click', () => {
      const newTheme = document.documentElement.classList.contains('dark') ? 'light' : 'dark';
      applyTheme(newTheme);
    });
  });
</script>
