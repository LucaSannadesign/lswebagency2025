---
import Layout from '@/layouts/PageLayout.astro';
import MiniAnalisiWidget from '@/components/MiniAnalisi';

// === SEO ===
const metadata = {
  title: 'Mini‑Analisi Guidata — LS Web Agency',
  description:
    'Rispondi a 7 domande veloci e ottieni subito priorità, servizio consigliato e fascia orientativa per il tuo progetto web. Gratis e senza impegno.',
  canonical: '/mini-analisi',
  robots: { index: true, follow: true },
};
---

<Layout metadata={metadata}>
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-violet-100 via-white to-white dark:from-violet-900/30 dark:via-transparent"></div>
    <div class="container mx-auto px-6 pt-16 pb-8 text-center">
      <span class="inline-flex items-center gap-2 rounded-full px-3 py-1 text-xs font-semibold bg-violet-100 text-violet-700 dark:bg-violet-900/40 dark:text-violet-200 ring-1 ring-violet-200/60 dark:ring-violet-700/50">
        Gratis · ~1 minuto · senza impegno
      </span>
      <h1
        class="mt-4 text-3xl md:text-5xl font-extrabold tracking-tight
               text-transparent bg-clip-text [-webkit-text-fill-color:transparent]
               bg-gradient-to-r from-black via-violet-700 to-fuchsia-400
               dark:from-white dark:via-violet-400 dark:to-fuchsia-300">
        Mini‑Analisi Guidata
      </h1>
      <p class="mt-3 max-w-2xl mx-auto text-base md:text-lg text-neutral-600 dark:text-neutral-300">
        Rispondi a poche domande sul tuo progetto. In meno di un minuto ottieni le priorità,
        il servizio più adatto e una fascia orientativa di intervento.
      </p>
    </div>
  </section>

  <!-- MINI‑ANALISI -->
  <section class="container mx-auto px-6 pb-16">
    <div class="max-w-2xl mx-auto">
      <MiniAnalisiWidget client:visible />
      <p class="mt-4 text-center text-xs text-neutral-500 dark:text-neutral-400">
        I risultati sono una stima orientativa generata dalle tue risposte e non costituiscono un preventivo.
      </p>
    </div>
  </section>
</Layout>
