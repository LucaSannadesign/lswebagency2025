<!-- Form con reCAPTCHA -->
<form id="sib-form" method="POST" action="https://sibforms.com/serve/MUIFAO-Z2RUGGmqdvs_eFuJquCwXhgbYiJUP0Mjl70sSak-P5KtVJlBs2uD7rx-jgbSXwXV-VUsYxlMzt_uyovwBoGCopPGjQ0UPDP1Li-Y4V9R0GKLRkuDrM1UI_pqZ5i1spa163EjcIllfxp5YDgU0jPksEBJOQyAa6bxgmMpwsjQNN1uq8BcfpJW7FWoDxM2xSSku48QTHCeP" data-type="subscription">
    <input type="hidden" id="recaptchaResponse" name="recaptchaResponse">
    
    <div style="padding: 8px 0;">
      <div class="sib-form-block" style="font-size:32px; text-align:center; font-weight:700; font-family:Helvetica, sans-serif; color:#3C4858;">
        <p>📩 Iscriviti alla Newsletter</p>
      </div>
    </div>
    
    <div style="padding: 8px 0;">
      <div class="sib-input sib-form-block">
        <div class="form__entry entry_block">
          <div class="form__label-row">
            <label class="entry__label" for="EMAIL" data-required="*">Inserisci il tuo indirizzo email per iscriverti</label>
            <div class="entry__field">
              <input class="input" type="text" id="EMAIL" name="EMAIL" autocomplete="off" placeholder="EMAIL" data-required="true" required />
            </div>
          </div>
        </div>
      </div>
    </div>

    <div style="padding: 8px 0;">
      <div class="sib-form-block" style="text-align: center">
        <button id="subscribe-button" class="sib-form-block__button sib-form-block__button-with-loader" type="submit">
          ISCRIVITI
        </button>
      </div>
    </div>
</form>

<script>
  document.getElementById('sib-form').addEventListener('submit', function(event) {
      event.preventDefault(); // Blocca l'invio predefinito del form

      grecaptcha.ready(function() {
          grecaptcha.execute('6LeZb_YqAAAAABWxxq80K2dC_E7lDWy1j4I3Zr9O', { action: 'submit' }).then(function(token) {
              document.getElementById('recaptchaResponse').value = token;
              document.getElementById('sib-form').submit(); // Invia il form solo dopo aver ottenuto il token
          });
      });
  });
</script>
