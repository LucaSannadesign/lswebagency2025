---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Creazione Siti Web Professionali - LS Web Agency',
  description: 'Scopri come LS Web Agency realizza siti web professionali, ottimizzati per SEO e conversioni, perfetti per aziende e professionisti.',
  permalink: '/servizi/creazione-siti-web/',
  keywords: ['creazione siti web', 'siti web professionali', 'realizzazione siti web Sassari', 'sviluppo siti web', 'web design'],
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->
  <Hero
    title="Creazione Siti Web Professionali"
    subtitle="Progettiamo e realizziamo siti web moderni, performanti e ottimizzati per i motori di ricerca."
    image={{ src: '~/assets/images/creazione-siti-web.jpg', alt: 'Creazione siti web professionali' }}
  />

  <!-- Features Widget *************** -->
  <Features
    id="features"
    tagline="Perché scegliere noi"
    title="Realizziamo siti web che fanno la differenza"
    subtitle="Ogni sito è progettato per garantire massima usabilità, design accattivante e performance elevate."
    items={[
      {
        title: 'SEO e Velocità',
        description: 'Tutti i nostri siti sono ottimizzati per Google e garantiscono tempi di caricamento rapidi.',
        icon: 'tabler:search',
      },
      {
        title: 'Mobile First',
        description: 'Siti perfetti su ogni dispositivo: desktop, tablet e smartphone.',
        icon: 'tabler:device-mobile',
      },
      {
        title: 'Design Unico',
        description: 'Creiamo esperienze visive che rispecchiano il tuo brand e attirano clienti.',
        icon: 'tabler:palette',
      },
      {
        title: 'Conversione e UX',
        description: 'Strutture ottimizzate per migliorare l’esperienza utente e aumentare le conversioni.',
        icon: 'tabler:graph',
      },
    ]}
  />

  <!-- Content Widget **************** -->
  <Content
    isReversed
    tagline="Strategia e tecnologia"
    title="Come realizziamo il tuo sito web"
    items={[
      {
        title: 'Analisi e Progettazione',
        description: 'Studiamo il tuo mercato e creiamo una strategia vincente per il tuo sito.',
      },
      {
        title: 'Sviluppo e Design',
        description: 'Realizziamo un sito web su misura con design accattivante e codice pulito.',
      },
      {
        title: 'SEO e Ottimizzazione',
        description: 'Implementiamo le migliori tecniche SEO per far scalare il tuo sito su Google.',
      },
    ]}
    image={{ src: '~/assets/images/web-development.jpg', alt: 'Sviluppo siti web professionali' }}
  />

  <!-- CallToAction Widget *********** -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Richiedi un preventivo',
        href: '/contatti',
        icon: 'tabler:message',
      },
    ]}
  >
    <Fragment slot="title">Porta il tuo business online con un sito su misura</Fragment>
    <Fragment slot="subtitle">Contattaci oggi per una consulenza personalizzata.</Fragment>
  </CallToAction>
</Layout>
