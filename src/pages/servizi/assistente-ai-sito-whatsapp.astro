---
// src/pages/servizi/assistente-ai-sito-whatsapp.astro
import Layout from '@/layouts/PageLayout.astro';
import AssistantDemo from '@/components/AssistantDemo';

const metadata = {
  title: 'Assistente AI per sito e WhatsApp — LS Web Agency',
  description:
    'Un assistente configurato sui contenuti della tua attività: risponde alle domande frequenti anche fuori orario, raccoglie le richieste e facilita il passaggio a una persona quando serve.',
  canonical: '/servizi/assistente-ai-sito-whatsapp',
};
---

<Layout metadata={metadata}>
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-violet-100 via-white to-white dark:from-violet-900/40 dark:via-transparent"></div>
    <div class="container mx-auto px-6 pt-16 pb-12 text-center">
      <h1
  class="text-4xl md:text-6xl font-extrabold tracking-tight
         text-neutral-900 dark:text-white
         bg-gradient-to-r from-neutral-900 via-purple-700 to-fuchsia-500
         dark:from-neutral-100 dark:via-fuchsia-400 dark:to-pink-300
         bg-clip-text
         supports-[background-clip:text]:text-transparent
         supports-[-webkit-background-clip:text]:text-transparent">
  Assistente AI per sito e WhatsApp, con controllo umano
</h1>
      <p class="mt-4 max-w-3xl mx-auto text-base md:text-lg text-neutral-600 dark:text-neutral-300">
        Configurato sui contenuti della tua attività, risponde alle domande frequenti, raccoglie le richieste e facilita il passaggio a una persona quando serve.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a href="#demo-assistente" class="inline-flex items-center justify-center rounded-full px-5 py-3 text-white bg-violet-600 hover:bg-violet-700 transition">
          Prova la demo
        </a>
        <a href="/contatti?servizio=assistente-ai" class="inline-flex items-center justify-center rounded-full px-5 py-3 text-white bg-black hover:opacity-90 transition">
          Richiedi una valutazione
        </a>
      </div>

      <!-- Micro-trust -->
      <p class="mt-8 text-sm text-neutral-500 dark:text-neutral-400">
        Modulo configurabile del sistema digitale · controllo umano · adatto a professionisti e PMI
      </p>
    </div>
  </section>

  <!-- DEMO GUIDATA (simulazione, nessun dato salvato) -->
  <section id="demo-assistente" class="container mx-auto px-6 pt-4 pb-10 scroll-mt-24">
    <div class="max-w-2xl mx-auto text-center mb-6">
      <h2 class="text-2xl md:text-3xl font-bold">Prova l’assistente (simulazione)</h2>
      <p class="mt-2 text-neutral-600 dark:text-neutral-300">
        Un esempio di come l’assistente può rispondere ai tuoi clienti. È una demo guidata: non salva dati e non sostituisce la configurazione sulla tua attività.
      </p>
    </div>
    <div class="max-w-2xl mx-auto">
      <AssistantDemo client:visible />
    </div>
  </section>

  <!-- BENEFICI -->
  <section class="container mx-auto px-6 pt-6 pb-2">
    <div class="grid md:grid-cols-3 gap-5">
      <div class="rounded-2xl p-6 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/70 dark:bg-neutral-900/50 shadow-sm">
        <h3 class="font-semibold text-lg mb-2">Risposte automatiche anche fuori orario</h3>
        <p class="text-neutral-600 dark:text-neutral-300">Chi scrive la sera o nel weekend riceve una risposta automatica sulle domande frequenti, con la richiesta registrata per il ricontatto.</p>
      </div>
      <div class="rounded-2xl p-6 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/70 dark:bg-neutral-900/50 shadow-sm">
        <h3 class="font-semibold text-lg mb-2">Richieste raccolte con ordine</h3>
        <p class="text-neutral-600 dark:text-neutral-300">Le richieste arrivano con i dati necessari al ricontatto, invece di restare sparse tra canali diversi.</p>
      </div>
      <div class="rounded-2xl p-6 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/70 dark:bg-neutral-900/50 shadow-sm">
        <h3 class="font-semibold text-lg mb-2">Passaggio umano configurabile</h3>
        <p class="text-neutral-600 dark:text-neutral-300">Le regole di inoltro a una persona vengono definite insieme: parole chiave, argomenti o richiesta esplicita dell’utente.</p>
      </div>
    </div>
  </section>

  <!-- FEATURE -->
  <section class="container mx-auto px-6 py-10">
    <h2 class="text-2xl md:text-3xl font-bold mb-6">Cosa fa (in concreto)</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        {t:'FAQ su sito e WhatsApp',d:'Orari, sedi, servizi, modalità di contatto: risposte coerenti con i contenuti che fornisci.'},
        {t:'Raccolta delle richieste',d:'Le richieste vengono registrate in modo ordinato, con i recapiti necessari al ricontatto.'},
        {t:'Passaggio a una persona',d:'Regole configurabili per indirizzare la conversazione ai contatti o a WhatsApp.'},
        {t:'Tono di voce',d:'Linguaggio e contesto impostati sui materiali della tua attività, aggiornabili nel tempo.'},
        {t:'Log delle conversazioni',d:'Le conversazioni registrate permettono di rivedere e correggere le risposte.'},
        {t:'Integrazione sul sito',d:'Widget leggero sul sito. Il canale WhatsApp dipende dal tipo di utilizzo.'},
      ].map(item => (
        <div class="rounded-2xl p-6 bg-gradient-to-b from-neutral-50 to-white dark:from-neutral-900/40 dark:to-neutral-900 ring-1 ring-neutral-200 dark:ring-neutral-800 shadow-sm">
          <div class="mb-2 font-semibold">{item.t}</div>
          <p class="text-neutral-600 dark:text-neutral-300">{item.d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- TIMELINE -->
  <section class="container mx-auto px-6 py-6">
    <h2 class="text-2xl md:text-3xl font-bold mb-6">Come funziona</h2>
    <div class="grid md:grid-cols-4 gap-4">
      {[
        ['Onboarding','Invia FAQ reali, link, listino/menu, policy, orari.'],
        ['Configurazione','Creiamo la base di conoscenza e i flussi di inoltro.'],
        ['Integrazione & test','Widget sul sito ed eventuale canale WhatsApp; test su casi reali.'],
        ['Go-live & tuning','Monitoraggio, log e correzioni delle risposte.'],
      ].map(([title,desc],i)=>(
        <div class="relative rounded-2xl p-5 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/70 dark:bg-neutral-900/50 shadow-sm">
          <div class="flex items-center gap-2 mb-2">
            <span class="inline-flex w-8 h-8 items-center justify-center rounded-full bg-violet-600 text-white font-bold">{i+1}</span>
            <h3 class="font-semibold">{title}</h3>
          </div>
          <p class="text-sm text-neutral-600 dark:text-neutral-300">{desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- CAPACITÀ -->
  <section class="container mx-auto px-6 py-8">
    <div class="grid sm:grid-cols-3 gap-4 text-center">
      <div class="rounded-2xl p-6 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/70 dark:bg-neutral-900/50 shadow-sm">
        <div class="font-semibold text-lg">FAQ sempre disponibili</div>
        <div class="mt-2 text-sm text-neutral-600 dark:text-neutral-300">Le domande frequenti ricevono una risposta automatica in qualsiasi momento.</div>
      </div>
      <div class="rounded-2xl p-6 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/70 dark:bg-neutral-900/50 shadow-sm">
        <div class="font-semibold text-lg">Richieste raccolte con ordine</div>
        <div class="mt-2 text-sm text-neutral-600 dark:text-neutral-300">Ogni richiesta viene registrata con i dati utili al ricontatto.</div>
      </div>
      <div class="rounded-2xl p-6 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/70 dark:bg-neutral-900/50 shadow-sm">
        <div class="font-semibold text-lg">Controllo e passaggio umano</div>
        <div class="mt-2 text-sm text-neutral-600 dark:text-neutral-300">Le regole di inoltro a una persona restano sotto il tuo controllo.</div>
      </div>
    </div>

    <!-- Chiarimento disponibilità -->
    <div class="mt-6 rounded-2xl p-6 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/70 dark:bg-neutral-900/50">
      <h2 class="text-xl font-bold mb-2">Disponibilità: cosa è automatico e cosa è umano</h2>
      <p class="text-neutral-600 dark:text-neutral-300">
        Le risposte automatiche possono essere disponibili in qualsiasi momento. Il passaggio e la risposta umana avvengono negli orari concordati.
      </p>
    </div>
  </section>

  <!-- CONFIGURAZIONE E COSTI -->
  <section id="configurazione" class="container mx-auto px-6 py-10 scroll-mt-24">
    <h2 class="text-2xl md:text-3xl font-bold mb-4">Configurazione e costi</h2>
    <p class="max-w-3xl text-neutral-600 dark:text-neutral-300">
      Il perimetro dipende dai canali, dal numero di flussi, dalle integrazioni e dal volume delle richieste. Dopo la valutazione ricevi una proposta che distingue configurazione, eventuali costi di servizi esterni e gestione opzionale.
    </p>

    <div class="mt-6 grid md:grid-cols-2 gap-6">
      <div class="rounded-2xl p-6 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/70 dark:bg-neutral-900/50 shadow-sm">
        <h3 class="font-semibold text-lg mb-3">Incluso nella configurazione</h3>
        <ul class="space-y-2 text-neutral-700 dark:text-neutral-300">
          <li>Analisi delle FAQ e dei contenuti</li>
          <li>Configurazione delle risposte</li>
          <li>Raccolta delle richieste</li>
          <li>Passaggio a una persona</li>
          <li>Integrazione sul sito</li>
          <li>Test iniziali</li>
        </ul>
      </div>
      <div class="rounded-2xl p-6 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/70 dark:bg-neutral-900/50 shadow-sm">
        <h3 class="font-semibold text-lg mb-3">Moduli opzionali</h3>
        <ul class="space-y-2 text-neutral-700 dark:text-neutral-300">
          <li>WhatsApp e provider esterni</li>
          <li>CRM</li>
          <li>Multilingua</li>
          <li>Flussi personalizzati</li>
          <li>Report</li>
          <li>Gestione continuativa</li>
        </ul>
      </div>
    </div>

    <div class="mt-6">
      <a href="/contatti?servizio=assistente-ai" class="inline-flex items-center justify-center rounded-full px-6 py-3 text-white bg-violet-600 hover:bg-violet-700 transition font-semibold">
        Richiedi una valutazione
      </a>
    </div>
  </section>

  <!-- WHATSAPP -->
  <section class="container mx-auto px-6 pt-2 pb-10">
    <div class="rounded-2xl p-6 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/70 dark:bg-neutral-900/50">
      <h2 class="text-xl md:text-2xl font-bold mb-3">Canale WhatsApp</h2>
      <ul class="space-y-2 text-neutral-700 dark:text-neutral-300">
        <li>L’integrazione dipende dal tipo di utilizzo previsto.</li>
        <li>Possono essere necessarie API o piattaforme esterne.</li>
        <li>Eventuali costi di terzi vengono indicati separatamente nel preventivo.</li>
      </ul>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container mx-auto px-6 py-10">
    <h2 class="text-2xl md:text-3xl font-bold mb-6">FAQ</h2>
    <div class="space-y-3">
      {[
        ['L’assistente è multilingua?', 'Può rispondere in più lingue partendo dalle FAQ fornite. Consigliamo comunque una lingua principale.'],
        ['Come vengono trattati i dati?', 'Il servizio viene configurato applicando minimizzazione dei dati, regole di conservazione e controllo degli accessi. La configurazione definitiva dipende dagli strumenti utilizzati e dai trattamenti del cliente e non costituisce certificazione o consulenza legale.'],
        ['Serve WhatsApp Business API?', 'Dipende dall’uso: per risposte base può bastare WhatsApp Business. Per automazioni avanzate valutiamo insieme API o piattaforme esterne, con i relativi costi indicati separatamente nel preventivo.'],
        ['Quando passa a un umano?', 'In base a regole configurabili: parole chiave (es. “reclamo”), argomenti sensibili o richiesta esplicita dell’utente. La risposta umana avviene negli orari concordati.'],
        ['Cosa include la gestione opzionale?', 'Monitoraggio, piccoli aggiustamenti alle risposte e ai flussi, supporto tecnico standard. Migliorie strutturali o nuovi flussi vengono valutati a parte.'],
        ['Cosa non fa l’assistente?', 'Non prende decisioni legali o mediche, non gestisce pagamenti diretti in chat né sostituisce il servizio clienti umano in casi complessi.'],
        ['Serve un CRM?', 'No, non è obbligatorio. Possiamo esportare i log oppure integrare un CRM in seguito, come modulo opzionale.'],
        ['Quanto dura l’attivazione?', 'Indicativamente 5–10 giorni lavorativi, in base alla qualità delle FAQ e dei materiali forniti.'],
      ].map(([q,a]) => (
        <details class="rounded-2xl p-4 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/70 dark:bg-neutral-900/50">
          <summary class="font-semibold cursor-pointer">{q}</summary>
          <p class="mt-2 text-neutral-600 dark:text-neutral-300">{a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- CTA FINALE -->
  <section class="container mx-auto px-6 pb-10">
    <div class="rounded-3xl p-8 md:p-12 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-gradient-to-br from-violet-950 via-neutral-900 to-fuchsia-950 text-white">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-extrabold mb-4">Vuoi valutare un assistente su sito e WhatsApp?</h2>
        <p class="text-lg text-white/80 leading-relaxed mb-6">
          Raccontaci come gestisci oggi le richieste: dopo la valutazione ricevi una proposta con il perimetro e i prossimi passi.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="#demo-assistente" class="inline-flex items-center justify-center px-7 py-3 rounded-full font-semibold bg-white text-neutral-900 hover:bg-white/90">
            Prova la demo
          </a>
          <a href="/contatti?servizio=assistente-ai" class="inline-flex items-center justify-center px-7 py-3 rounded-full font-semibold border border-white/30 hover:bg-white/10">
            Richiedi una valutazione
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Sticky CTA mobile -->
  <div class="fixed bottom-4 inset-x-0 px-4 md:hidden z-40">
    <div class="rounded-full bg-white/90 dark:bg-neutral-900/90 shadow-lg backdrop-blur flex gap-2 p-2 ring-1 ring-neutral-200 dark:ring-neutral-800">
      <a href="#demo-assistente" class="flex-1 inline-flex items-center justify-center rounded-full px-4 py-2 text-white bg-violet-600 hover:bg-violet-700 transition">Demo</a>
      <a href="/contatti?servizio=assistente-ai" class="flex-1 inline-flex items-center justify-center rounded-full px-4 py-2 bg-black text-white hover:opacity-90 transition">Valutazione</a>
    </div>
  </div>

  <!-- JSON-LD combinato -->
  <script type="application/ld+json" is:inline>
  [{
    "@context":"https://schema.org",
    "@type":"Service",
    "name":"Assistente AI per sito e WhatsApp",
    "areaServed":"IT",
    "provider":{"@type":"Organization","name":"LS Web Agency"},
    "description":"Assistente configurato sui contenuti dell’attività: risponde alle domande frequenti, raccoglie le richieste e facilita il passaggio a una persona quando serve. Le risposte automatiche possono essere disponibili in qualsiasi momento; il passaggio e la risposta umana avvengono negli orari concordati."
  },{
    "@context":"https://schema.org",
    "@type":"FAQPage",
    "mainEntity":[
      {"@type":"Question","name":"L’assistente è multilingua?","acceptedAnswer":{"@type":"Answer","text":"Può rispondere in più lingue partendo dalle FAQ fornite. Consigliamo comunque una lingua principale."}},
      {"@type":"Question","name":"Come vengono trattati i dati?","acceptedAnswer":{"@type":"Answer","text":"Il servizio viene configurato applicando minimizzazione dei dati, regole di conservazione e controllo degli accessi. La configurazione definitiva dipende dagli strumenti utilizzati e dai trattamenti del cliente e non costituisce certificazione o consulenza legale."}},
      {"@type":"Question","name":"Serve WhatsApp Business API?","acceptedAnswer":{"@type":"Answer","text":"Dipende dall’uso: per risposte base può bastare WhatsApp Business. Per automazioni avanzate valutiamo insieme API o piattaforme esterne, con i relativi costi indicati separatamente nel preventivo."}},
      {"@type":"Question","name":"Quando passa a un umano?","acceptedAnswer":{"@type":"Answer","text":"In base a regole configurabili: parole chiave, argomenti sensibili o richiesta esplicita dell’utente. La risposta umana avviene negli orari concordati."}},
      {"@type":"Question","name":"Cosa include la gestione opzionale?","acceptedAnswer":{"@type":"Answer","text":"Monitoraggio, piccoli aggiustamenti alle risposte e ai flussi, supporto tecnico standard. Migliorie strutturali o nuovi flussi vengono valutati a parte."}},
      {"@type":"Question","name":"Cosa non fa l’assistente?","acceptedAnswer":{"@type":"Answer","text":"Non prende decisioni legali o mediche, non gestisce pagamenti diretti in chat né sostituisce il servizio clienti umano in casi complessi."}},
      {"@type":"Question","name":"Serve un CRM?","acceptedAnswer":{"@type":"Answer","text":"No, non è obbligatorio. Possiamo esportare i log oppure integrare un CRM in seguito, come modulo opzionale."}},
      {"@type":"Question","name":"Quanto dura l’attivazione?","acceptedAnswer":{"@type":"Answer","text":"Indicativamente 5–10 giorni lavorativi, in base alla qualità delle FAQ e dei materiali forniti."}}
    ]
  },{
    "@context":"https://schema.org",
    "@type":"BreadcrumbList",
    "itemListElement":[
      {"@type":"ListItem","position":1,"name":"Servizi","item":"/servizi"},
      {"@type":"ListItem","position":2,"name":"Assistente AI per sito e WhatsApp","item":"/servizi/assistente-ai-sito-whatsapp"}
    ]
  }]
  </script>
</Layout>
