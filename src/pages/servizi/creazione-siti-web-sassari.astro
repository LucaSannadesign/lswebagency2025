---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Layout from '~/layouts/PageLayout.astro';
import Button from '~/components/ui/Button.astro'; // ✅ Import del componente Button

const metadata = {
  title: 'Creazione Siti Web a Sassari - LS Web Agency',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Servizi"
    title="Creazione Siti Web a Sassari - LS Web Agency"
    subtitle="Realizziamo siti web professionali su misura, ottimizzati per SEO e performance elevate."
  >
    <Fragment slot="actions">
      <Button variant="primary" href="/contatti">Richiedi una consulenza</Button>
    </Fragment>
  </Hero>

  <Content>
    <h2>Perché scegliere LS Web Agency?</h2>
    <p>Nel mondo digitale di oggi, avere un <strong>sito web professionale</strong> è fondamentale. Ci occupiamo della creazione di siti web su misura.</p>
  </Content>

  <Features2
    items={[
      { title: 'Design Moderno', description: 'Ogni sito è progettato per offrire un’esperienza utente unica e coinvolgente.' },
      { title: 'Ottimizzazione SEO', description: 'Garantiamo visibilità sui motori di ricerca grazie a strategie SEO avanzate.' },
      { title: 'Siti Responsive', description: 'Perfetti su ogni dispositivo: desktop, tablet e smartphone.' }
    ]}
  />

  <CallToAction
    title="Vuoi un sito web su misura per la tua attività?"
    subtitle="Contattaci oggi stesso e trasformiamo la tua idea in realtà."
  >
    <Fragment slot="actions">
      <Button variant="primary" href="/contatti">Parliamone</Button>
    </Fragment>
  </CallToAction>
</Layout>
