---
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { Icon } from '@iconify/react';

const metadata = {
  title: 'Creazione Siti Web - LS Web Agency',
  description: 'Realizziamo siti web ottimizzati per SEO, performance elevate e un’esperienza utente impeccabile.',
};
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <Hero
  actions={[
    {
      variant: 'primary',
      text: 'Richiedi una consulenza',
      href: '/contatti',
    },
    { text: 'Portfolio', href: '/portfolio' },
  ]}
  image={{ src: '~/assets/images/creazione-sito-web-professionale.webp', alt: 'Creazione siti web', width: 800, height: 600 }}
>
  <Fragment slot="title">
    Creazione <span class="text-accent text-gradient dark:text-white highlight">Siti Web Professionali e Performanti</span>
  </Fragment>

  <Fragment slot="subtitle">
    <span class="hidden sm:inline">
      <span class="font-semibold">LS Web Agency</span> crea siti web ottimizzati per SEO, rapidi e responsive, con un design personalizzato per valorizzare il tuo brand.
    </span>
    <span class="block mb-1 sm:hidden font-bold text-blue-600">
      Trasformiamo la tua idea in un sito web vincente.
    </span>
    Perfetti per aziende, professionisti e negozi online, offriamo soluzioni su misura per la tua crescita digitale.
  </Fragment>
</Hero>

  <!-- Servizi Offerti -->
  <Features3
  title="I Nostri Servizi"
  subtitle="Soluzioni su misura per il tuo sito web"
  columns={3}
  items={[
    {
      title: 'Siti Web Personalizzati',
      description: 'Design esclusivo e funzionalità su misura per la tua attività.',
      icon: 'tabler:template',
      itemClasses: {
        panel: 'bg-white dark:bg-slate-900 shadow-lg border border-gray-200 dark:border-gray-700 p-6 rounded-lg',
      },
    },
    {
      title: 'Ottimizzazione SEO',
      description: 'Migliora il tuo posizionamento nei motori di ricerca con strategie efficaci.',
      icon: 'tabler:search',
      itemClasses: {
        panel: 'bg-white dark:bg-slate-900 shadow-lg border border-gray-200 dark:border-gray-700 p-6 rounded-lg',
      },
    },
    {
      title: 'Siti Responsive',
      description: 'Perfetti su qualsiasi dispositivo: desktop, tablet e mobile.',
      icon: 'tabler:device-desktop',
      itemClasses: {
        panel: 'bg-white dark:bg-slate-900 shadow-lg border border-gray-200 dark:border-gray-700 p-6 rounded-lg',
      },
    },
  ]}
/>

    <!-- Perché scegliere LS Web Agency -->
    <section class="py-16">
      <div class="container mx-auto px-4">
        <h2 class="text-3xl font-bold text-center mb-6">Perché scegliere noi?</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
          <div class="space-y-6">
            <div class="flex items-start space-x-4">
              <Icon icon="tabler:trophy" className="text-accent text-3xl" />
              <div>
                <h3 class="text-lg font-semibold flex items-center">
                  <Icon icon="tabler:trophy" class="mr-2 text-primary" /> Esperienza e Affidabilità
                </h3>
                <p class="text-muted">Anni di esperienza nel settore garantiscono un prodotto di qualità.</p>
              </div>
            </div>
  
            <div class="flex items-start space-x-4">
              <Icon icon="tabler:palette" className="text-accent text-3xl" />
              <div>
                <h3 class="text-lg font-semibold flex items-center">
                  <Icon icon="tabler:palette" class="mr-2 text-primary" /> Design Moderno
                </h3>
                <p class="text-muted">Interfacce curate per una navigazione intuitiva e coinvolgente.</p>
              </div>
            </div>
  
            <div class="flex items-start space-x-4">
              <Icon icon="tabler:shield-check" className="text-accent text-3xl" />
              <div>
                <h3 class="text-lg font-semibold flex items-center">
                  <Icon icon="tabler:shield-check" class="mr-2 text-primary" /> Sicurezza e Aggiornamenti
                </h3>
                <p class="text-muted">Tecnologie all’avanguardia per garantire stabilità e protezione.</p>
              </div>
            </div>
          </div>
  
          <div class="space-y-6">
            <div class="flex items-start space-x-4">
              <Icon icon="tabler:users" className="text-accent text-3xl" />
              <div>
                <h3 class="text-lg font-semibold flex items-center">
                  <Icon icon="tabler:users" class="mr-2 text-primary" /> Supporto Continuo
                </h3>
                <p class="text-muted">Ti accompagniamo dalla fase di sviluppo all'assistenza post-lancio.</p>
              </div>
            </div>
  
            <div class="flex items-start space-x-4">
              <Icon icon="tabler:graph" className="text-accent text-3xl" />
              <div>
                <h3 class="text-lg font-semibold flex items-center">
                  <Icon icon="tabler:graph" class="mr-2 text-primary" /> Strategie di Crescita
                </h3>
                <p class="text-muted">Monitoriamo il rendimento del sito per massimizzare i risultati.</p>
              </div>
            </div>
  
            <div class="flex items-start space-x-4">
              <Icon icon="tabler:device-mobile" className="text-accent text-3xl" />
              <div>
                <h3 class="text-lg font-semibold flex items-center">
                  <Icon icon="tabler:device-mobile" class="mr-2 text-primary" /> Mobile-First
                </h3>
                <p class="text-muted">Ottimizzato per smartphone e tablet per un’esperienza perfetta ovunque.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  <!-- Sezione Testimonianze -->
  <Testimonials />

  <!-- Call to Action -->
  <CallToAction
    title="Vuoi un sito web professionale?"
    subtitle="Parliamone e troviamo la soluzione perfetta per la tua attività."
  >
    <Fragment slot="actions">
      <a href="/contatti" class="btn-primary">Richiedi una consulenza</a>
    </Fragment>
  </CallToAction>
</Layout>
