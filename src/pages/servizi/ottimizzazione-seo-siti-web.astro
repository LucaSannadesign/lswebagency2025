---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';
import Button from '~/components/ui/Button.astro';

const metadata = {
  title: 'Ottimizzazione SEO a Sassari - LS Web Agency',
  description: 'Migliora la visibilità del tuo sito web con strategie avanzate di Ottimizzazione SEO a Sassari.',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Ottimizzazione SEO a Sassari"
    title="Aumenta la visibilità del tuo sito con strategie SEO efficaci"
    subtitle="Ottimizziamo il tuo sito web per scalare le classifiche di Google e aumentare il traffico organico."
    actions={[{ variant: 'primary', text: 'Richiedi una consulenza', href: '/contatti' }]}
    image={{
      src: '~/assets/images/seo-ottimizzazione-ls-webagency.webp',
      alt: 'Ottimizzazione SEO per siti web',
    }}
  />

  <!-- Introduzione alla SEO -->
  <section class="container mx-auto px-6 py-12 text-lg text-gray-700 dark:text-gray-300">
    <h2 class="text-2xl font-bold text-center text-gray-900 dark:text-white mb-6">
      Perché l'ottimizzazione SEO è fondamentale per il tuo business?
    </h2>
    <p class="text-center max-w-3xl mx-auto mb-8">
      La SEO (Search Engine Optimization) è l'insieme di strategie volte a migliorare la posizione del tuo sito nei risultati di ricerca organica.
      Un sito ben ottimizzato non solo attira più visitatori, ma converte meglio i clienti e garantisce un ritorno sull'investimento duraturo.
    </p>
  </section>

  <!-- Approfondimento sulle attività SEO -->
  <Features2
    items={[
      {
        title: 'SEO Tecnico',
        description: 'Ottimizziamo la struttura del sito per garantire velocità, sicurezza e una perfetta esperienza utente, migliorando i Core Web Vitals di Google.',
      },
      {
        title: 'SEO On-Page',
        description: 'Miglioriamo titoli, meta descrizioni, contenuti, struttura dei link interni e dati strutturati per aumentare la rilevanza della tua pagina.',
      },
      {
        title: 'SEO Off-Page',
        description: 'Gestiamo backlink di qualità, Digital PR e menzioni online per migliorare la tua autorità e la fiducia agli occhi di Google.',
      },
      {
        title: 'SEO Locale',
        description: 'Ottimizziamo il tuo sito per le ricerche locali, migliorando la scheda Google My Business e la presenza nei risultati geolocalizzati.',
      },
      {
        title: 'SEO per E-commerce',
        description: 'Ottimizziamo le schede prodotto, i filtri di ricerca e la navigazione per aumentare le conversioni e migliorare la user experience.',
      },
      {
        title: 'Analisi e Monitoraggio',
        description: 'Utilizziamo strumenti come Google Analytics, Search Console e strumenti di tracciamento avanzati per monitorare il rendimento e apportare miglioramenti continui.',
      },
    ]}
  />

  <!-- Sezione Benefici della SEO -->
  <section class="container mx-auto px-6 py-12 text-lg text-gray-700 dark:text-gray-300">
    <h2 class="text-2xl font-bold text-center text-gray-900 dark:text-white mb-6">
      I Benefici della SEO per il tuo Business
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="p-6 bg-gray-100 dark:bg-gray-800 rounded-lg shadow-md">
        <h3 class="text-xl font-semibold mb-3">🔍 Maggiore visibilità online</h3>
        <p>
          Un sito ben posizionato nei risultati di ricerca riceve più traffico e ha maggiori possibilità di conversione.
        </p>
      </div>
      <div class="p-6 bg-gray-100 dark:bg-gray-800 rounded-lg shadow-md">
        <h3 class="text-xl font-semibold mb-3">📈 Crescita del traffico organico</h3>
        <p>
          Investire nella SEO significa ottenere traffico gratuito e di qualità, senza dover dipendere dagli annunci a pagamento.
        </p>
      </div>
      <div class="p-6 bg-gray-100 dark:bg-gray-800 rounded-lg shadow-md">
        <h3 class="text-xl font-semibold mb-3">💰 ROI Elevato</h3>
        <p>
          A differenza delle campagne pubblicitarie a pagamento, i risultati della SEO sono duraturi e offrono un ritorno sull’investimento nel lungo periodo.
        </p>
      </div>
      <div class="p-6 bg-gray-100 dark:bg-gray-800 rounded-lg shadow-md">
        <h3 class="text-xl font-semibold mb-3">⚡ Esperienza utente ottimizzata</h3>
        <p>
          Un sito SEO-friendly è anche più veloce, intuitivo e accessibile, migliorando l’esperienza per gli utenti e riducendo il tasso di rimbalzo.
        </p>
      </div>
    </div>
  </section>

  <!-- Call To Action -->
  <CallToAction
    title="Vuoi un sito web su misura per la tua attività?"
    subtitle="Contattaci oggi stesso e trasformiamo la tua idea in realtà."
  >
    <Fragment slot="actions">
      <Button variant="primary" href="/contatti">Parliamone</Button>
    </Fragment>
  </CallToAction>
</Layout>
