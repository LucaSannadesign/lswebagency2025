---
import Layout from '@/layouts/PageLayout.astro';

const metadata = {
  title: 'Transizione Digitale per il Turismo | LS Web Agency',
  description: 'Supportiamo le imprese turistiche nella transizione digitale. Analisi, ottimizzazione presenza online, visibilità locale e supporto operativo.',
  canonical: 'https://www.lswebagency.com/transizione-digitale-turismo',
};
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-blue-50 to-indigo-100 dark:from-slate-950 dark:to-slate-900 py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl lg:text-6xl font-bold text-gray-900 dark:text-white mb-6">
          Più visibilità e più richieste dirette per la tua <span class="text-blue-600 dark:text-blue-300">attività turistica</span>
        </h1>
        <p class="text-xl lg:text-2xl text-gray-600 dark:text-neutral-200 mb-8 max-w-3xl mx-auto">
          Aiutiamo B&B, agriturismi, piccoli hotel e attività turistiche a migliorare sito, presenza online e acquisizione contatti con interventi digitali pratici e sostenibili.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contatti" class="bg-blue-600 text-white px-8 py-4 rounded-lg font-semibold hover:bg-blue-700 dark:hover:bg-blue-500 transition-colors">
            Richiedi una verifica preliminare
          </a>
          <a
            href="#servizi"
            class="border-2 border-blue-600 text-blue-600 px-8 py-4 rounded-lg font-semibold hover:bg-blue-50 dark:border-blue-300 dark:text-blue-200 dark:hover:bg-blue-950/40 transition-colors"
          >
            Scopri come lavoriamo
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Sezione A chi è rivolto -->
  <section class="py-16 lg:py-24 bg-white dark:bg-neutral-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 dark:text-white mb-6">
          A chi è rivolto
        </h2>
        <p class="text-lg text-gray-600 dark:text-neutral-200 max-w-3xl mx-auto">
          Questo servizio è pensato per realtà turistiche che vogliono migliorare la propria presenza online in modo concreto, chiaro e professionale.
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="text-center p-6 bg-white dark:bg-neutral-900/80 rounded-lg shadow-sm dark:shadow-black/25 dark:ring-1 dark:ring-neutral-800">
          <div class="w-16 h-16 bg-blue-100 dark:bg-blue-950/40 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-blue-600 dark:text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">B&B e affittacamere</h3>
          <p class="text-gray-600 dark:text-neutral-300">Strutture ricettive familiari che vogliono aumentare le prenotazioni dirette</p>
        </div>

        <div class="text-center p-6 bg-white dark:bg-neutral-900/80 rounded-lg shadow-sm dark:shadow-black/25 dark:ring-1 dark:ring-neutral-800">
          <div class="w-16 h-16 bg-green-100 dark:bg-green-950/40 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-600 dark:text-green-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">Agriturismi</h3>
          <p class="text-gray-600 dark:text-neutral-300">Aziende agricole con ospitalità che desiderano valorizzare la propria offerta</p>
        </div>

        <div class="text-center p-6 bg-white dark:bg-neutral-900/80 rounded-lg shadow-sm dark:shadow-black/25 dark:ring-1 dark:ring-neutral-800">
          <div class="w-16 h-16 bg-purple-100 dark:bg-purple-950/40 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-purple-600 dark:text-purple-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">Piccoli hotel indipendenti</h3>
          <p class="text-gray-600 dark:text-neutral-300">Strutture alberghiere che vogliono competere con le grandi catene</p>
        </div>

        <div class="text-center p-6 bg-white dark:bg-neutral-900/80 rounded-lg shadow-sm dark:shadow-black/25 dark:ring-1 dark:ring-neutral-800">
          <div class="w-16 h-16 bg-orange-100 dark:bg-orange-950/40 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-orange-600 dark:text-orange-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h1m4 0h1m-6 4h8m-5-10V3a1 1 0 011-1h1a1 1 0 011 1v1M5 7a2 2 0 012-2h10a2 2 0 012 2v11a2 2 0 01-2 2H7a2 2 0 01-2-2V7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">Attività esperienziali</h3>
          <p class="text-gray-600 dark:text-neutral-300">Guide, escursioni, degustazioni e servizi turistici specializzati</p>
        </div>

        <div class="text-center p-6 bg-white dark:bg-neutral-900/80 rounded-lg shadow-sm dark:shadow-black/25 dark:ring-1 dark:ring-neutral-800">
          <div class="w-16 h-16 bg-red-100 dark:bg-red-950/40 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-red-600 dark:text-red-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">Operatori turistici locali</h3>
          <p class="text-gray-600 dark:text-neutral-300">Agenzie e tour operator che operano sul territorio</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sezione Problema -->
  <section class="py-16 lg:py-24 bg-white dark:bg-neutral-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 dark:text-white mb-6">
          Le principali difficoltà che incontriamo
        </h2>
        <p class="text-lg text-gray-600 dark:text-neutral-200 max-w-3xl mx-auto">
          Molte attività turistiche si trovano ad affrontare questi problemi concreti nella gestione della presenza online
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-red-50 dark:bg-neutral-900/80 p-6 rounded-lg shadow-sm dark:shadow-black/20 dark:ring-1 dark:ring-neutral-800">
          <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">Sito poco visibile</h3>
          <p class="text-gray-600 dark:text-neutral-300">Il sito non compare nelle prime posizioni di Google quando i clienti cercano strutture nella zona.</p>
        </div>

        <div class="bg-orange-50 dark:bg-neutral-900/80 p-6 rounded-lg shadow-sm dark:shadow-black/20 dark:ring-1 dark:ring-neutral-800">
          <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">Troppe richieste via telefono</h3>
          <p class="text-gray-600 dark:text-neutral-300">I clienti non trovano facilmente informazioni e contatti chiari, generando chiamate ripetitive.</p>
        </div>

        <div class="bg-yellow-50 dark:bg-neutral-900/80 p-6 rounded-lg shadow-sm dark:shadow-black/20 dark:ring-1 dark:ring-neutral-800">
          <div class="w-12 h-12 bg-yellow-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">Dipendenza da intermediari</h3>
          <p class="text-gray-600 dark:text-neutral-300">Eccessiva dipendenza da portali di prenotazione che applicano commissioni elevate.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sezione Servizi -->
  <section id="servizi" class="py-16 lg:py-24 bg-gray-50 dark:bg-neutral-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 dark:text-white mb-6">
          I Nostri Servizi per il Turismo
        </h2>
        <p class="text-lg text-gray-600 dark:text-neutral-200 max-w-3xl mx-auto">
          Soluzioni complete per trasformare digitalmente la tua attività turistica
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-white dark:bg-neutral-900/80 p-8 rounded-lg shadow-sm dark:shadow-black/20 dark:ring-1 dark:ring-neutral-800">
          <div class="w-16 h-16 bg-blue-100 dark:bg-blue-950/40 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-blue-600 dark:text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 dark:text-white mb-4">Analisi Iniziale</h3>
          <p class="text-gray-600 dark:text-neutral-300 mb-4">
            Esaminiamo il tuo sito, la visibilità su Google e i canali di contatto per identificare le aree di miglioramento più importanti.
          </p>
          <ul class="text-gray-600 dark:text-neutral-300 space-y-2">
            <li class="flex items-center"><span class="w-2 h-2 bg-blue-600 rounded-full mr-3"></span>Audit completo della presenza online</li>
            <li class="flex items-center"><span class="w-2 h-2 bg-blue-600 rounded-full mr-3"></span>Analisi della concorrenza</li>
            <li class="flex items-center"><span class="w-2 h-2 bg-blue-600 rounded-full mr-3"></span>Identificazione target di mercato</li>
          </ul>
        </div>

        <div class="bg-white dark:bg-neutral-900/80 p-8 rounded-lg shadow-sm dark:shadow-black/20 dark:ring-1 dark:ring-neutral-800">
          <div class="w-16 h-16 bg-green-100 dark:bg-green-950/40 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-green-600 dark:text-green-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9v-9m0-9v9"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 dark:text-white mb-4">Ottimizzazione Presenza Online</h3>
          <p class="text-gray-600 dark:text-neutral-300 mb-4">
            Miglioriamo il sito web, le informazioni di contatto e la presentazione dei servizi per facilitare le prenotazioni dirette.
          </p>
          <ul class="text-gray-600 dark:text-neutral-300 space-y-2">
            <li class="flex items-center"><span class="w-2 h-2 bg-green-600 rounded-full mr-3"></span>Miglioramento posizionamento Google</li>
            <li class="flex items-center"><span class="w-2 h-2 bg-green-600 rounded-full mr-3"></span>Ottimizzazione contenuti e immagini</li>
            <li class="flex items-center"><span class="w-2 h-2 bg-green-600 rounded-full mr-3"></span>Semplificazione contatti e prenotazioni</li>
          </ul>
        </div>

        <div class="bg-white dark:bg-neutral-900/80 p-8 rounded-lg shadow-sm dark:shadow-black/20 dark:ring-1 dark:ring-neutral-800">
          <div class="w-16 h-16 bg-purple-100 dark:bg-purple-950/40 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-purple-600 dark:text-purple-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 dark:text-white mb-4">Visibilità Locale</h3>
          <p class="text-gray-600 dark:text-neutral-300 mb-4">
            Miglioriamo la presenza su Google Maps e nelle ricerche locali per intercettare i turisti che cercano strutture nella zona.
          </p>
          <ul class="text-gray-600 dark:text-neutral-300 space-y-2">
            <li class="flex items-center"><span class="w-2 h-2 bg-purple-600 rounded-full mr-3"></span>Ottimizzazione Google My Business</li>
            <li class="flex items-center"><span class="w-2 h-2 bg-purple-600 rounded-full mr-3"></span>Gestione recensioni online</li>
            <li class="flex items-center"><span class="w-2 h-2 bg-purple-600 rounded-full mr-3"></span>Local SEO specializzato</li>
          </ul>
        </div>

        <div class="bg-white dark:bg-neutral-900/80 p-8 rounded-lg shadow-sm dark:shadow-black/20 dark:ring-1 dark:ring-neutral-800">
          <div class="w-16 h-16 bg-orange-100 dark:bg-orange-950/40 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-orange-600 dark:text-orange-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192L5.636 18.364M12 2.25a9.75 9.75 0 109.75 9.75A9.75 9.75 0 0012 2.25z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 dark:text-white mb-4">Supporto Operativo</h3>
          <p class="text-gray-600 dark:text-neutral-300 mb-4">
            Assistenza continuativa per aggiornamenti, manutenzione e piccole modifiche senza dover gestire aspetti tecnici.
          </p>
          <ul class="text-gray-600 dark:text-neutral-300 space-y-2">
            <li class="flex items-center"><span class="w-2 h-2 bg-orange-600 rounded-full mr-3"></span>Controllo mensile posizionamento</li>
            <li class="flex items-center"><span class="w-2 h-2 bg-orange-600 rounded-full mr-3"></span>Aggiornamenti stagionali</li>
            <li class="flex items-center"><span class="w-2 h-2 bg-orange-600 rounded-full mr-3"></span>Supporto tecnico quando serve</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Sezione Processo -->
  <section class="py-16 lg:py-24 bg-white dark:bg-neutral-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 dark:text-white mb-6">
          Il Nostro Processo
        </h2>
        <p class="text-lg text-gray-600 dark:text-neutral-200 max-w-3xl mx-auto">
          Un approccio strutturato in 4 fasi per garantire il successo della tua transizione digitale
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-blue-600 text-white rounded-full flex items-center justify-center mx-auto mb-6 text-2xl font-bold">
            1
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Analisi</h3>
          <p class="text-gray-600 dark:text-neutral-300">
            Studiamo la tua attività, il mercato di riferimento e definiamo obiettivi chiari e misurabili.
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-green-600 text-white rounded-full flex items-center justify-center mx-auto mb-6 text-2xl font-bold">
            2
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Proposta Operativa</h3>
          <p class="text-gray-600 dark:text-neutral-300">
            Creiamo una strategia personalizzata con timeline, budget e KPI specifici per la tua realtà.
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-purple-600 text-white rounded-full flex items-center justify-center mx-auto mb-6 text-2xl font-bold">
            3
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Implementazione</h3>
          <p class="text-gray-600 dark:text-neutral-300">
            Realizziamo le soluzioni digitali pianificate con il massimo della qualità e attenzione ai dettagli.
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-orange-600 text-white rounded-full flex items-center justify-center mx-auto mb-6 text-2xl font-bold">
            4
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Ottimizzazione</h3>
          <p class="text-gray-600 dark:text-neutral-300">
            Monitoriamo i risultati e ottimizziamo continuamente per massimizzare il ROI.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sezione Vantaggi -->
  <section class="py-16 lg:py-24 bg-gradient-to-br from-blue-50 to-indigo-100 dark:from-slate-950 dark:to-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 dark:text-white mb-6">
          I risultati che puoi ottenere
        </h2>
        <p class="text-lg text-gray-600 dark:text-neutral-200 max-w-3xl mx-auto">
          Miglioramenti concreti che noterai nella gestione quotidiana della tua attività
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-white dark:bg-neutral-900/80 p-6 rounded-lg shadow-sm dark:shadow-black/20 dark:ring-1 dark:ring-neutral-800">
          <div class="flex items-center mb-4">
            <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center mr-3">
              <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Più richieste dirette</h3>
          </div>
          <p class="text-gray-600 dark:text-neutral-300">Maggiori contatti e prenotazioni che arrivano direttamente dal tuo sito web.</p>
        </div>

        <div class="bg-white dark:bg-neutral-900/80 p-6 rounded-lg shadow-sm dark:shadow-black/20 dark:ring-1 dark:ring-neutral-800">
          <div class="flex items-center mb-4">
            <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center mr-3">
              <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Meno commissioni</h3>
          </div>
