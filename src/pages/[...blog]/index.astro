---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import { Icon } from '@iconify/react';
import Button from '~/components/ui/Button.astro';
import { getImage } from 'astro:assets';
import myImageSrc from '~/assets/images/hero-image.png';

const heroImage = await getImage({
  src: myImageSrc,
  width: 1792, // ✅ Specifica la larghezza manualmente
  height: 1024, // ✅ Specifica l'altezza manualmente
});

const metadata = {
  title: 'LS Web Agency — Creazione Siti Web & Strategie Digitali',
  description: 'Migliora la tua presenza online con un sito web professionale su misura.',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Soluzioni Digitali su Misura"
    title="Migliora la tua presenza online con un sito web professionale"
    subtitle="Realizziamo siti web su misura, moderni, performanti e ottimizzati per la SEO."
    image={{
      src: heroImage.src, // ✅ Usa l'URL generato automaticamente
      alt: 'LS Web Agency - Creazione Siti Web',
      width: heroImage.width,
      height: heroImage.height
    }}
  >
    <Fragment slot="actions">
      <Button variant="primary" href="/contatti">
        <Icon icon="tabler:message" className="mr-2" /> Richiedi una consulenza
      </Button>
      <Button href="#features">Scopri di più</Button>
    </Fragment>
  </Hero>
</Layout>
