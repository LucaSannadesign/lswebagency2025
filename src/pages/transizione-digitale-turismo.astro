---
import Layout from '@/layouts/PageLayout.astro';

const pageTitle =
  "Transizione Digitale Turismo | Più visibilità e richieste dirette | LS Web Agency";
const pageDescription =
  "Aiuto B&B, affittacamere, agriturismi, case vacanza, piccoli hotel indipendenti e attività turistiche locali a migliorare sito, call to action, modulo richieste ed esperienza mobile per ottenere più richieste dirette.";
const canonical = "https://www.lswebagency.com/transizione-digitale-turismo";
const ogImage =
  "https://www.lswebagency.com/images/og/transizione-digitale-turismo.jpg";

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": "https://www.lswebagency.com/#localbusiness",
  name: "LS Web Agency",
  url: "https://www.lswebagency.com/",
  image: ogImage,
  description:
    "LS Web Agency aiuta attività locali e strutture ricettive a migliorare presenza online, conversione e raccolta contatti.",
  telephone: "+39 340 3223494",
  email: "info@lswebagency.com",
  areaServed: [
    { "@type": "AdministrativeArea", name: "Sassari" },
    { "@type": "AdministrativeArea", name: "Nord Sardegna" },
    { "@type": "Country", name: "Italia" },
  ],
  address: {
    "@type": "PostalAddress",
    addressLocality: "Sassari",
    addressRegion: "SS",
    addressCountry: "IT",
  },
  sameAs: [
    "https://www.linkedin.com/in/lucasanna-art/",
    "https://www.facebook.com/lucasannadesign/",
    "https://www.instagram.com/lucasanna_art/",
    "https://it.pinterest.com/lucasanna_art/",
  ],
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": "https://www.lswebagency.com/transizione-digitale-turismo#service",
  name: "Transizione Digitale Turismo",
  serviceType:
    "Ottimizzazione richieste dirette e conversione per strutture ricettive",
  provider: {
    "@type": "LocalBusiness",
    "@id": "https://www.lswebagency.com/#localbusiness",
  },
  url: canonical,
  description:
    "Servizio dedicato a B&B, affittacamere, agriturismi, case vacanza, piccoli hotel indipendenti e attività turistiche locali per migliorare richieste dirette, call to action, modulo richieste, esperienza mobile e gestione contatti senza rifare il sito da zero.",
  areaServed: [
    { "@type": "AdministrativeArea", name: "Sassari" },
    { "@type": "AdministrativeArea", name: "Nord Sardegna" },
    { "@type": "Country", name: "Italia" },
  ],
  audience: {
    "@type": "Audience",
    audienceType:
      "B&B, affittacamere, agriturismi, case vacanza, piccoli hotel indipendenti, attività turistiche locali",
  },
  offers: [
    {
      "@type": "Offer",
      name: "Audit richieste dirette",
      price: "99",
      priceCurrency: "EUR",
      availability: "https://schema.org/InStock",
      url: canonical,
    },
    {
      "@type": "Offer",
      name: "Setup conversione",
      price: "590",
      priceCurrency: "EUR",
      availability: "https://schema.org/InStock",
      url: canonical,
    },
    {
      "@type": "Offer",
      name: "Monitoraggio richieste",
      price: "79",
      priceCurrency: "EUR",
      availability: "https://schema.org/InStock",
      url: canonical,
    },
  ],
};
---

<Layout
  metadata={{
    title: pageTitle,
    description: pageDescription,
    canonical: canonical,
    openGraph: {
      url: canonical,
      images: [{ url: ogImage }],
      type: 'article',
    },
    twitter: {
      cardType: 'summary_large_image',
    },
    jsonLd: [localBusinessSchema, serviceSchema],
  }}
>
  <main>
      <section class="hero">
        <div class="container">
          <span class="eyebrow">Servizi digitali per turismo e ospitalità</span>

          <h1>Più visibilità e più richieste dirette per la tua attività turistica</h1>

          <p class="lead">
            Aiuto B&amp;B, affittacamere, agriturismi, case vacanza, piccoli hotel indipendenti
            e attività turistiche locali a migliorare il sito, il percorso di contatto
            e la raccolta delle richieste, così da trasformare meglio le visite in contatti utili,
            senza rifare tutto da zero.
          </p>

          <div class="hero-actions">
            <a href="#form" class="btn btn-primary">Richiedi un audit</a>
            <a href="#come-funziona" class="btn btn-secondary">Scopri come funziona</a>
          </div>

          <ul class="hero-points">
            <li>Call to action più efficaci</li>
            <li>Modulo richieste più chiaro</li>
            <li>Esperienza mobile migliorata</li>
            <li>Flusso contatti più ordinato</li>
          </ul>
        </div>
      </section>

      <section class="section">
        <div class="container narrow">
          <h2>Il problema non è solo essere online. È far lavorare davvero il sito.</h2>
          <p>
            Molte strutture turistiche hanno già un sito, una scheda Google o una presenza
            sui portali, ma questo non basta per ottenere richieste dirette in modo costante.
          </p>
          <p>
            Spesso il visitatore arriva sulla pagina, guarda alcune informazioni, ma non trova
            un percorso chiaro per contattarti, chiedere disponibilità o compiere il passo successivo.
          </p>
          <p>
            Il risultato è semplice: visite che non si trasformano in richieste, contatti poco chiari,
            gestione dispersiva e maggiore dipendenza da intermediari e commissioni.
          </p>
        </div>
      </section>

      <section class="section section-alt">
        <div class="container">
          <h2>Le difficoltà più frequenti nelle attività turistiche</h2>

          <div class="grid grid-3">
            <article class="card card-accent">
              <h3>Sito poco chiaro o poco visibile</h3>
              <p>
                La struttura online esiste, ma non comunica bene il valore della tua attività
                e non accompagna il visitatore verso un’azione concreta.
              </p>
            </article>

            <article class="card card-accent">
              <h3>Call to action poco efficaci</h3>
              <p>
                I pulsanti e gli inviti al contatto non sono abbastanza visibili, convincenti
                o posizionati nei punti giusti della pagina.
              </p>
            </article>

            <article class="card card-accent">
              <h3>Modulo richieste troppo generico</h3>
              <p>
                Molti form raccolgono poche informazioni utili oppure creano attrito,
                rendendo più difficile capire e gestire bene la richiesta.
              </p>
            </article>

            <article class="card">
              <h3>Troppe richieste via telefono o in modo dispersivo</h3>
              <p>
                Quando il sito non organizza bene il contatto, le informazioni arrivano in modo
                frammentato e richiedono più tempo per essere gestite.
              </p>
            </article>

            <article class="card">
              <h3>Esperienza mobile poco efficace</h3>
              <p>
                Su smartphone testi, pulsanti e campi possono risultare scomodi o poco leggibili,
                con il rischio di perdere richieste utili.
              </p>
            </article>

            <article class="card">
              <h3>Dipendenza da portali e intermediari</h3>
              <p>
                Se il sito non converte bene, la struttura resta più esposta a commissioni,
                intermediazioni e minore controllo sul flusso delle richieste.
              </p>
            </article>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="container narrow">
          <h2>A chi è rivolto questo servizio</h2>
          <p>
            Questo servizio è pensato per realtà turistiche che vogliono migliorare la propria
            presenza online in modo concreto, con un focus sulle richieste dirette e sulla gestione dei contatti.
          </p>
          <ul class="list-clean">
            <li>B&amp;B e affittacamere</li>
            <li>Agriturismi</li>
            <li>Case vacanza</li>
            <li>Piccoli hotel indipendenti</li>
            <li>Attività esperienziali e operatori turistici locali</li>
          </ul>
          <p>
            È una soluzione adatta soprattutto a chi vuole migliorare ciò che già esiste,
            senza affrontare subito un rifacimento completo del sito.
          </p>
        </div>
      </section>

      <section id="come-funziona" class="section section-alt">
        <div class="container">
          <h2>Come funziona</h2>

          <div class="grid grid-3">
            <article class="card step-card card-accent">
              <span class="step-number">1</span>
              <h3>Richiedi l’audit</h3>
              <p>
                Compili il form con il sito della tua struttura, la città e il tuo obiettivo principale.
                In questo modo posso analizzare la situazione con un contesto chiaro.
              </p>
            </article>

            <article class="card step-card card-accent">
              <span class="step-number">2</span>
              <h3>Ricevi una valutazione iniziale</h3>
              <p>
                Analizzo struttura della pagina, call to action, modulo richieste, esperienza mobile
                e principali punti che possono frenare le richieste dirette.
              </p>
            </article>

            <article class="card step-card card-accent">
              <span class="step-number">3</span>
              <h3>Decidi se attivare il setup</h3>
              <p>
                Se vuoi, posso occuparmi io delle ottimizzazioni principali, intervenendo in modo leggero
                e mirato per migliorare conversione, contatti e chiarezza del percorso utente.
              </p>
            </article>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="container">
          <h2>Un percorso semplice, con un primo passo chiaro</h2>
          <p class="section-intro">
            L’obiettivo non è complicare il tuo sito, ma renderlo più efficace.
            Per questo il servizio è organizzato in tre livelli progressivi.
          </p>

          <div class="grid grid-3 pricing-grid">
            <article class="card pricing-card">
              <h3>Audit richieste dirette</h3>
              <p class="price">99 €</p>
              <p class="price-copy">
                Una valutazione iniziale per capire cosa sta frenando richieste,
                contatti e conversione del sito.
              </p>
              <ul>
                <li>Analisi homepage</li>
                <li>Verifica call to action</li>
                <li>Analisi modulo richieste</li>
                <li>Controllo esperienza mobile</li>
                <li>3 criticità principali</li>
                <li>3 priorità operative</li>
              </ul>
            </article>

            <article class="card pricing-card featured card-accent">
              <span class="mini-badge">Consigliato</span>
              <h3>Setup conversione</h3>
              <p class="price">590 €</p>
              <p class="price-copy">
                Implementazione delle ottimizzazioni principali per migliorare
                il percorso di contatto e la qualità delle richieste.
              </p>
              <ul>
                <li>Ottimizzazione CTA principali</li>
                <li>Revisione o miglioramento modulo richieste</li>
                <li>Thank-you page più efficace</li>
                <li>Email automatica di risposta</li>
                <li>Micro miglioramenti UX</li>
                <li>Flusso contatti più ordinato</li>
              </ul>
            </article>

            <article class="card pricing-card">
              <h3>Monitoraggio richieste</h3>
              <p class="price">79 €/mese</p>
              <p class="price-copy">
                Un supporto leggero per controllare il funzionamento del flusso richieste
                e continuare a migliorarlo nel tempo.
              </p>
              <ul>
                <li>Controllo del flusso contatti</li>
                <li>Mini report mensile</li>
                <li>Una micro-ottimizzazione al mese</li>
                <li>Verifica form e autoresponder</li>
                <li>Supporto leggero continuativo</li>
              </ul>
            </article>
          </div>
        </div>
      </section>

      <section class="section section-alt">
        <div class="container">
          <h2>Cosa puoi ottenere</h2>

          <div class="grid grid-2">
            <article class="card card-accent">
              <h3>Più richieste dirette</h3>
              <p>
                Un percorso più chiaro aiuta il visitatore a compiere il passo successivo
                e a contattarti con maggiore facilità.
              </p>
            </article>

            <article class="card card-accent">
              <h3>Contatti più leggibili e utili</h3>
              <p>
                Un modulo meglio progettato raccoglie informazioni più utili,
                riduce la dispersione e facilita la gestione.
              </p>
            </article>

            <article class="card">
              <h3>Meno tempo perso</h3>
              <p>
                Con un flusso più ordinato, diminuiscono richieste incomplete,
                passaggi confusi e attività ripetitive.
              </p>
            </article>

            <article class="card">
              <h3>Più controllo sui risultati</h3>
              <p>
                Migliorare sito, CTA e raccolta contatti aiuta la struttura
                a lavorare con maggiore consapevolezza e autonomia.
              </p>
            </article>

            <article class="card">
              <h3>Minore dipendenza da portali</h3>
              <p>
                Rafforzare il canale diretto significa dare più valore al tuo sito
                e ridurre la dipendenza da intermediazioni esterne.
              </p>
            </article>

            <article class="card">
              <h3>Un miglioramento concreto, non dispersivo</h3>
              <p>
                Il primo obiettivo non è rifare tutto, ma intervenire sui punti
                che oggi possono limitare risultati e gestione.
              </p>
            </article>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="container narrow">
          <h2>Non un rifacimento totale. Un miglioramento mirato.</h2>
          <p>
            Questo servizio non nasce per complicare la tua presenza online con strumenti inutili
            o interventi troppo pesanti.
          </p>
          <p>
            Nasce per aiutarti a capire dove il sito perde opportunità e per intervenire
            in modo concreto su ciò che conta davvero: chiarezza, contatto, usabilità e richieste dirette.
          </p>
          <p>
            Il primo obiettivo non è rifare tutto, ma migliorare i punti che oggi possono limitare
            risultati e gestione.
          </p>
        </div>
      </section>

      <section class="section section-alt">
        <div class="container narrow">
          <h2>Domande frequenti</h2>

          <div class="faq">
            <article class="faq-item">
              <h3>Devo rifare il sito?</h3>
              <p>
                No. L’obiettivo iniziale è lavorare su miglioramenti mirati:
                call to action, modulo richieste, esperienza mobile e flusso contatti.
              </p>
            </article>

            <article class="faq-item">
              <h3>Lavori anche su WordPress?</h3>
              <p>
                Sì. Posso intervenire su WordPress e su altre configurazioni comuni,
                valutando caso per caso la soluzione più adatta.
              </p>
            </article>

            <article class="faq-item">
              <h3>Quanto tempo richiede l’audit?</h3>
              <p>
                In genere la valutazione iniziale può essere restituita entro 24–48 ore lavorative,
                salvo casi particolari.
              </p>
            </article>

            <article class="faq-item">
              <h3>È adatto anche a strutture piccole?</h3>
              <p>
                Sì. È pensato soprattutto per realtà che vogliono migliorare richieste dirette
                e gestione contatti senza affrontare subito interventi più complessi.
              </p>
            </article>

            <article class="faq-item">
              <h3>Posso acquistare solo l’audit?</h3>
              <p>
                Sì. L’audit è il primo passo e può essere richiesto anche senza attivare subito il setup.
              </p>
            </article>

            <article class="faq-item">
              <h3>Cosa succede dopo l’audit?</h3>
              <p>
                Ricevi una valutazione con criticità e priorità operative. Da lì puoi decidere
                se implementare da solo o affidare a me il setup delle ottimizzazioni principali.
              </p>
            </article>
          </div>
        </div>
      </section>

      <section id="form" class="section cta-section">
        <div class="container narrow">
          <h2>Richiedi una valutazione iniziale del sito della tua struttura</h2>
          <p>
            Compila il form per ricevere un primo riscontro su call to action, modulo richieste,
            esperienza mobile e punti che possono ridurre le richieste dirette.
          </p>

          <form method="POST" action="/api/richieste-dirette" class="lead-form">
            <div class="form-grid">
              <div class="field">
                <label for="nome">Nome e cognome</label>
                <input id="nome" name="nome" type="text" required />
              </div>

              <div class="field">
                <label for="struttura">Nome struttura</label>
                <input id="struttura" name="struttura" type="text" required />
              </div>

              <div class="field">
                <label for="sito">Sito web</label>
                <input id="sito" name="sito" type="url" required />
              </div>

              <div class="field">
                <label for="citta">Città</label>
                <input id="citta" name="citta" type="text" required />
              </div>

              <div class="field">
                <label for="email">Email</label>
                <input id="email" name="email" type="email" required />
              </div>

              <div class="field">
                <label for="telefono">Telefono</label>
                <input id="telefono" name="telefono" type="tel" />
              </div>

              <div class="field field-full">
                <label for="obiettivo">Obiettivo principale</label>
                <select id="obiettivo" name="obiettivo" required>
                  <option value="">Seleziona un obiettivo</option>
                  <option value="aumentare-richieste-dirette">Aumentare richieste dirette</option>
                  <option value="migliorare-modulo-richieste">Migliorare modulo richieste</option>
                  <option value="capire-conversione-bassa">Capire perché il sito converte poco</option>
                  <option value="migliorare-esperienza-mobile">Migliorare esperienza mobile</option>
                  <option value="altro">Altro</option>
                </select>
              </div>

              <div class="field field-full">
                <label for="messaggio">Messaggio</label>
                <textarea id="messaggio" name="messaggio" rows="5"></textarea>
              </div>
            </div>

            <button type="submit" class="btn btn-primary">Invia richiesta</button>
            <p class="form-note">
              Riceverai un primo riscontro orientativo entro 24–48 ore lavorative.
            </p>
          </form>
        </div>
      </section>

      <section class="section final-cta">
        <div class="container narrow center">
          <h2>Vuoi capire se il tuo sito sta perdendo richieste utili?</h2>
          <p>
            Parti da una valutazione iniziale e individua i punti che possono migliorare
            contatti, chiarezza e richieste dirette.
          </p>
          <a href="#form" class="btn btn-primary">Richiedi un audit</a>
        </div>
      </section>
    </main>
  </Layout>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }

  :global(*) {
    box-sizing: border-box;
  }

  .container {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
  }

  .narrow {
    width: min(820px, calc(100% - 2rem));
    margin: 0 auto;
  }

  .center {
    text-align: center;
  }

  .section {
    padding: 5rem 0;
  }

  .section-alt {
    /* usa il background ereditato dal body/layout */
  }

  .hero {
    position: relative;
    overflow: hidden;
    padding: 6rem 0 5rem;
    /* background gestito dal body/layout */
  }

  .hero .container {
    position: relative;
    z-index: 1;
    min-height: 560px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-right: min(42%, 460px);
  }

  .hero::after {
    content: "";
    position: absolute;
    top: 0;
    right: 0;
    width: min(42vw, 620px);
    height: 100%;
    background: url("/images/turismo-hero-right.webp");
    background-repeat: no-repeat;
    background-position: center center;
    background-size: contain;
    pointer-events: none;
    opacity: 1;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    min-height: 30px;
    padding: 0.2rem 0.8rem;
    margin-bottom: 1rem;
    border-radius: 999px;
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: #2b5fe8;
    background: rgba(59, 130, 246, 0.08);
    border: 1px solid rgba(59, 130, 246, 0.14);
  }

  h1,
  h2,
  h3 {
    margin: 0 0 1rem;
    line-height: 1.15;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3.7rem);
    max-width: 12ch;
    letter-spacing: -0.035em;
  }

  .section h2 {
    position: relative;
    padding-left: 1rem;
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }

  .section h2::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.14em;
    width: 4px;
    height: 1.08em;
    border-radius: 999px;
    background: linear-gradient(180deg, #2563eb 0%, #60a5fa 100%);
  }

  h2 {
    font-size: clamp(1.65rem, 3vw, 2.5rem);
  }

  h3 {
    font-size: 1.12rem;
    letter-spacing: -0.01em;
  }

  p {
    margin: 0 0 1rem;
  }

  .lead {
    font-size: 1.1rem;
    max-width: 64ch;
  }

  .section-intro {
    max-width: 64ch;
    margin-bottom: 1.5rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin: 1.8rem 0;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.92rem 1.45rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    border: 1px solid transparent;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease;
    cursor: pointer;
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn-primary {
    background: #0f172a;
    color: #ffffff;
    border-color: #0f172a;
    box-shadow: none;
  }

  .btn-primary:hover {
    background: #111827;
    border-color: #111827;
  }

  .btn-secondary {
    background: #ffffff;
    color: #111827;
    border-color: #cbd5e1;
    box-shadow: none;
  }

  .btn-secondary:hover {
    border-color: #94a3b8;
    background: #ffffff;
  }

  .hero-points,
  .list-clean {
    padding: 0;
    margin: 1.25rem 0 0;
    list-style: none;
  }

  .hero-points {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.95rem 1rem;
    max-width: 780px;
  }

  .hero-points li,
  .list-clean li,
  .pricing-card ul li {
    position: relative;
    padding-left: 1.15rem;
  }

