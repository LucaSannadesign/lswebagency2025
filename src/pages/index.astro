---
/**
 * HOMEPAGE — lswebagency.com
 *
 * Focus Keyword : "agenzia web Sassari"
 * Keyword sec.  : "siti web professionali Sassari", "SEO locale Sassari",
 *                 "sviluppo siti web Sardegna"
 */

import Layout from '@/layouts/PageLayout.astro';
import VoucherSlider from "../components/VoucherSlider.astro";
import { Icon } from 'astro-icon/components';
import { findLatestPosts } from '@/utils/blog';
import { APP_BLOG } from 'astrowind:config';
import Grid from '@/components/blog/Grid.astro';
import { getBlogPermalink } from '@/utils/permalinks';

const latestPosts = APP_BLOG.isEnabled ? await findLatestPosts({ count: 4 }) : [];

if (import.meta.env.DEV) {
  console.log('[DEBUG HOME] APP_BLOG.isEnabled:', APP_BLOG.isEnabled);
  console.log('[DEBUG HOME] latestPosts.length:', latestPosts.length);
  console.log('[DEBUG HOME] latestPosts:', latestPosts.map(p => ({ title: p.title, slug: p.slug })));
}

/* ─────────────────────────────────────────────
   META + SEO
───────────────────────────────────────────── */
const metadata = {
  title: 'Agenzia Web Sassari — Siti Web Professionali e SEO Locale | LS Web Agency',
  description:
    'LS Web Agency Sassari: realizziamo siti web professionali e strategie SEO locale per attività, studi e PMI. Analisi gratuita, risposta in 24h.',
  canonical: '/',
  robots: { index: true, follow: true },
  openGraph: {
    url: 'https://www.lswebagency.com/',
    type: 'website',
    images: [
      {
        url: 'https://www.lswebagency.com/images/og-home.jpg',
        width: 1200,
        height: 630,
        alt: 'LS Web Agency Sassari — Realizzazione siti web e SEO locale',
      },
    ],
  },
  twitter: {
    cardType: 'summary_large_image',
    handle: '@lswebagency',
    site: '@lswebagency',
  },
  ignoreTitleTemplate: true,
};

/* ─────────────────────────────────────────────
   SCHEMA — LocalBusiness
───────────────────────────────────────────── */
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['ProfessionalService', 'LocalBusiness'],
  '@id': 'https://www.lswebagency.com/#organization',
  name: 'LS Web Agency di Luca Sanna',
  alternateName: 'LS Web Agency',
  url: 'https://www.lswebagency.com',
  telephone: '+393403223494',
  email: 'info@lswebagency.com',
  priceRange: '€€',
  image: 'https://www.lswebagency.com/images/og-home.jpg',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Via Alcide De Gasperi, 3',
    addressLocality: 'Sassari',
    postalCode: '07100',
    addressRegion: 'SS',
    addressCountry: 'IT',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 40.7259,
    longitude: 8.5556,
  },
  areaServed: [
    { '@type': 'City', name: 'Sassari' },
    { '@type': 'AdministrativeArea', name: 'Sardegna' },
    { '@type': 'Country', name: 'Italia' },
  ],
  founder: {
    '@type': 'Person',
    name: 'Luca Sanna',
    url: 'https://www.lucasanna.eu',
  },
  sameAs: [
    'https://www.linkedin.com/in/lucasanna-art/',
    'https://www.facebook.com/lucasannadesign/',
    'https://www.instagram.com/lucasanna_art/',
    'https://it.pinterest.com/lucasanna_art/',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer support',
    telephone: '+393403223494',
    email: 'info@lswebagency.com',
    areaServed: 'IT',
    availableLanguage: ['it', 'en'],
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Servizi LS Web Agency',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'Realizzazione siti web professionali a Sassari' },
      },
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'SEO locale Sassari' },
      },
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'AI e automazioni per PMI' },
      },
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'Strategia digitale e supporto continuativo' },
      },
    ],
  },
};

/* ─────────────────────────────────────────────
   SCHEMA — FAQPage
───────────────────────────────────────────── */
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Quanto tempo serve per vedere risultati con la SEO?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Un sito nuovo è online in 2–4 settimane. Per Google Maps i primi miglioramenti si vedono in 30–60 giorni; i risultati SEO più solidi arrivano dopo 3–6 mesi di lavoro continuativo.',
      },
    },
    {
      '@type': 'Question',
      name: 'Quanto costa un sito web professionale a Sassari?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Ogni progetto è diverso e dipende dalle esigenze dell'attività. Dopo l'analisi gratuita prepariamo un preventivo chiaro e dettagliato, senza sorprese.",
      },
    },
    {
      '@type': 'Question',
      name: 'Devo fornire testi e immagini per il sito?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No, non è necessario. Ci occupiamo noi di testi e immagini. Se hai già del materiale, lo usiamo e lo miglioriamo.',
      },
    },
    {
      '@type': 'Question',
      name: "LS Web Agency lavora solo a Sassari o in tutta Italia?",
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Siamo a Sassari ma lavoriamo con clienti in tutta Italia. La maggior parte del lavoro avviene online, con aggiornamenti via video o telefono.',
      },
    },
    {
      '@type': 'Question',
      name: 'Posso modificare il sito da solo dopo la consegna?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sì. Ti mostriamo come fare le modifiche base (testi, immagini, prezzi). Se preferisci, possiamo gestirle noi nel servizio di assistenza continuativa.',
      },
    },
    {
      '@type': 'Question',
      name: 'Cosa succede se il sito non porta risultati?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Lavoriamo finché non funziona. Seguiamo ogni progetto nel tempo, monitoriamo i dati e miglioriamo la strategia se i risultati attesi non arrivano.',
      },
    },
  ],
};

const WHATSAPP =
  'https://wa.me/393403223494?text=Ciao%2C%20vorrei%20informazioni%20sui%20servizi%20LS%20Web%20Agency.';
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- ═══════════════════════════════════════
       HERO
  ════════════════════════════════════════ -->
  <section
    class="relative isolate bg-brand-surface dark:bg-slate-950 overflow-hidden lg:min-h-[min(40rem,88vh)] lg:bg-[url('/images/hero-webagency-client-devices.webp')] lg:bg-no-repeat lg:bg-[position:96%_center] lg:bg-[length:auto_98%]"
  >
    <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-brand-purple/20 rounded-full blur-3xl"></div>
      <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-brand-blue/20 rounded-full blur-3xl"></div>
    </div>

    <div
      class="pointer-events-none absolute inset-0 -z-10 hidden overflow-hidden dark:lg:block"
      aria-hidden="true"
    >
      <div
        class="absolute -right-[14%] top-[10%] h-[80%] w-[64%] max-w-3xl rounded-full bg-brand-blue/[0.07] blur-[100px]"
      >
      </div>
      <div
        class="absolute right-[-2%] top-[20%] h-[64%] w-[54%] max-w-2xl rounded-full bg-brand-purple/[0.055] blur-[86px]"
      >
      </div>
      <div
        class="absolute bottom-[-6%] right-[-10%] h-44 w-[min(124%,52rem)] max-w-none rounded-[100%] bg-[radial-gradient(ellipse_74%_52%_at_56%_108%,rgba(30,41,59,0.38)_0%,rgba(15,23,42,0.09)_48%,transparent_72%)] blur-xl"
      >
      </div>
    </div>

    <div class="mx-auto max-w-screen-xl px-6 md:px-8 pt-12 sm:pt-16 pb-12 lg:pb-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 lg:gap-12 gap-10 items-center">
        <div class="text-center lg:text-left order-1 min-w-0 lg:max-w-lg">
          <header>
            <h1 class="text-4xl sm:text-5xl lg:text-[3rem] xl:text-[3.5rem] font-extrabold tracking-tight leading-[1.05] hero-title">
              <span class="block"><span class="t-dark">Siti web professionali</span></span>
              <span class="block"><span class="t-violet">chiari e orientati ai contatti</span></span>
            </h1>

            <p class="mt-6 text-lg md:text-xl text-brand-ink/80 dark:text-slate-300 leading-relaxed max-w-xl mx-auto lg:mx-0">
              Per attività locali e professionisti, realizziamo siti web professionali più chiari, credibili e orientati ai contatti. Se il tuo sito è già online, un’analisi rapida è il primo passo per capire cosa migliorare e ottenere più richieste.
            </p>

            <div class="mt-4 flex flex-wrap justify-center lg:justify-start gap-2">
              <span class="px-3 py-1.5 rounded-full bg-brand-blue/10 dark:bg-brand-blue/20 text-xs font-semibold text-brand-blue">
                Sassari e da remoto in tutta Italia
              </span>
            </div>
          </header>

          <div
            class="mt-9 flex flex-col items-center gap-3 sm:flex-row sm:items-center sm:gap-3"
            aria-label="Azioni principali"
          >
            <a
              href="/contatti"
              class="w-full max-w-sm sm:w-auto inline-flex items-center justify-center whitespace-nowrap px-6 py-3 sm:px-8 sm:py-4 text-sm sm:text-base font-semibold text-white bg-brand-blue hover:bg-brand-blue/90 rounded-full shadow-lg ring-1 ring-white/20 hover:shadow-xl transform hover:-translate-y-0.5 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-blue focus-visible:ring-offset-2"
            >
              Richiedi un'analisi rapida
              <Icon name="tabler:arrow-right" class="w-5 h-5 ml-2 shrink-0" />
            </a>

            <a
              href="#servizi"
              class="w-full max-w-sm sm:w-auto inline-flex items-center justify-center whitespace-nowrap px-6 py-3 sm:px-8 sm:py-4 text-sm sm:text-base font-semibold text-brand-ink dark:text-white bg-transparent hover:bg-brand-blue/10 dark:hover:bg-brand-blue/20 rounded-full ring-1 ring-brand-ink/10 dark:ring-slate-600 transform hover:-translate-y-0.5 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-ink/20 focus-visible:ring-offset-2"
            >
              Scopri come funziona
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       SERVIZI
  ════════════════════════════════════════ -->
  <section
    id="servizi"
    class="relative isolate overflow-hidden bg-gradient-to-b from-slate-50 via-white to-slate-100/90 py-16 md:py-24 dark:from-slate-950 dark:via-slate-900 dark:to-slate-950"
  >
    <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
      <div
        class="absolute -top-28 right-[8%] h-80 w-80 rounded-full bg-brand-blue/[0.06] blur-3xl dark:bg-brand-blue/[0.11]"
      >
      </div>
      <div
        class="absolute -bottom-20 left-[4%] h-72 w-72 rounded-full bg-brand-purple/[0.05] blur-3xl dark:bg-brand-purple/[0.09]"
      >
      </div>
    </div>

    <div class="relative z-[1] mx-auto max-w-screen-xl px-6 md:px-8">
      <div class="text-center mb-12 md:mb-14">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-slate-900 dark:text-white mb-4">
          Cosa guardiamo nel tuo sito
        </h2>
        <p class="text-lg md:text-xl text-slate-600 dark:text-slate-300 max-w-4xl mx-auto leading-relaxed">
          Analizziamo la tua homepage per rendere il messaggio più chiaro, aumentare la fiducia e far arrivare più richieste di contatto. Ti indichiamo cosa funziona, cosa può frenare le richieste di contatto e quali interventi conviene affrontare per primi.
        </p>
      </div>

      <div class="mx-auto grid max-w-5xl grid-cols-1 gap-6 md:grid-cols-2 md:gap-8 lg:gap-10">
        <div
          class="rounded-2xl bg-gradient-to-br from-white to-slate-50/95 p-7 ring-1 ring-slate-200/90 shadow-[0_22px_55px_-18px_rgba(15,23,42,0.14)] md:p-9 dark:from-slate-800 dark:to-slate-900/95 dark:ring-slate-600/55 dark:shadow-[0_22px_55px_-18px_rgba(0,0,0,0.48)]"
        >
          <ul class="space-y-6 md:space-y-8 text-base md:text-lg text-slate-700 dark:text-slate-200 leading-[1.7] font-medium">
            <li class="flex items-start gap-3.5 md:gap-4">
              <Icon name="tabler:point-filled" class="w-5 h-5 shrink-0 mt-[0.35rem] text-brand-blue" />
              <span>Chiarezza del messaggio: cosa fai e per chi, senza ambiguità</span>
            </li>
            <li class="flex items-start gap-3.5 md:gap-4">
              <Icon name="tabler:point-filled" class="w-5 h-5 shrink-0 mt-[0.35rem] text-brand-blue" />
              <span>Fiducia e credibilità: segnali e contenuti che rassicurano prima della richiesta</span>
            </li>
          </ul>
        </div>
        <div
          class="rounded-2xl bg-gradient-to-br from-white to-slate-50/95 p-7 ring-1 ring-slate-200/90 shadow-[0_22px_55px_-18px_rgba(15,23,42,0.14)] md:p-9 dark:from-slate-800 dark:to-slate-900/95 dark:ring-slate-600/55 dark:shadow-[0_22px_55px_-18px_rgba(0,0,0,0.48)]"
        >
          <ul class="space-y-6 md:space-y-8 text-base md:text-lg text-slate-700 dark:text-slate-200 leading-[1.7] font-medium">
            <li class="flex items-start gap-3.5 md:gap-4">
              <Icon name="tabler:point-filled" class="w-5 h-5 shrink-0 mt-[0.35rem] text-brand-blue" />
              <span>Percorso utente: ordine delle sezioni e CTA per arrivare al contatto con meno frizioni</span>
            </li>
            <li class="flex items-start gap-3.5 md:gap-4">
              <Icon name="tabler:point-filled" class="w-5 h-5 shrink-0 mt-[0.35rem] text-brand-blue" />
              <span>Facilità di contatto: form e informazioni ben visibili e facili da usare</span>
            </li>
          </ul>
        </div>
      </div>

      <div class="mt-10 md:mt-12 text-center">
        <a
          href="/contatti"
          class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-white bg-brand-blue hover:opacity-95 rounded-full transition-all duration-200"
        >
          <span>Richiedi l’audit rapido</span>
          <Icon name="tabler:arrow-right" class="w-4 h-4" />
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       PER CHI È L'ANALISI RAPIDA
  ════════════════════════════════════════ -->
  <section class="container mx-auto px-6 py-12">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-8">
        <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 dark:text-white mb-3">
          Questa analisi rapida è utile se…
        </h2>
        <p class="text-lg text-slate-600 dark:text-slate-300">
          Se il tuo sito è già online ma porta poche richieste, l'analisi rapida serve a capire cosa migliorare prima di intervenire più a fondo. Ti diamo priorità chiare e indicazioni pratiche.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="rounded-2xl p-6 bg-white dark:bg-slate-800 ring-1 ring-slate-200 dark:ring-slate-700">
          <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100 mb-2">Sito già online, ma con poche richieste</h3>
          <p class="text-slate-600 dark:text-slate-300">
            Individuiamo cosa non convince e cosa manca per far scattare la richiesta di contatto.
          </p>
        </div>

        <div class="rounded-2xl p-6 bg-white dark:bg-slate-800 ring-1 ring-slate-200 dark:ring-slate-700">
          <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100 mb-2">Rifare il sito è davvero necessario?</h3>
          <p class="text-slate-600 dark:text-slate-300">
            Verifichiamo se bastano piccoli interventi su messaggio e CTA oppure se serve un redesign più ampio.
          </p>
        </div>

        <div class="rounded-2xl p-6 bg-white dark:bg-slate-800 ring-1 ring-slate-200 dark:ring-slate-700">
          <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100 mb-2">Servizio valido, ma poco chiaro online</h3>
          <p class="text-slate-600 dark:text-slate-300">
            Mettiamo in ordine valore, percorso utente e invito all’azione, così i visitatori capiscono e contattano.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       COME FUNZIONA
  ════════════════════════════════════════ -->
  <section class="relative bg-white dark:bg-slate-950 py-16 md:py-24">
    <div class="mx-auto max-w-screen-xl px-6 md:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-slate-900 dark:text-white mb-4">
          Un percorso semplice in 3 step
        </h2>
        <p class="text-lg md:text-xl text-slate-600 dark:text-slate-300 max-w-4xl mx-auto">
          Guardiamo il tuo sito, ti indichiamo cosa migliorare e, se vuoi, interveniamo sulle parti giuste per far crescere le richieste di contatto.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            n: '1',
            title: 'Guardiamo il tuo sito',
            text: 'Guardiamo la homepage e il percorso verso il contatto per capire cosa rende il messaggio poco chiaro o poco convincente.',
          },
          {
            n: '2',
            title: 'Ti indichiamo cosa migliorare',
            text: 'Ti segnaliamo le priorità e gli interventi più utili per aumentare chiarezza, fiducia e contatti.',
          },
          {
            n: '3',
            title: 'Se vuoi, interveniamo sul sito',
            text: 'Se serve, interveniamo sulle aree chiave e rendiamo più efficace il percorso fino alla richiesta.',
          },
        ].map(({ n, title, text }) => (
          <div class="flex flex-col items-start">
            <div class="w-12 h-12 rounded-full bg-blue-600 text-white flex items-center justify-center text-xl font-bold mb-4">
              {n}
            </div>
            <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">{title}</h3>
            <p class="text-slate-600 dark:text-slate-300">{text}</p>
          </div>
        ))}
      </div>

      <div class="mt-10 text-center">
        <a
          href="/servizi"
          class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-white bg-brand-blue hover:opacity-95 rounded-full transition-all duration-200"
        >
          <span>Scopri i servizi</span>
          <Icon name="tabler:arrow-right" class="w-4 h-4" />
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       PERCHÉ IMPORTA
  ════════════════════════════════════════ -->
  <section class="relative bg-slate-50 dark:bg-slate-900/50 py-16 md:py-24">
    <div class="mx-auto max-w-screen-xl px-6 md:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-slate-900 dark:text-white mb-6">
          Cosa cambia quando il sito è più chiaro
        </h2>

        <div class="space-y-6 text-lg text-slate-600 dark:text-slate-300 text-left">
          <p>
            Quando messaggio, struttura e call to action funzionano meglio, il sito non diventa solo più bello: diventa più utile per chi lo visita e più credibile per chi sta valutando se contattarti.
          </p>
          <p>
            <strong class="text-slate-900 dark:text-white">Si capisce subito cosa fai</strong>{' '}
            Il visitatore non deve interpretare da solo il tuo servizio.
          </p>
          <p>
            <strong class="text-slate-900 dark:text-white">Trasmette più fiducia</strong>{' '}
            Un sito più ordinato e leggibile aiuta a percepire meglio professionalità e affidabilità.
          </p>
          <p>
            <strong class="text-slate-900 dark:text-white">Accompagna meglio verso il contatto</strong>{' '}
            Quando il percorso è più chiaro, chiedere informazioni o fissare un appuntamento diventa più naturale.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       PER CHI È
  ════════════════════════════════════════ -->
  <section class="container mx-auto px-6 py-12">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-8">
        <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 dark:text-white mb-3">
          Per chi è il modo in cui lavoro
        </h2>
        <p class="text-lg text-slate-600 dark:text-slate-300">
          Lavoro meglio con attività locali, piccoli studi e professionisti che vogliono un sito più chiaro, più credibile e più utile per ricevere contatti, non solo una presenza online da aggiornare.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="rounded-2xl p-6 bg-emerald-50 dark:bg-emerald-950/20 ring-1 ring-emerald-200 dark:ring-emerald-900">
          <h3 class="text-xl font-bold text-emerald-900 dark:text-emerald-100 mb-3 flex items-center gap-2">
            <Icon name="tabler:check" class="w-6 h-6" />
            Perfetto se:
          </h3>
          <ul class="space-y-2 text-emerald-800 dark:text-emerald-200">
            <li class="flex items-start gap-2">
              <span class="text-emerald-600 leading-none mt-0.5">•</span>
              <span>Hai un'attività locale o uno studio professionale e vuoi più clienti</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-emerald-600 leading-none mt-0.5">•</span>
              <span>Vuoi apparire su Google e su Google Maps quando cercano nella tua zona</span>
