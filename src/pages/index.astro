            background-color: rgba(196, 152, 246, 0.9) !important;
          }
        </style>

        <script is:inline>
          (() => {
            console.log('[reviews] script run');
            const section = document.currentScript?.parentElement;
            if (!section) {
              console.log('[reviews] abort: no section');
              return;
            }

            const viewport = section.querySelector('[data-viewport]');
            const cards = Array.from(section.querySelectorAll('[data-card]'));
            const btnPrev = section.querySelector('[data-prev]');
            const btnNext = section.querySelector('[data-next]');
            const dotsRoot = section.querySelector('[data-dots]');
            if (!viewport || cards.length === 0) {
              console.log('[reviews] abort: no viewport or cards', {
                hasViewport: !!viewport,
                cards: cards.length,
              });
              return;
            }

            const prefersReducedMotion =
              window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

            const desktopMq =
              window.matchMedia && window.matchMedia('(min-width: 1024px)');
            const isDesktop = () => !!desktopMq && desktopMq.matches;

            const AUTOPLAY_DELAY_MS = 5200;
            let autoplayTimer = null;
            let isHovering = false;
            let isFocusWithin = false;
            let isAutoplayWrap = false;

            function stopAutoplay() {
              console.log('[reviews] stopAutoplay', { hadTimer: !!autoplayTimer });
              if (autoplayTimer) window.clearInterval(autoplayTimer);
              autoplayTimer = null;
            }

            function startAutoplay() {
              if (prefersReducedMotion) {
                console.log('[reviews] startAutoplay skip: prefers-reduced-motion');
                return;
              }
              if (!isDesktop()) {
                console.log('[reviews] startAutoplay skip: not desktop (min-width 1024px)');
                return;
              }
              if (isHovering) {
                console.log('[reviews] startAutoplay skip: hovering');
                return;
              }
              if (isFocusWithin) {
                console.log('[reviews] startAutoplay skip: focus within section');
                return;
              }
              if (cards.length <= 1) {
                console.log('[reviews] startAutoplay skip: single card');
                return;
              }

              stopAutoplay();
              console.log('[reviews] startAutoplay: interval created', AUTOPLAY_DELAY_MS);
              autoplayTimer = window.setInterval(() => {
                console.log('[reviews] autoplay tick', { current });
                // Riparte pulito dalla prima card a fine elenco
                const willWrap = current + 1 >= cards.length;
                const next = willWrap ? 0 : current + 1;
                isAutoplayWrap = willWrap;
                setActive(next, true);
                isAutoplayWrap = false;
              }, AUTOPLAY_DELAY_MS);
            }

            let current = 0;

            function cardContentScrollLeft(card) {
              const v = viewport.getBoundingClientRect();
              const c = card.getBoundingClientRect();
              return viewport.scrollLeft + (c.left - v.left);
            }

            function recalc() {
              setActive(0, false);
            }

            function setActive(index, scroll = true) {
              const prev = current;
              current = Math.max(0, Math.min(index, cards.length - 1));
              console.log('[reviews] setActive', { index, scroll, prev, current });

              cards.forEach((c, i) => c.setAttribute('aria-current', String(i === current)));

              if (dotsRoot) {
                const dots = Array.from(dotsRoot.querySelectorAll('[data-dot]'));
                dots.forEach((d) => {
                  const i = Number(d.getAttribute('data-dot'));
                  const isActive = i === current;
                  d.setAttribute('aria-current', isActive ? 'true' : 'false');
                  d.classList.toggle('bg-brand-blue/55', isActive);
                  d.classList.toggle('bg-brand-blue/25', !isActive);
                  d.classList.toggle('w-2', isActive);
                  d.classList.toggle('h-2', isActive);
                  d.classList.toggle('w-1.5', !isActive);
                  d.classList.toggle('h-1.5', !isActive);
                });
              }

              if (!scroll) return;
              const card = cards[current];
              if (!card) return;
              let left = cardContentScrollLeft(card);
              const max = Math.max(0, viewport.scrollWidth - viewport.clientWidth);
              left = Math.max(0, Math.min(max, left));
              viewport.scrollTo({
                left,
                behavior:
                  prefersReducedMotion || isAutoplayWrap ? 'auto' : 'smooth',
              });
            }

            function updateByScroll() {
              // Scegli la card più vicina all'inizio del viewport
              const anchor = viewport.scrollLeft + viewport.clientWidth * 0.15;
              let bestIndex = 0;
              let bestDist = Infinity;
              cards.forEach((card, i) => {
                const off = cardContentScrollLeft(card);
                const dist = Math.abs(off - anchor);
                if (dist < bestDist) {
                  bestDist = dist;
                  bestIndex = i;
                }
              });
              setActive(bestIndex, false);
            }

            if (viewport) {
              viewport.addEventListener('scroll', () => updateByScroll(), { passive: true });
            }

            // Pausa autoplay quando l'utente passa sopra il carousel (viewport, card, controlli).
            section.addEventListener('mouseenter', () => {
              isHovering = true;
              stopAutoplay();
            });
            section.addEventListener('mouseleave', () => {
              isHovering = false;
              startAutoplay();
            });

            // Riprende autoplay solo quando non c'e' piu' focus attivo dentro la sezione.
            section.addEventListener('focusin', () => {
              isFocusWithin = true;
              stopAutoplay();
            });
            section.addEventListener('focusout', (e) => {
              const next = e.relatedTarget;
              if (!next || !section.contains(next)) {
                isFocusWithin = false;
                startAutoplay();
              }
            });

            if (btnPrev) {
              btnPrev.addEventListener('click', () => setActive(current - 1, true));
              btnPrev.addEventListener('focusin', () => stopAutoplay());
              btnPrev.addEventListener('focusout', () => startAutoplay());
            }
            if (btnNext) {
              btnNext.addEventListener('click', () => setActive(current + 1, true));
              btnNext.addEventListener('focusin', () => stopAutoplay());
              btnNext.addEventListener('focusout', () => startAutoplay());
            }

            if (dotsRoot) {
              dotsRoot.addEventListener('click', (e) => {
                const target = e.target?.closest?.('[data-dot]');
                if (!target) return;
                const idx = Number(target.getAttribute('data-dot'));
                if (Number.isFinite(idx)) setActive(idx, true);
              });
              dotsRoot.addEventListener('focusin', () => stopAutoplay());
              dotsRoot.addEventListener('focusout', () => startAutoplay());
            }

            if (desktopMq) {
              const onDesktopChange = () => {
                if (!desktopMq.matches) stopAutoplay();
                else startAutoplay();
              };
              if (typeof desktopMq.addEventListener === 'function') {
                desktopMq.addEventListener('change', onDesktopChange);
              } else if (typeof desktopMq.addListener === 'function') {
                desktopMq.addListener(onDesktopChange);
              }
            }

            // Crea indicatori in base al numero di card (cosi' e' facile aggiungere altre recensioni in futuro).
            if (dotsRoot) {
              dotsRoot.innerHTML = '';
              cards.forEach((_, i) => {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.setAttribute('data-dot', String(i));
                btn.setAttribute('aria-label', `Vai alla recensione ${i + 1}`);
                btn.setAttribute('aria-current', i === 0 ? 'true' : 'false');
                btn.className =
                  'h-1.5 w-1.5 rounded-full bg-brand-blue/25 hover:bg-brand-blue/35 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-blue';
                dotsRoot.appendChild(btn);
              });
            }

            recalc();
            console.log('[reviews] ready', {
              cards: cards.length,
              prefersReducedMotion,
              isDesktop: isDesktop(),
            });
            // Se il cursore è già sopra il carousel al momento dell'avvio script, non partire con l'autoplay.
            try {
              isHovering = section.matches(':hover') || viewport.matches(':hover');
            } catch {
              isHovering = false;
            }
            console.log('[reviews] isHovering at boot', isHovering);
            startAutoplay();

            let resizeTimer = null;
            window.addEventListener('resize', () => {
              window.clearTimeout(resizeTimer);
              resizeTimer = window.setTimeout(() => {
                recalc();
              }, 200);
            });
          })();
        </script>
        </div>
      </div>

    </div>
  </section>

