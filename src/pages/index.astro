      <script>
        function setStatus(el: HTMLElement | null, text: string, kind: 'idle' | 'load' | 'ok' | 'err') {
          if (!el) return;
          el.textContent = text;
          const base = 'mb-4 min-h-[1.25rem] text-sm text-center ';
          if (kind === 'idle') el.className = base;
          else if (kind === 'load') el.className = base + 'text-gray-600 dark:text-gray-400';
          else if (kind === 'ok') el.className = base + 'text-green-600 dark:text-green-400';
          else el.className = base + 'text-red-600 dark:text-red-400';
        }

        function buildMessage(formData: FormData): string {
          const lines: string[] = [];
          const need = String(formData.get('need') || '').trim();
          const budget = String(formData.get('budget') || '').trim();
          const phone = String(formData.get('phone') || '').trim();
          if (need) lines.push(`Bisogno: ${need}`);
          if (budget && budget !== 'Preferisco indicarlo dopo') lines.push(`Budget indicativo: ${budget}`);
          if (phone) lines.push(`Telefono: ${phone}`);
          const body = String(formData.get('message') || '').trim();
          if (lines.length) return `${lines.join('\n')}\n\n${body}`;
          return body;
        }

        function attachContactFormHandler() {
          const form = document.getElementById('contact-form');
          if (!form || !(form instanceof HTMLFormElement)) return;

          const statusEl = document.getElementById('contact-form-status');
          const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
          if (form.dataset.contactFetchBound === '1') return;
          form.dataset.contactFetchBound = '1';

          form.addEventListener('submit', async (event) => {
            event.preventDefault();

            if (submitBtn) submitBtn.disabled = true;
            setStatus(statusEl, 'Invio in corso…', 'load');

            const formData = new FormData(form);
            const payload = {
              name: String(formData.get('name') || ''),
              email: String(formData.get('email') || ''),
              message: buildMessage(formData),
              privacy: formData.get('disclaimer') === 'on',
              company: '',
            };

            try {
              const res = await fetch('/api/contatti', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                },
                body: JSON.stringify(payload),
              });
              let body: { ok?: boolean; message?: string } = {};
              try {
                body = await res.json();
              } catch {
                body = {};
              }

              if (res.ok && body.ok === true) {
                const msg =
                  typeof body.message === 'string' ? body.message : 'Messaggio inviato con successo.';
                setStatus(statusEl, msg, 'ok');
                form.reset();
              } else {
                const msg = typeof body.message === 'string' ? body.message : 'Richiesta non riuscita.';
                setStatus(statusEl, msg, 'err');
              }
            } catch {
              setStatus(statusEl, 'Connessione non riuscita. Riprova.', 'err');
            } finally {
              if (submitBtn) submitBtn.disabled = false;
            }
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', attachContactFormHandler);
        } else {
          attachContactFormHandler();
        }
      </script>
