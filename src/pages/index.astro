---
/**
 * HOMEPAGE — lswebagency.com
 *
 * Focus Keyword : "agenzia web Sassari"
 * Keyword sec.  : "siti web professionali Sassari", "SEO locale Sassari",
 *                 "sviluppo siti web Sardegna"
 */

import Layout from '@/layouts/PageLayout.astro';
import VoucherSlider from "../components/VoucherSlider.astro";
import { Icon } from 'astro-icon/components';
import { findLatestPosts } from '@/utils/blog';
import { APP_BLOG } from 'astrowind:config';
import Grid from '@/components/blog/Grid.astro';
import { getBlogPermalink } from '@/utils/permalinks';

const latestPosts = APP_BLOG.isEnabled ? await findLatestPosts({ count: 4 }) : [];

if (import.meta.env.DEV) {
  console.log('[DEBUG HOME] APP_BLOG.isEnabled:', APP_BLOG.isEnabled);
  console.log('[DEBUG HOME] latestPosts.length:', latestPosts.length);
  console.log('[DEBUG HOME] latestPosts:', latestPosts.map(p => ({ title: p.title, slug: p.slug })));
}

/* ─────────────────────────────────────────────
   META + SEO
───────────────────────────────────────────── */
const metadata = {
  title: 'Agenzia Web Sassari — Siti Web Professionali e SEO Locale | LS Web Agency',
  description:
    'LS Web Agency Sassari: realizziamo siti web professionali e strategie SEO locale per attività, studi e PMI. Analisi gratuita, risposta in 24h.',
  canonical: '/',
  robots: { index: true, follow: true },
  openGraph: {
    url: 'https://www.lswebagency.com/',
    type: 'website',
    images: [
      {
        url: 'https://www.lswebagency.com/images/og-home.jpg',
        width: 1200,
        height: 630,
        alt: 'LS Web Agency Sassari — Realizzazione siti web e SEO locale',
      },
    ],
  },
  twitter: {
    cardType: 'summary_large_image',
    handle: '@lswebagency',
    site: '@lswebagency',
  },
  ignoreTitleTemplate: true,
};

/* ─────────────────────────────────────────────
   SCHEMA — LocalBusiness
───────────────────────────────────────────── */
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['ProfessionalService', 'LocalBusiness'],
  '@id': 'https://www.lswebagency.com/#organization',
  name: 'LS Web Agency di Luca Sanna',
  alternateName: 'LS Web Agency',
  url: 'https://www.lswebagency.com',
  telephone: '+393403223494',
  email: 'info@lswebagency.com',
  priceRange: '€€',
  image: 'https://www.lswebagency.com/images/og-home.jpg',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Via Alcide De Gasperi, 3',
    addressLocality: 'Sassari',
    postalCode: '07100',
    addressRegion: 'SS',
    addressCountry: 'IT',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 40.7259,
    longitude: 8.5556,
  },
  areaServed: [
    { '@type': 'City', name: 'Sassari' },
    { '@type': 'AdministrativeArea', name: 'Sardegna' },
    { '@type': 'Country', name: 'Italia' },
  ],
  founder: {
    '@type': 'Person',
    name: 'Luca Sanna',
    url: 'https://www.lucasanna.eu',
  },
  sameAs: [
    'https://www.linkedin.com/in/lucasanna-art/',
    'https://www.facebook.com/lucasannadesign/',
    'https://www.instagram.com/lucasanna_art/',
    'https://it.pinterest.com/lucasanna_art/',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer support',
    telephone: '+393403223494',
    email: 'info@lswebagency.com',
    areaServed: 'IT',
    availableLanguage: ['it', 'en'],
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Servizi LS Web Agency',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'Realizzazione siti web professionali a Sassari' },
      },
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'SEO locale Sassari' },
      },
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'AI e automazioni per PMI' },
      },
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'Strategia digitale e supporto continuativo' },
      },
    ],
  },
};

/* ─────────────────────────────────────────────
   SCHEMA — FAQPage
───────────────────────────────────────────── */
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Quanto tempo serve per vedere risultati con la SEO?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Un sito nuovo è online in 2–4 settimane. Per Google Maps i primi miglioramenti si vedono in 30–60 giorni; i risultati SEO più solidi arrivano dopo 3–6 mesi di lavoro continuativo.',
      },
    },
    {
      '@type': 'Question',
      name: 'Quanto costa un sito web professionale a Sassari?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Ogni progetto è diverso e dipende dalle esigenze dell'attività. Dopo l'analisi gratuita prepariamo un preventivo chiaro e dettagliato, senza sorprese.",
      },
    },
    {
      '@type': 'Question',
      name: 'Devo fornire testi e immagini per il sito?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No, non è necessario. Ci occupiamo noi di testi e immagini. Se hai già del materiale, lo usiamo e lo miglioriamo.',
      },
    },
    {
      '@type': 'Question',
      name: "LS Web Agency lavora solo a Sassari o in tutta Italia?",
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Siamo a Sassari ma lavoriamo con clienti in tutta Italia. La maggior parte del lavoro avviene online, con aggiornamenti via video o telefono.',
      },
    },
    {
      '@type': 'Question',
      name: 'Posso modificare il sito da solo dopo la consegna?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sì. Ti mostriamo come fare le modifiche base (testi, immagini, prezzi). Se preferisci, possiamo gestirle noi nel servizio di assistenza continuativa.',
      },
    },
    {
      '@type': 'Question',
      name: 'Cosa succede se il sito non porta risultati?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Lavoriamo finché non funziona. Seguiamo ogni progetto nel tempo, monitoriamo i dati e miglioriamo la strategia se i risultati attesi non arrivano.',
      },
    },
  ],
};

const WHATSAPP =
  'https://wa.me/393403223494?text=Ciao%2C%20vorrei%20informazioni%20sui%20servizi%20LS%20Web%20Agency.';
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- ═══════════════════════════════════════
       HERO
  ════════════════════════════════════════ -->
  <section class="relative isolate bg-brand-surface dark:bg-slate-950 overflow-hidden">
    <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-brand-purple/20 rounded-full blur-3xl"></div>
      <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-brand-blue/20 rounded-full blur-3xl"></div>
    </div>

    <div class="mx-auto max-w-screen-xl px-6 md:px-8 pt-12 sm:pt-16 pb-12 lg:pb-16">
      <div class="grid lg:grid-cols-[1.1fr_0.9fr] gap-10 items-center">
        <div class="text-center lg:text-left order-1 min-w-0">
          <div class="inline-flex items-center gap-2 px-4 py-1.5 mb-6 bg-white/70 dark:bg-white/10 backdrop-blur-sm rounded-full ring-1 ring-brand-ink/10 text-xs max-w-full whitespace-nowrap overflow-hidden text-ellipsis text-brand-ink dark:text-slate-300">
            <span class="w-2 h-2 rounded-full bg-brand-blue shrink-0"></span>
            <span class="font-semibold">LS Web Agency</span>
            <span class="hidden sm:inline">· Agenzia web a Sassari</span>
          </div>

          <header>
            <h1 class="text-4xl sm:text-5xl lg:text-[3rem] xl:text-[3.5rem] font-extrabold tracking-tight leading-[1.05] hero-title">
              <span class="block"><span class="t-dark">Realizzazione siti web</span></span>
              <span class="block"><span class="t-violet">e SEO locale a Sassari</span></span>
            </h1>

            <p class="mt-5 text-lg md:text-xl text-brand-ink/80 dark:text-slate-300 leading-relaxed max-w-xl mx-auto lg:mx-0">
              Siamo un'agenzia web a Sassari. Realizziamo siti veloci e strategie SEO locali per aiutare attività, studi e professionisti a ricevere più richieste da Google.
            </p>

            <p class="mt-4 inline-block px-4 py-2 rounded-full bg-brand-blue/10 dark:bg-brand-blue/20 text-sm font-semibold text-brand-blue">
              Operiamo da Sassari · Collaboriamo da remoto in tutta Italia
            </p>
          </header>

          <div
            class="mt-7 flex flex-col items-center gap-3 sm:flex-row sm:items-center sm:gap-3"
            aria-label="Azioni principali"
          >
            <a
              href="/contatti"
              class="w-full max-w-sm sm:w-auto inline-flex items-center justify-center whitespace-nowrap px-6 py-3 sm:px-8 sm:py-4 text-sm sm:text-base font-semibold text-white bg-brand-blue hover:bg-brand-blue/90 rounded-full shadow-sm hover:shadow-lg transform hover:-translate-y-0.5 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-blue focus-visible:ring-offset-2"
            >
              Richiedi analisi gratuita
              <Icon name="tabler:arrow-right" class="w-5 h-5 ml-2 shrink-0" />
            </a>

            <a
              href={WHATSAPP}
              target="_blank"
              rel="noopener"
              class="w-full max-w-sm sm:w-auto inline-flex items-center justify-center whitespace-nowrap px-6 py-3 sm:px-8 sm:py-4 text-sm sm:text-base font-semibold text-brand-ink dark:text-white bg-white dark:bg-slate-900/60 hover:bg-white/90 dark:hover:bg-slate-800 rounded-full ring-1 ring-brand-ink/10 dark:ring-slate-600 shadow-xs hover:shadow-md transform hover:-translate-y-0.5 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-ink/20 focus-visible:ring-offset-2"
            >
              <Icon name="tabler:brand-whatsapp" class="w-5 h-5 mr-2 shrink-0 text-green-500" />
              Scrivici su WhatsApp
            </a>
          </div>

     
        </div>

        <div class="relative order-2 mt-10 lg:mt-0 hidden sm:block">
          <div class="relative aspect-[16/10] rounded-3xl overflow-hidden bg-gradient-to-br from-brand-ink via-brand-purple/40 to-brand-blue/30 shadow-2xl ring-1 ring-white/10">
            <div class="pointer-events-none absolute inset-0 flex items-center justify-center">
              <div class="h-72 w-72 rounded-full bg-brand-blue/40 blur-3xl opacity-80"></div>
            </div>

            <img
              src="/images/lswebagency-hero-serp-contatti.webp"
              alt="Schermata del posizionamento su Google per un cliente LS Web Agency a Sassari"
              width="800"
              height="500"
              loading="eager"
              fetchpriority="high"
              decoding="sync"
              class="w-full h-full object-cover hero-image-floating"
            />

            <div class="absolute inset-0 bg-gradient-to-br from-brand-ink/40 via-brand-purple/20 to-brand-blue/20 pointer-events-none mix-blend-multiply"></div>

            <div class="absolute bottom-6 left-6 bg-white/95 dark:bg-slate-800/95 backdrop-blur-sm rounded-xl px-4 py-3 shadow-lg ring-1 ring-brand-ink/10">
              <div class="flex items-center gap-2">
                <Icon name="tabler:clock" class="w-5 h-5 text-brand-blue" />
                <span class="text-sm font-semibold text-brand-ink dark:text-white">Risposta entro 24h</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       SERVIZI
  ════════════════════════════════════════ -->
  <section id="servizi" class="relative bg-slate-50 dark:bg-slate-900/50 py-16 md:py-24">
    <div class="mx-auto max-w-screen-xl px-6 md:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-slate-900 dark:text-white mb-4">
          Servizi digitali per far crescere la tua presenza online
        </h2>
        <p class="text-lg md:text-xl text-slate-600 dark:text-slate-300 max-w-3xl mx-auto">
          Lavoriamo con attività locali, professionisti e PMI a Sassari e in Sardegna per rendere il sito e la presenza su Google più chiari, visibili e utili al business.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <article class="group relative bg-white dark:bg-slate-800 rounded-3xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 border border-slate-200 dark:border-slate-700 hover:-translate-y-2">
          <div class="absolute -top-4 -right-4 w-24 h-24 bg-gradient-to-br from-blue-500 to-blue-600 rounded-full opacity-10 group-hover:opacity-20 transition-opacity"></div>
          <div class="relative">
            <div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-blue-600 rounded-2xl flex items-center justify-center mb-6">
              <Icon name="tabler:device-laptop" class="w-8 h-8 text-white" />
            </div>
            <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">
              Siti web professionali a Sassari
            </h3>
            <p class="text-slate-600 dark:text-slate-300 mb-6 leading-relaxed">
              Realizziamo siti web moderni, veloci e orientati ai contatti per attività locali e PMI.
            </p>
            <ul class="space-y-2 mb-6 text-sm text-slate-600 dark:text-slate-300">
              <li class="flex items-center gap-2">
                <Icon name="tabler:check" class="w-5 h-5 text-emerald-600 shrink-0" />
                <span>Si vede bene su cellulare</span>
              </li>
              <li class="flex items-center gap-2">
                <Icon name="tabler:check" class="w-5 h-5 text-emerald-600 shrink-0" />
                <span>Google lo trova facilmente</span>
              </li>
              <li class="flex items-center gap-2">
                <Icon name="tabler:check" class="w-5 h-5 text-emerald-600 shrink-0" />
                <span>Carica in pochi secondi</span>
              </li>
              <li class="flex items-center gap-2">
                <Icon name="tabler:check" class="w-5 h-5 text-emerald-600 shrink-0" />
                <span>Design professionale</span>
              </li>
            </ul>
            <a href="/servizi/siti-web" class="inline-flex items-center text-blue-600 dark:text-blue-400 font-semibold hover:underline group/link">
              Vai al servizio di realizzazione siti web a Sassari
              <Icon name="tabler:arrow-right" class="w-4 h-4 ml-2 group-hover/link:translate-x-1 transition-transform" />
            </a>
          </div>
        </article>

        <article class="group relative bg-white dark:bg-slate-800 rounded-3xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 border border-slate-200 dark:border-slate-700 hover:-translate-y-2">
          <div class="absolute -top-4 -right-4 w-24 h-24 bg-gradient-to-br from-emerald-500 to-emerald-600 rounded-full opacity-10 group-hover:opacity-20 transition-opacity"></div>
          <div class="relative">
            <div class="w-16 h-16 bg-gradient-to-br from-emerald-500 to-emerald-600 rounded-2xl flex items-center justify-center mb-6">
              <Icon name="tabler:map-pin" class="w-8 h-8 text-white" />
            </div>
            <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">
              SEO locale a Sassari
            </h3>
            <p class="text-slate-600 dark:text-slate-300 mb-6 leading-relaxed">
              Ti aiutiamo a comparire su Google quando i clienti cercano i tuoi servizi nella tua zona.
            </p>
            <ul class="space-y-2 mb-6 text-sm text-slate-600 dark:text-slate-300">
              <li class="flex items-center gap-2">
                <Icon name="tabler:check" class="w-5 h-5 text-emerald-600 shrink-0" />
                <span>Scheda Google ottimizzata</span>
              </li>
              <li class="flex items-center gap-2">
                <Icon name="tabler:check" class="w-5 h-5 text-emerald-600 shrink-0" />
                <span>Appari nelle ricerche locali</span>
              </li>
              <li class="flex items-center gap-2">
                <Icon name="tabler:check" class="w-5 h-5 text-emerald-600 shrink-0" />
                <span>Più recensioni positive</span>
              </li>
              <li class="flex items-center gap-2">
                <Icon name="tabler:check" class="w-5 h-5 text-emerald-600 shrink-0" />
                <span>Report mensili chiari</span>
              </li>
            </ul>
            <a href="/servizi/seo-locale" class="inline-flex items-center text-emerald-600 dark:text-emerald-400 font-semibold hover:underline group/link">
              Scopri il servizio di SEO locale a Sassari
              <Icon name="tabler:arrow-right" class="w-4 h-4 ml-2 group-hover/link:translate-x-1 transition-transform" />
            </a>
          </div>
        </article>

        <article class="group relative bg-white dark:bg-slate-800 rounded-3xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 border border-slate-200 dark:border-slate-700 hover:-translate-y-2">
          <div class="absolute -top-4 -right-4 w-24 h-24 bg-gradient-to-br from-violet-500 to-violet-600 rounded-full opacity-10 group-hover:opacity-20 transition-opacity"></div>
          <div class="relative">
            <div class="w-16 h-16 bg-gradient-to-br from-violet-500 to-violet-600 rounded-2xl flex items-center justify-center mb-6">
              <Icon name="tabler:tools" class="w-8 h-8 text-white" />
            </div>
            <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">
              Strategia e supporto continuo
            </h3>
            <p class="text-slate-600 dark:text-slate-300 mb-6 leading-relaxed">
              Progettiamo una presenza digitale più chiara, credibile e utile per il tuo business nel tempo.
            </p>
            <ul class="space-y-2 mb-6 text-sm text-slate-600 dark:text-slate-300">
              <li class="flex items-center gap-2">
                <Icon name="tabler:check" class="w-5 h-5 text-emerald-600 shrink-0" />
                <span>Assistenza quando serve</span>
              </li>
              <li class="flex items-center gap-2">
                <Icon name="tabler:check" class="w-5 h-5 text-emerald-600 shrink-0" />
                <span>Backup automatici</span>
              </li>
              <li class="flex items-center gap-2">
                <Icon name="tabler:check" class="w-5 h-5 text-emerald-600 shrink-0" />
                <span>Sito sempre veloce</span>
              </li>
              <li class="flex items-center gap-2">
                <Icon name="tabler:check" class="w-5 h-5 text-emerald-600 shrink-0" />
                <span>Rispondiamo subito</span>
              </li>
            </ul>
            <a href="/servizi/assistenza-manutenzione" class="inline-flex items-center text-violet-600 dark:text-violet-400 font-semibold hover:underline group/link">
              Contattaci per una consulenza
              <Icon name="tabler:arrow-right" class="w-4 h-4 ml-2 group-hover/link:translate-x-1 transition-transform" />
            </a>
          </div>
        </article>
      </div>

      <div class="mt-10 text-center">
        <p class="text-slate-600 dark:text-slate-300 mb-4 text-base">Non sai da dove iniziare?</p>
        <a
          href="/contatti"
          class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-white bg-brand-blue hover:opacity-95 rounded-full transition-all duration-200"
        >
          <span>Parliamone insieme, gratis</span>
          <Icon name="tabler:arrow-right" class="w-4 h-4" />
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       COME FUNZIONA
  ════════════════════════════════════════ -->
  <section class="relative bg-white dark:bg-slate-950 py-16 md:py-24">
    <div class="mx-auto max-w-screen-xl px-6 md:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-slate-900 dark:text-white mb-4">
          Come funziona
        </h2>
        <p class="text-lg md:text-xl text-slate-600 dark:text-slate-300 max-w-2xl mx-auto">
          Quattro passaggi semplici per iniziare
        </p>
      </div>

      <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-8">
        {[
          {
            n: '1',
            title: 'Ci contatti',
            text: 'Compila il form o scrivici su WhatsApp. Ci racconti cosa fai e cosa vuoi ottenere.',
          },
          {
            n: '2',
            title: 'Analizziamo insieme',
            text: 'Guardiamo la tua situazione attuale e ti diciamo cosa si può migliorare. Gratis.',
          },
          {
            n: '3',
            title: 'Piano su misura',
            text: 'Ti prepariamo un piano chiaro: cosa facciamo, quanto tempo serve, quanto costa.',
          },
          {
            n: '4',
            title: 'Iniziamo a lavorare',
            text: 'Partiamo subito. Ti teniamo aggiornato ogni settimana sui progressi.',
          },
        ].map(({ n, title, text }) => (
          <div class="flex gap-4">
            <div class="flex-shrink-0">
              <div class="w-12 h-12 rounded-full bg-blue-600 text-white flex items-center justify-center text-xl font-bold">
                {n}
              </div>
            </div>
            <div>
              <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">{title}</h3>
              <p class="text-slate-600 dark:text-slate-300">{text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       PERCHÉ IMPORTA
  ════════════════════════════════════════ -->
  <section class="relative bg-slate-50 dark:bg-slate-900/50 py-16 md:py-24">
    <div class="mx-auto max-w-screen-xl px-6 md:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-slate-900 dark:text-white mb-6">
          Perché è importante avere un sito che funziona
        </h2>

        <div class="space-y-6 text-lg text-slate-600 dark:text-slate-300 text-left">
          <p>
            <strong class="text-slate-900 dark:text-white">Il 90% delle persone cerca online prima di comprare.</strong>{' '}
            Se non ti trovano, vanno dai tuoi concorrenti.
          </p>
          <p>
            <strong class="text-slate-900 dark:text-white">Un sito lento o confuso fa scappare i clienti.</strong>{' '}
            Bastano 3 secondi di attesa per perdere metà dei visitatori.
          </p>
          <p>
            <strong class="text-slate-900 dark:text-white">Apparire su Google Maps porta clienti veri.</strong>{' '}
            Chi cerca nella tua zona è pronto a comprare, non sta solo guardando.
          </p>
