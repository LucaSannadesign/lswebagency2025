---
/**
 * HOMEPAGE — lswebagency.com
 *
 * Focus Keyword : "agenzia web Sassari"
 * Keyword sec.  : "siti web professionali Sassari", "SEO locale Sassari",
 *                 "sviluppo siti web Sardegna"
 */

import Layout from '@/layouts/PageLayout.astro';
import Button from '@/components/ui/Button.astro';
import HeroHome from '@/components/widgets/HeroHome.astro';
import HomeCard from '@/components/ui/HomeCard.astro';
import ProblemCard from '@/components/ui/ProblemCard.astro';
import PersonalizedCta from '@/components/ux/PersonalizedCta.astro';
import { Icon } from 'astro-icon/components';
import { findLatestPosts } from '@/utils/blog';
import { APP_BLOG } from 'astrowind:config';
import Grid from '@/components/blog/Grid.astro';
import { getBlogPermalink } from '@/utils/permalinks';

const latestPosts = APP_BLOG.isEnabled ? await findLatestPosts({ count: 4 }) : [];

if (import.meta.env.DEV) {
  console.log('[DEBUG HOME] APP_BLOG.isEnabled:', APP_BLOG.isEnabled);
  console.log('[DEBUG HOME] latestPosts.length:', latestPosts.length);
  console.log('[DEBUG HOME] latestPosts:', latestPosts.map(p => ({ title: p.title, slug: p.slug })));
}

/* ─────────────────────────────────────────────
   META + SEO
───────────────────────────────────────────── */
const metadata = {
  title: 'Siti Web Strategici per Acquisire Clienti | LS Web Agency',
  description:
    'Realizzo siti web strategici per PMI e professionisti: form chiari, SEO, tracciamento e gestione ordinata delle richieste clienti, da Sassari in tutta Italia.',
  canonical: '/',
  robots: { index: true, follow: true },
  openGraph: {
    url: 'https://www.lswebagency.com/',
    type: 'website',
    images: [
      {
        url: 'https://www.lswebagency.com/images/og-home.jpg',
        width: 1200,
        height: 630,
        alt: 'LS Web Agency — siti web strategici per acquisire clienti, da Sassari in tutta Italia',
      },
    ],
  },
  twitter: {
    cardType: 'summary_large_image',
    handle: '@lswebagency',
    site: '@lswebagency',
  },
  ignoreTitleTemplate: true,
};

/* ─────────────────────────────────────────────
   SCHEMA — LocalBusiness
───────────────────────────────────────────── */
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['ProfessionalService', 'LocalBusiness'],
  '@id': 'https://www.lswebagency.com/#organization',
  name: 'LS Web Agency di Luca Sanna',
  alternateName: 'LS Web Agency',
  url: 'https://www.lswebagency.com',
  telephone: '+393403223494',
  email: 'info@lswebagency.com',
  priceRange: '€€',
  image: 'https://www.lswebagency.com/images/og-home.jpg',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Via Alcide De Gasperi, 3',
    addressLocality: 'Sassari',
    postalCode: '07100',
    addressRegion: 'SS',
    addressCountry: 'IT',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 40.7259,
    longitude: 8.5556,
  },
  areaServed: [
    { '@type': 'City', name: 'Sassari' },
    { '@type': 'AdministrativeArea', name: 'Sardegna' },
    { '@type': 'Country', name: 'Italia' },
  ],
  founder: {
    '@type': 'Person',
    name: 'Luca Sanna',
    url: 'https://www.lucasanna.eu',
  },
  sameAs: [
    'https://www.linkedin.com/in/lucasanna-art/',
    'https://www.facebook.com/lucasannadesign/',
    'https://www.instagram.com/lucasanna_art/',
    'https://it.pinterest.com/lucasanna_art/',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer support',
    telephone: '+393403223494',
    email: 'info@lswebagency.com',
    areaServed: 'IT',
    availableLanguage: ['it', 'en'],
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Siti web strategici LS Web Agency',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Siti web strategici per acquisire e gestire richieste clienti',
          url: 'https://www.lswebagency.com/servizi/siti-web',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Form chiari e gestione ordinata delle richieste clienti',
          url: 'https://www.lswebagency.com/servizi/siti-web',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'SEO tecnica e tracciamento conversioni integrati nel sito',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Automazioni leggere e supporto continuativo integrati nel sito',
        },
      },
    ],
  },
};

/* ─────────────────────────────────────────────
   SCHEMA — FAQPage
───────────────────────────────────────────── */
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Quanto costa indicativamente un sito web?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Dipende da struttura, numero di pagine, contenuti e obiettivi. Preparo sempre un preventivo chiaro prima di iniziare, calibrato sul progetto.',
      },
    },
    {
      '@type': 'Question',
      name: 'Posso partire da un audit prima di rifare il sito?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sì. L’audit tecnico e di accessibilità prioritizzato serve proprio a capire cosa funziona, cosa frena i contatti e quali interventi hanno priorità. In alcuni casi non serve rifare tutto: può bastare migliorare struttura, testi, CTA o percorso utente.',
      },
    },
    {
      '@type': 'Question',
      name: 'Quanto tempo serve per mettere online un sito?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Per un sito essenziale i tempi medi possono andare da 2 a 4 settimane, in base alla disponibilità di testi, immagini, feedback e materiali. Prima di iniziare definisco sempre tempi e passaggi principali.',
      },
    },
    {
      '@type': 'Question',
      name: 'È possibile pagare in più fasi?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sì, per i progetti completi è possibile concordare un pagamento a fasi: acconto iniziale, saldo intermedio o finale, in base al tipo di lavoro e alla durata del progetto.',
      },
    },
    {
      '@type': 'Question',
      name: 'Mi aiuti anche dopo la pubblicazione?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sì. Posso occuparmi di aggiornamenti, piccole modifiche, manutenzione, controlli tecnici e miglioramenti progressivi. L’obiettivo è evitare che il sito venga pubblicato e poi lasciato fermo.',
      },
    },
    {
      '@type': 'Question',
      name: 'Lavori solo a Sassari?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No. Lavoro con attività locali e professionisti di Sassari e della Sardegna, ma posso seguire progetti anche a distanza tramite email, videochiamata e strumenti condivisi.',
      },
    },
    {
      '@type': 'Question',
      name: 'Devo avere già testi e immagini pronti?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Non necessariamente. Se hai già materiali possiamo partire da quelli; se invece mancano, posso aiutarti a organizzare testi, struttura dei contenuti e immagini coerenti con il progetto.',
      },
    },
  ],
};

const WHATSAPP =
  'https://wa.me/393403223494?text=Ciao%2C%20vorrei%20informazioni%20sui%20servizi%20LS%20Web%20Agency.';
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- ═══════════════════════════════════════
       HERO
  ════════════════════════════════════════ -->
  <HeroHome />

  <!-- Transizione morbida hero → servizi: colma lo stacco bianco con una sfumatura lilla → grigio freddo
       (da brand-surface, fondo della hero, a slate-50, inizio sezione servizi). -->
  <div class="bg-gradient-to-b from-[#F5F0FB] to-slate-50 dark:from-slate-950 dark:to-slate-950">
    <PersonalizedCta />
  </div>

  <!-- ═══════════════════════════════════════
       SERVIZI
  ════════════════════════════════════════ -->
  <section
    id="servizi"
    class="relative isolate overflow-hidden bg-gradient-to-b from-[#FBF9FE] via-white to-[#F7F2FC] py-16 md:py-24 dark:from-slate-950 dark:via-slate-900 dark:to-slate-950"
  >
    <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
      <div class="absolute -top-28 right-[8%] h-80 w-80 rounded-full bg-[#7628E8]/[0.06] blur-3xl dark:bg-[#7628E8]/[0.14]">
      </div>
      <div class="absolute -bottom-20 left-[4%] h-72 w-72 rounded-full bg-[#E72AAE]/[0.05] blur-3xl dark:bg-[#E72AAE]/[0.10]">
      </div>
    </div>

    <div class="relative z-[1] mx-auto max-w-screen-xl px-6 md:px-8">
      <div class="text-center mb-12 md:mb-14">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-[#211831] dark:text-white mb-4">
          Un sito web che non solo ti presenta
        </h2>
        <p class="text-lg md:text-xl text-[#5E566B] dark:text-slate-300 max-w-4xl mx-auto leading-relaxed">
          Un sito web non deve limitarsi a mostrarti online: deve aiutarti a ricevere, organizzare e seguire meglio le
          richieste. Form, SEO, tracciamento e gestione contatti fanno parte del sito — componenti integrati, non servizi
          da aggiungere dopo.
        </p>
      </div>

      <div class="mx-auto grid max-w-5xl grid-cols-1 gap-5 md:grid-cols-2 md:gap-6">
        <ProblemCard
          title="Ricevo poche richieste"
          description="Il sito è online, ma non porta abbastanza contatti o richieste qualificate."
          href="#contatti"
          ctaLabel="Richiedi la valutazione gratuita"
          icon="tabler:message-2"
        />
        <ProblemCard
          title="Il sito è vecchio o confuso"
          description="La struttura, i testi o l’immagine non rappresentano più la tua attività."
          href="/contatti"
          ctaLabel="Valuta un restyling"
          icon="tabler:refresh"
        />
        <ProblemCard
          title="Non mi trovano su Google"
          description="La presenza locale è debole o poco visibile nelle ricerche e su Google Maps."
          href="/contatti"
          ctaLabel="Scopri SEO locale"
          icon="tabler:map-pin-search"
        />
        <ProblemCard
          title="Devo partire da zero"
          description="Serve un sito chiaro, leggero e pensato per presentare bene la tua attività."
          href="/contatti"
          ctaLabel="Richiedi preventivo sito"
          icon="tabler:rocket"
        />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       ANALISI GRATUITA VS AUDIT RAPIDO
  ════════════════════════════════════════ -->
  <section id="analisi-audit" class="container mx-auto px-6 py-12 md:py-16">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-10 md:mb-12">
        <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 dark:text-white mb-3">
          Valutazione iniziale gratuita o audit: da dove conviene partire?
        </h2>
        <p class="text-lg text-slate-600 dark:text-slate-300 max-w-3xl mx-auto leading-relaxed">
          Il percorso è semplice: valutazione iniziale gratuita → audit tecnico e di accessibilità prioritizzato → sprint tecnico di ottimizzazione → eventuale sito web strategico. Puoi iniziare con la valutazione gratuita per un primo orientamento, oppure partire dall’audit per evidenze e priorità operative.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 text-left">
        <div
          class="flex flex-col rounded-2xl bg-gradient-to-br from-white to-slate-50/95 p-6 md:p-7 ring-1 ring-slate-200/90 shadow-[0_22px_55px_-18px_rgba(15,23,42,0.14)] dark:from-slate-800 dark:to-slate-900/95 dark:ring-slate-600/55 dark:shadow-[0_22px_55px_-18px_rgba(0,0,0,0.48)]"
        >
          <h3 class="text-lg font-bold text-slate-900 dark:text-white">Valutazione iniziale gratuita</h3>
          <p class="mt-2 text-sm font-semibold text-brand-blue dark:text-violet-400">Gratuita</p>
          <p class="mt-3 text-sm md:text-base text-slate-600 dark:text-slate-300 leading-relaxed">
            Un primo sguardo leggero, senza report strutturato, per capire se il sito ha problemi evidenti di chiarezza, messaggio o percorso verso il contatto.
          </p>
          <ul class="mt-4 flex-1 space-y-2 text-sm text-slate-700 dark:text-slate-200">
            <li class="flex items-start gap-2">
              <Icon name="tabler:point-filled" class="w-4 h-4 shrink-0 mt-0.5 text-brand-blue" />
              <span>Prima impressione sulla homepage</span>
            </li>
            <li class="flex items-start gap-2">
              <Icon name="tabler:point-filled" class="w-4 h-4 shrink-0 mt-0.5 text-brand-blue" />
              <span>Indicazione generale dei problemi principali</span>
            </li>
            <li class="flex items-start gap-2">
              <Icon name="tabler:point-filled" class="w-4 h-4 shrink-0 mt-0.5 text-brand-blue" />
              <span>Consiglio sul passo successivo più utile</span>
            </li>
          </ul>
          <a
            href="/contatti"
            class="mt-6 inline-flex w-full items-center justify-center gap-2 px-5 py-3 text-sm font-semibold text-brand-ink dark:text-white bg-transparent hover:bg-brand-blue/10 dark:hover:bg-brand-blue/20 rounded-full ring-1 ring-slate-300 dark:ring-slate-600 transition-all duration-200"
          >
            <span>Richiedi la valutazione gratuita</span>
            <Icon name="tabler:arrow-right" class="w-4 h-4 shrink-0" />
          </a>
        </div>

        <div
          class="flex flex-col rounded-2xl bg-gradient-to-br from-white to-slate-50/95 p-6 md:p-7 ring-1 ring-slate-200/90 shadow-[0_22px_55px_-18px_rgba(15,23,42,0.14)] dark:from-slate-800 dark:to-slate-900/95 dark:ring-slate-600/55 dark:shadow-[0_22px_55px_-18px_rgba(0,0,0,0.48)]"
        >
          <h3 class="text-lg font-bold text-slate-900 dark:text-white">Audit tecnico e di accessibilità prioritizzato</h3>
          <p class="mt-2 text-sm font-semibold text-brand-blue dark:text-violet-400">Su preventivo</p>
          <p class="mt-3 text-sm md:text-base text-slate-600 dark:text-slate-300 leading-relaxed">
            Analisi tecnica e verifica manuale selettiva per attività locali, professionisti e PMI: chiarezza, struttura, UX, SEO di base e accessibilità, con evidenze e priorità.
          </p>
          <ul class="mt-4 flex-1 space-y-2 text-sm text-slate-700 dark:text-slate-200">
            <li class="flex items-start gap-2">
              <Icon name="tabler:point-filled" class="w-4 h-4 shrink-0 mt-0.5 text-brand-blue" />
              <span>Analisi homepage e percorso utente</span>
            </li>
            <li class="flex items-start gap-2">
              <Icon name="tabler:point-filled" class="w-4 h-4 shrink-0 mt-0.5 text-brand-blue" />
              <span>Verifica CTA, messaggio e struttura</span>
            </li>
            <li class="flex items-start gap-2">
              <Icon name="tabler:point-filled" class="w-4 h-4 shrink-0 mt-0.5 text-brand-blue" />
              <span>Priorità operative chiare per intervenire</span>
            </li>
          </ul>
          <a
            href="/contatti"
            class="mt-6 inline-flex w-full items-center justify-center gap-2 px-5 py-3 text-sm font-semibold text-white bg-brand-blue hover:opacity-95 rounded-full transition-all duration-200"
          >
            <span>Richiedi disponibilità per l’audit</span>
            <Icon name="tabler:arrow-right" class="w-4 h-4 shrink-0" />
          </a>
        </div>
      </div>

      <p class="mt-10 text-center text-sm md:text-base text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed">
        Non sempre serve rifare tutto: l’obiettivo è capire quale intervento ha più senso, evitando modifiche inutili.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       COME FUNZIONA
  ════════════════════════════════════════ -->
  <section class="relative bg-white dark:bg-slate-950 py-16 md:py-24">
    <div class="mx-auto max-w-screen-xl px-6 md:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-slate-900 dark:text-white mb-4">
          Un percorso semplice in 3 step
        </h2>
        <p class="text-lg md:text-xl text-slate-600 dark:text-slate-300 max-w-4xl mx-auto">
          Guardiamo il tuo sito, ti indichiamo cosa migliorare e, se vuoi, interveniamo sulle parti giuste per far crescere le richieste di contatto.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            n: '1',
            title: 'Guardiamo il tuo sito',
            text: 'Guardiamo la homepage e il percorso verso il contatto per capire cosa rende il messaggio poco chiaro o poco convincente.',
          },
          {
            n: '2',
            title: 'Ti indichiamo cosa migliorare',
            text: 'Ti segnaliamo le priorità e gli interventi più utili per aumentare chiarezza, fiducia e contatti.',
          },
          {
            n: '3',
            title: 'Se vuoi, interveniamo sul sito',
            text: 'Se serve, interveniamo sulle aree chiave e rendiamo più efficace il percorso fino alla richiesta.',
          },
        ].map(({ n, title, text }) => (
          <div class="flex flex-col items-start">
            <div class="w-12 h-12 rounded-full bg-primary text-white flex items-center justify-center text-xl font-bold mb-4">
              {n}
            </div>
            <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">{title}</h3>
            <p class="text-slate-600 dark:text-slate-300">{text}</p>
          </div>
        ))}
      </div>

      <div
        class="mt-12 md:mt-14 max-w-6xl mx-auto rounded-2xl bg-slate-50/80 px-5 py-8 md:px-8 md:py-10 ring-1 ring-slate-200/80 dark:bg-slate-900/50 dark:ring-slate-700/50"
      >
        <div class="text-center mb-6 md:mb-8">
          <h3 class="text-2xl md:text-3xl font-bold text-slate-900 dark:text-white mb-2">
            Scegli da dove partire
          </h3>
          <p class="text-sm md:text-base text-slate-600 dark:text-slate-300 max-w-2xl mx-auto leading-relaxed">
            Una scelta rapida per capire se partire da un audit, da un nuovo sito o dalla SEO locale.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 md:gap-4 items-stretch text-left">
          <HomeCard
            variant="neutral"
            badges={[{ text: 'Diagnosi' }]}
            title="Audit tecnico e di accessibilità prioritizzato"
            price="Su preventivo"
            priceNote="disponibilità su richiesta"
            description="Analisi tecnica e verifica manuale selettiva per attività locali, professionisti e PMI, su chiarezza, struttura, UX, SEO di base e accessibilità."
            items={[
              'Analisi homepage e percorso utente',
              'CTA, messaggio e struttura',
              'Priorità operative chiare',
            ]}
            cta={{ label: 'Richiedi disponibilità per l’audit', href: '#analisi-audit' }}
          />

          <HomeCard
            variant="featured"
            badges={[{ text: 'Percorso più richiesto', tone: 'gradient' }, { text: 'Progettazione' }]}
            title="Sito per attività locali"
            price="Su preventivo"
            priceNote="preventivo calibrato sul progetto"
            description="Per creare o rifare un sito chiaro, leggero e pensato per presentare bene servizi, valori e contatti."
            items={['Design responsive', 'Struttura pagine essenziali', 'SEO base e form contatti']}
            cta={{ label: 'Richiedi preventivo sito', href: '/contatti' }}
          />

          <HomeCard
            variant="neutral"
            badges={[{ text: 'Visibilità locale' }]}
            title="SEO locale starter"
            price="Su preventivo"
            priceNote="disponibilità su richiesta"
            description="Per migliorare la presenza della tua attività nelle ricerche locali e su Google Maps."
            items={[
              'Verifica presenza locale',
              'Ottimizzazioni di base',
              'Priorità per migliorare visibilità',
            ]}
            cta={{ label: 'Verifica SEO locale', href: '/servizi/seo-locale' }}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       PERCHÉ IMPORTA
  ════════════════════════════════════════ -->
  <section class="relative bg-slate-50 dark:bg-slate-900/50 py-16 md:py-24">
    <div class="mx-auto max-w-screen-xl px-6 md:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-slate-900 dark:text-white mb-6">
          Cosa cambia quando il sito è più chiaro
        </h2>

        <div class="space-y-6 text-lg text-slate-600 dark:text-slate-300 text-left">
          <p>
            Quando messaggio, struttura e call to action funzionano meglio, il sito non diventa solo più bello: diventa più utile per chi lo visita e più credibile per chi sta valutando se contattarti.
          </p>
          <p>
            <strong class="text-slate-900 dark:text-white">Si capisce subito cosa fai</strong>{' '}
            Il visitatore non deve interpretare da solo il tuo servizio.
          </p>
          <p>
            <strong class="text-slate-900 dark:text-white">Trasmette più fiducia</strong>{' '}
            Un sito più ordinato e leggibile aiuta a percepire meglio professionalità e affidabilità.
          </p>
          <p>
            <strong class="text-slate-900 dark:text-white">Accompagna meglio verso il contatto</strong>{' '}
            Quando il percorso è più chiaro, chiedere informazioni o fissare un appuntamento diventa più naturale.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       INTERVENTI MIRATI — STUDI DENTISTICI / ATTIVITÀ LOCALI
  ════════════════════════════════════════ -->
  <section class="relative bg-white dark:bg-slate-950 py-16 md:py-24">
    <div class="mx-auto max-w-screen-xl px-6 md:px-8">
      <div class="text-center mb-10 md:mb-12 max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 dark:text-white mb-3">
