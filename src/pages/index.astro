            background-color: rgba(15, 23, 42, 0.12) !important;
          }

          .reviews-google-carousel [data-dots] button:hover {
            background-color: rgba(15, 23, 42, 0.2) !important;
          }

          .reviews-google-carousel [data-dots] button[aria-current="true"] {
            background-color: rgba(118, 40, 232, 0.9) !important;
          }

