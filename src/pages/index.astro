---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'LS Web Agency — Creazione di Siti Web, App e Soluzioni Digitali',
  description: 'Scopri le nostre soluzioni digitali per siti web moderni, performanti e ottimizzati per SEO.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Scopri i nostri servizi',
        href: '/servizi',
      },
      { text: 'Portfolio', href: '/portfolio' },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'Immagine Hero LS Web Agency' }}
  >
    <Fragment slot="title">
     Creazione siti web e app <span class="text-accent text-gradient dark:text-white highlight">professionali e performanti</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        <span class="font-semibold">LS Web Agency</span> realizza siti web, app e soluzioni digitali su misura, combinando performance, estetica e SEO avanzato.
      </span>
      <span class="block mb-1 sm:hidden font-bold text-blue-600">
        LS Web Agency: Creatività e tecnologia al servizio del tuo brand.
      </span>
      Ideali per aziende, professionisti ed e-commerce, trasformiamo la tua visione in una realtà digitale vincente.
    </Fragment>
  </Hero>

  <!-- Features Widget -->
  <Features
    id="features"
    tagline="Servizi"
    title="Cosa offriamo con LS Web Agency"
    subtitle="Soluzioni digitali professionali per aziende, professionisti e startup. Creiamo esperienze web su misura per il tuo business."
    items={[
      {
        title: 'Siti Web Moderni e Performanti',
        description: 'Realizziamo siti web personalizzati, ottimizzati per SEO e con design responsive, garantendo massima velocità e usabilità.',
        icon: 'tabler:device-desktop',
      },
      {
        title: 'Sviluppo App su Misura',
        description: 'Progettiamo e sviluppiamo applicazioni web e mobile intuitive e performanti, adattate alle esigenze del tuo business.',
        icon: 'tabler:device-mobile',
      },
      {
        title: 'Strategie di Web Marketing',
        description: 'Utilizziamo strategie di digital marketing e SEO per aumentare la visibilità del tuo brand e migliorare il posizionamento sui motori di ricerca.',
        icon: 'tabler:chart-line',
      },
      {
        title: 'Branding e Identità Visiva',
        description: 'Creiamo loghi, grafiche personalizzate e identità visive accattivanti per far emergere il tuo brand nel mercato digitale.',
        icon: 'tabler:palette',
      },
      {
        title: 'E-commerce e Vendite Online',
        description: 'Sviluppiamo soluzioni di e-commerce sicure e scalabili, integrando sistemi di pagamento e gestione ordini per il massimo rendimento.',
        icon: 'tabler:shopping-cart',
      },
      {
        title: 'Manutenzione e Supporto Continuo',
        description: 'Offriamo assistenza e aggiornamenti costanti per garantire la sicurezza, la stabilità e la crescita del tuo sito o applicazione.',
        icon: 'tabler:lifebuoy',
      },
    ]}
  />

  <!-- Elementi Essenziali -->
  <Features2
    title="Elementi essenziali di un sito web moderno"
    subtitle="Ogni dettaglio conta per garantire un’esperienza utente fluida e professionale"
    tagline="Componenti Chiave"
    items={[
      {
        title: 'Navigazione Intuitiva',
        description: "Un menu chiaro e ben strutturato aiuta gli utenti a trovare ciò che cercano rapidamente.",
        icon: 'tabler:layout-navbar',
      },
      {
        title: 'Design Accattivante',
        description: "L'estetica è fondamentale: colori, font e immagini devono comunicare il valore del brand.",
        icon: 'tabler:palette',
      },
      {
        title: 'Performance e Velocità',
        description: 'Un sito veloce riduce il tasso di abbandono e migliora il posizionamento sui motori di ricerca.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Contenuti Ottimizzati',
        description: "Testi chiari, immagini di qualità e call-to-action efficaci rendono un sito funzionale e coinvolgente.",
        icon: 'tabler:file-text',
      },
      {
        title: 'SEO e Visibilità',
        description: 'L’ottimizzazione per i motori di ricerca (SEO) è essenziale per attrarre traffico organico e clienti.',
        icon: 'tabler:search',
      },
      {
        title: 'Responsive e Mobile-Friendly',
        description: 'Il sito deve adattarsi perfettamente a tutti i dispositivi, dal desktop allo smartphone.',
        icon: 'tabler:device-mobile',
      },
      {
        title: 'Sezione Contatti Strategica',
        description: 'Facilitare la comunicazione con i clienti attraverso form chiari e informazioni di contatto ben visibili.',
        icon: 'tabler:mail',
      },
      {
        title: 'Integrazione con Social Media',
        description: 'Un sito con collegamenti ai social network aiuta a migliorare la presenza online e la fidelizzazione.',
        icon: 'tabler:brand-facebook',
      },
      {
        title: 'Sicurezza e Protezione Dati',
        description: 'Proteggiamo il tuo sito con protocolli avanzati, certificati SSL e backup regolari per garantire sicurezza e affidabilità.',
        icon: 'tabler:shield-lock',
      },
    ]}
  />

  <!-- Call to Action -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Prenota una consulenza gratuita',
        href: '/contatti',
        icon: 'tabler:message',
      },
    ]}
  >
    <Fragment slot="title">
      Siti Web&nbsp;+&nbsp;<br class="block sm:hidden" />
      <span class="sm:whitespace-nowrap">SEO & Brand Identity</span>
    </Fragment>

    <Fragment slot="subtitle">
      Vuoi un sito web professionale e visibile sui motori di ricerca? 🚀 <br />
      Contattaci ora e scopri come possiamo trasformare la tua presenza online con soluzioni su misura per il tuo business.
    </Fragment>
  </CallToAction>
</Layout>
