---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';

// 📌 Corretto: Recuperiamo il `slug` dai dati della collezione
export async function getStaticPaths() {
  const projects = await getCollection('portfolio');

  return projects.map((entry) => ({
    params: { slug: entry.id }, // Usa `id` come slug
    props: { project: entry },
  }));
}

// 📌 Recuperiamo i dati del progetto
const { project } = Astro.props;
---

<Layout metadata={{ title: project.data.title }}>
  <section class="container mx-auto px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Colonna Immagine -->
      <div>
        {
          project.data.image && typeof project.data.image === 'object' ? (
            <img
              src={project.data.image.src}
              alt={project.data.image.alt || project.data.title}
              width={project.data.image.width || 'auto'}
              height={project.data.image.height || 'auto'}
              class="w-full rounded-lg shadow-md"
            />
          ) : (
            <img src={project.data.image} alt={project.data.title} class="w-full rounded-lg shadow-md" />
          )
        }
      </div>

      <!-- Colonna Dettagli -->
      <div>
        <h1 class="text-3xl font-bold">{project.data.title}</h1>
        <p class="text-gray-600 mt-2">{project.data.description}</p>

        {
          project.data.category && (
            <p class="mt-4">
              <strong>Categoria:</strong> {project.data.category}
            </p>
          )
        }

        {
          project.data.technologies && (
            <p class="mt-4">
              <strong>Tecnologie:</strong> {project.data.technologies.join(', ')}
            </p>
          )
        }
      </div>
    </div>
  </section>
</Layout>
