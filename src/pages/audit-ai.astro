---
// Riutilizza il layout standard del sito
import Layout from '@/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

// Metadata SEO per il tool
const metadata = {
  title: 'Homepage Audit AI - Analizza la tua pagina gratuitamente',
  description: 'Tool gratuito per analizzare SEO, prestazioni e UX della tua homepage in pochi secondi.'
};
---
<Layout metadata={metadata}>
  <!-- Hero migliorata -->
  <section class="relative py-28 bg-gradient-to-br from-[#f8f9ff] to-[#f0f4ff] dark:from-slate-900 dark:to-slate-950 overflow-hidden">
    <!-- Effetti background -->
    <div class="absolute inset-0 -z  -10 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/4 left-[60%] w-64 h-64 bg-brand-blue/5 rounded-full blur-3xl"></div>
    </div>

    <div class="max-w-4xl mx-auto px-6 md:px-8 text-center">
      <!-- Badge migliorato -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 mb-6 bg-white/70 dark:bg-white/10 backdrop-blur-sm rounded-full ring-1 ring-brand-ink/10 text-xs text-brand-ink dark:text-slate-300">
        <Icon name="tabler:sparkles" class="w-4 h-4 text-brand-blue shrink-0" />
        <span class="font-medium">Tool gratuito specializzato per attività locali</span>
      </div>

      <h1 class="text-4xl md:text-5xl lg:text-[3.5rem] font-extrabold text-slate-900 dark:text-white mb-5 leading-tight">
        Analisi SEO <span class="text-brand-blue">completa</span> e gratuita
      </h1>
      <p class="text-xl text-slate-700 dark:text-slate-300 mb-8 max-w-2xl mx-auto">
        Scopri cosa migliorare nella tua homepage per ottenere più contatti e clienti dal web
      </p>

      <!-- Micro-benefit -->
      <ul class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm text-slate-600 dark:text-slate-400 mb-10">
        <li class="inline-flex items-center gap-2">
          <Icon name="tabler:check" class="w-4 h-4 text-brand-blue shrink-0" />
          <span>Report chiaro e pratico</span>
        </li>
        <li class="inline-flex items-center gap-2">
          <Icon name="tabler:check" class="w-4 h-4 text-brand-blue shrink-0" />
          <span>Focus su conversione</span>
        </li>
        <li class="inline-flex items-center gap-2">
          <Icon name="tabler:check" class="w-4 h-4 text-brand-blue shrink-0" />
          <span>Ottimizzato per attività locali</span>
        </li>
      </ul>

      <!-- Form MVP -->
      <form id="auditForm" class="bg-white dark:bg-slate-800 rounded-2xl p-8 shadow-xl ring-1 ring-slate-200/50 dark:ring-slate-700/30 max-w-md mx-auto">
        <h3 class="text-center text-xl font-semibold text-slate-900 dark:text-slate-100 mb-6">
          Informazioni base per l'analisi
        </h3>

        <div class="space-y-4">
          <!-- URL -->
          <div>
            <label for="websiteUrl" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">
              URL del sito<span class="text-red-500">*</span>
            </label>
            <input 
              id="websiteUrl"
              name="websiteUrl" 
              type="url" 
              placeholder="https://tuo-nutrizionista.com" 
              class="w-full px-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue bg-white dark:bg-slate-900"
              required
            />
            <p id="urlError" class="mt-1 text-xs text-red-500 hidden">Inserisci un URL valido (es: https://tuo-sito.com)</p>
          </div>

          <!-- Nome Attività -->
          <div>
            <label for="businessName" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">
              Nome attività<span class="text-red-500">*</span>
            </label>
            <input 
              id="businessName"
              name="businessName" 
              type="text" 
              placeholder="Es: Studio Dentistico Bianchi" 
              class="w-full px-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue bg-white dark:bg-slate-900"
              required
            />
          </div>

          <!-- Città / Area -->
          <div>
            <label for="location" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">
              Città / Area geografica<span class="text-red-500">*</span>
            </label>
            <input 
              id="location"
              name="location" 
              type="text" 
              placeholder="Es: Sassari centro" 
              class="w-full px-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue bg-white dark:bg-slate-900"
              required
            />
          </div>

          <!-- Categoria -->
          <div>
            <label for="category" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">
              Categoria business<span class="text-red-500">*</span>
            </label>
            <select 
              id="category"
              name="category" 
              class="w-full px-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue bg-white dark:bg-slate-900"
              required
            >
              <option value="" disabled selected>Seleziona categoria</option>
              <option value="Professionista">Professionista (avvocato, dentista, etc.)</option>
              <option value="Negozio">Negozio fisico</option>
              <option value="Servizi">Servizi locali</option>
              <option value="Turismo">Turismo / Hotel</option>
              <option value="Ristorazione">Ristorazione</option>
              <option value="Altro">Altro</option>
            </select>
          </div>

          <!-- Keyword -->
          <div>
            <label for="mainKeyword" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">
              Keyword principale locale<span class="text-red-500">*</span>
            </label>
            <input 
              id="mainKeyword"
              name="mainKeyword" 
              type="text" 
              placeholder="Es: nutrizionista a Sassari" 
              class="w-full px-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue bg-white dark:bg-slate-900"
              required
            />
          </div>
        </div>

        <!-- Button -->
        <button type="submit" class="mt-6 w-full px-6 py-3 bg-brand-blue hover:bg-brand-blue/90 text-white font-medium rounded-xl transition-colors shadow-sm">
          Analizza Gratuitamente
        </button>

        <!-- Privacy Note -->
        <div class="mt-4 pt-4 border-t border-slate-100 dark:border-slate-700/50">
          <p class="text-xs text-slate-500 dark:text-slate-400 text-center flex items-center justify-center gap-2">
            <Icon name="tabler:shield-check" class="w-3.5 h-3.5 text-emerald-600" />
            <span>Analisi 100% gratuita · Nessuna registrazione · GDPR compliant</span>
          </p>
        </div>

        <!-- Client-side JS -->
        <script>
          const form = document.getElementById('auditForm');
          
          form.addEventListener('submit', (e) => {
            e.preventDefault();
            
            // Basic validation
            const urlInput = form.elements.websiteUrl;
            const urlError = document.getElementById('urlError');
            
            if (!urlInput.checkValidity()) {
              urlError.classList.remove('hidden');
              return;
            }
            
            // Get form data
            const formData = {
              url: form.elements.websiteUrl.value,
              business: form.elements.businessName.value,
              location: form.elements.location.value,
              category: form.elements.category.value,
              keyword: form.elements.mainKeyword.value
            };
            
            console.log('[Audit AI] Form submitted:', formData);
            
            // For now just show an alert
            alert(`Analisi richiesta per: ${formData.business}\nVerrai reindirizzato al report tra qualche secondo`);
          });

          // Validate URL on blur
          form.elements.websiteUrl.addEventListener('blur', (e) => {
            const urlError = document.getElementById('urlError');
            urlError.classList.toggle('hidden', e.target.checkValidity());
          });
        </script>
      </form>
    </div>
  </section>

  <!-- Placeholder report -->
  <section class="py-16 bg-white dark:bg-slate-950">
    <div class="max-w-4xl mx-auto px-6 md:px-8 text-center">
      <div class="p-8 md:p-12 rounded-2xl bg-gradient-to-br from-slate-50 to-slate-100 dark:from-slate-900/50 dark:to-slate-900/30 ring-1 ring-slate-200/70 dark:ring-slate-700/30">
        <div class="max-w-xl mx-auto">
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 dark:text-white mb-4 flex items-center justify-center gap-2">
            <Icon name="tabler:report-analytics" class="w-6 h-6 text-brand-blue" />
            <span>Il tuo report completo</span>
          </h2>
          <p class="text-slate-600 dark:text-slate-400 mb-6">
            Riceverai un'analisi dettagliata con:
          </p>
          <ul class="space-y-3 text-slate-700 dark:text-slate-300 text-sm">
            <li class="flex items-start gap-2">
              <Icon name="tabler:check" class="w-4 h-4 text-emerald-600 mt-0.5 shrink-0" />
              <span>Punteggio prestazioni e SEO</span>
            </li>
            <li class="flex items-start gap-2">
              <Icon name="tabler:check" class="w-4 h-4 text-emerald-600 mt-0.5 shrink-0" />
              <span>Indicatori di usabilità e conversione</span>
            </li>
            <li class="flex items-start gap-2">
              <Icon name="tabler:check" class="w-4 h-4 text-emerald-600 mt-0.5 shrink-0" />
              <span>Suggerimenti pratici per migliorare</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</Layout>
