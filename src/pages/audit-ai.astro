---
// Riutilizza il layout standard del sito
import Layout from '@/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

// Metadata SEO per il tool
const metadata = {
  title: 'Homepage Audit AI - Analizza la tua homepage gratuitamente',
  description:
    'Tool gratuito per valutare rapidamente chiarezza del messaggio, UX, fiducia e SEO locale della tua homepage.'
};
---
<Layout metadata={metadata}>
  <section class="relative py-24 md:py-28 bg-gradient-to-br from-[#f8f9ff] to-[#f0f4ff] dark:from-slate-900 dark:to-slate-950 overflow-hidden">
    <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/4 left-[60%] w-64 h-64 bg-brand-blue/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-[70%] w-72 h-72 bg-sky-400/5 rounded-full blur-3xl"></div>
    </div>

    <div class="max-w-4xl mx-auto px-6 md:px-8 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 mb-6 bg-white/70 dark:bg-white/10 backdrop-blur-sm rounded-full ring-1 ring-brand-ink/10 text-xs text-brand-ink dark:text-slate-300">
        <Icon name="tabler:sparkles" class="w-4 h-4 text-brand-blue shrink-0" />
        <span class="font-medium">Tool gratuito specializzato per attività locali</span>
      </div>

      <h1 class="text-4xl md:text-5xl lg:text-[3.5rem] font-extrabold text-slate-900 dark:text-white mb-5 leading-tight">
        Analizza la tua homepage e scopri cosa può migliorare davvero
      </h1>

      <p class="text-xl text-slate-700 dark:text-slate-300 mb-8 max-w-2xl mx-auto">
        Ottieni una valutazione iniziale su chiarezza del messaggio, fiducia, call to action e presenza locale della tua homepage.
      </p>

      <ul class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm text-slate-600 dark:text-slate-400 mb-10">
        <li class="inline-flex items-center gap-2">
          <Icon name="tabler:check" class="w-4 h-4 text-brand-blue shrink-0" />
          <span>Report rapido e leggibile</span>
        </li>
        <li class="inline-flex items-center gap-2">
          <Icon name="tabler:check" class="w-4 h-4 text-brand-blue shrink-0" />
          <span>Focus su conversione e chiarezza</span>
        </li>
        <li class="inline-flex items-center gap-2">
          <Icon name="tabler:check" class="w-4 h-4 text-brand-blue shrink-0" />
          <span>Pensato per business locali</span>
        </li>
      </ul>

      <form
        id="auditForm"
        novalidate
        class="bg-white dark:bg-slate-800 rounded-2xl p-8 shadow-xl ring-1 ring-slate-200/50 dark:ring-slate-700/30 max-w-xl mx-auto text-left"
      >
        <h2 class="text-center text-xl font-semibold text-slate-900 dark:text-slate-100 mb-2">
          Informazioni base per l’analisi
        </h2>
        <p class="text-sm text-slate-600 dark:text-slate-400 text-center mb-6">
          Inserisci i dati principali della homepage per ottenere una prima valutazione.
        </p>

        <div class="grid gap-4">
          <div>
            <label for="websiteUrl" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">
              URL del sito<span class="text-red-500">*</span>
            </label>
            <input
              id="websiteUrl"
              name="websiteUrl"
              type="url"
              placeholder="https://www.tuodominio.it"
              class="w-full px-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue bg-white dark:bg-slate-900"
              required
            />
            <p id="urlError" class="mt-1 text-xs text-red-500 hidden">
              Inserisci un URL valido, ad esempio: https://www.tuodominio.it
            </p>
          </div>

          <div>
            <label for="businessName" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">
              Nome attività<span class="text-red-500">*</span>
            </label>
            <input
              id="businessName"
              name="businessName"
              type="text"
              placeholder="Studio Dentistico Bianchi"
              class="w-full px-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue bg-white dark:bg-slate-900"
              required
            />
            <p id="businessNameError" class="mt-1 text-xs text-red-500 hidden">
              Inserisci il nome dell’attività.
            </p>
          </div>

          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <label for="city" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">
                Città / area geografica<span class="text-red-500">*</span>
              </label>
              <input
                id="city"
                name="city"
                type="text"
                placeholder="Sassari"
                class="w-full px-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue bg-white dark:bg-slate-900"
                required
              />
              <p id="cityError" class="mt-1 text-xs text-red-500 hidden">
                Inserisci città o area geografica.
              </p>
            </div>

            <div>
              <label for="category" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">
                Categoria business<span class="text-red-500">*</span>
              </label>
              <select
                id="category"
                name="category"
                class="w-full px-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue bg-white dark:bg-slate-900"
                required
              >
                <option value="">Seleziona categoria</option>
                <option value="Professionista">Professionista</option>
                <option value="Negozio">Negozio fisico</option>
                <option value="Servizi">Servizi locali</option>
                <option value="Turismo">Turismo / Hotel</option>
                <option value="Ristorazione">Ristorazione</option>
                <option value="Altro">Altro</option>
              </select>
              <p id="categoryError" class="mt-1 text-xs text-red-500 hidden">
                Seleziona una categoria.
              </p>
            </div>
          </div>

          <div>
            <label for="localKeyword" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">
              Keyword principale locale<span class="text-red-500">*</span>
            </label>
            <input
              id="localKeyword"
              name="localKeyword"
              type="text"
              placeholder="dentista sassari"
              class="w-full px-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue bg-white dark:bg-slate-900"
              required
            />
            <p id="localKeywordError" class="mt-1 text-xs text-red-500 hidden">
              Inserisci la keyword principale locale.
            </p>
          </div>
        </div>

        <button
          type="submit"
          class="mt-6 w-full px-6 py-3 bg-brand-blue hover:bg-brand-blue/90 text-white font-medium rounded-xl transition-colors shadow-sm"
        >
          Genera audit
        </button>

        <p
          id="formSuccess"
          class="mt-4 text-sm text-emerald-600 dark:text-emerald-400 text-center hidden"
          aria-live="polite"
        >
          Dati raccolti correttamente. Report generato.
        </p>

        <div class="mt-4 pt-4 border-t border-slate-100 dark:border-slate-700/50">
          <p class="text-xs text-slate-500 dark:text-slate-400 text-center flex items-center justify-center gap-2">
            <Icon name="tabler:shield-check" class="w-3.5 h-3.5 text-emerald-600" />
            <span>Analisi iniziale gratuita · Nessuna registrazione obbligatoria</span>
          </p>
        </div>

        <script>
          const form = document.getElementById('auditForm');
          const successMessage = document.getElementById('formSuccess');

          const loadingEl = document.getElementById('auditLoading');
          const placeholderEl = document.getElementById('auditReportPlaceholder');
          const reportEl = document.getElementById('auditReport');
          const errorEl = document.getElementById('auditError');

          const overallScoreEl = document.getElementById('overallScore');
          const overallStatusEl = document.getElementById('overallStatus');
          const topProblemsEl = document.getElementById('topProblems');
          const priorityActionsEl = document.getElementById('priorityActions');
          const sectionMessageEl = document.getElementById('sectionMessage');
          const sectionUxEl = document.getElementById('sectionUx');
          const sectionSeoEl = document.getElementById('sectionSeo');
          const sectionTrustEl = document.getElementById('sectionTrust');
          const finalSummaryEl = document.getElementById('finalSummary');

          const fields = [
            {
              input: form.querySelector('#websiteUrl'),
              error: document.getElementById('urlError'),
              validate: (el) => el.value.trim() !== '' && el.checkValidity()
            },
            {
              input: form.querySelector('#businessName'),
              error: document.getElementById('businessNameError'),
              validate: (el) => el.value.trim() !== ''
            },
            {
              input: form.querySelector('#city'),
              error: document.getElementById('cityError'),
              validate: (el) => el.value.trim() !== ''
            },
            {
              input: form.querySelector('#category'),
              error: document.getElementById('categoryError'),
              validate: (el) => el.value.trim() !== ''
            },
            {
              input: form.querySelector('#localKeyword'),
              error: document.getElementById('localKeywordError'),
              validate: (el) => el.value.trim() !== ''
            }
          ];

          function validateField(field) {
            const isValid = field.validate(field.input);
            field.error.classList.toggle('hidden', isValid);
            field.input.classList.toggle('border-red-500', !isValid);
            return isValid;
          }

          function renderList(container, items) {
            container.innerHTML = items
              .map(
                (item) => `
                  <li class="flex items-start gap-2">
                    <span class="mt-1 h-2 w-2 rounded-full bg-brand-blue shrink-0"></span>
                    <span>${item}</span>
                  </li>
                `
              )
              .join('');
          }

          function renderReport(report) {
            overallScoreEl.textContent = `${report.overallScore}/100`;
            overallStatusEl.textContent = report.status;

            renderList(topProblemsEl, report.topProblems);
            renderList(priorityActionsEl, report.priorityActions);

            sectionMessageEl.textContent = report.sections.chiarezzaMessaggio.summary;
            sectionUxEl.textContent = report.sections.uxEConversione.summary;
            sectionSeoEl.textContent = report.sections.seoLocale.summary;
            sectionTrustEl.textContent = report.sections.fiduciaEAutorevolezza.summary;
            finalSummaryEl.textContent = report.finalSummary;
          }

          fields.forEach((field) => {
            field.input.addEventListener('blur', () => validateField(field));
            field.input.addEventListener('input', () => {
              if (!field.error.classList.contains('hidden')) {
                validateField(field);
              }
            });
          });

          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            successMessage.classList.add('hidden');
            errorEl.classList.add('hidden');
            reportEl.classList.add('hidden');
            loadingEl.classList.add('hidden');

            const isFormValid = fields.every((field) => validateField(field));
            if (!isFormValid) return;

            const formData = {
              url: form.querySelector('#websiteUrl').value.trim(),
              businessName: form.querySelector('#businessName').value.trim(),
              city: form.querySelector('#city').value.trim(),
              category: form.querySelector('#category').value,
              localKeyword: form.querySelector('#localKeyword').value.trim()
            };

            console.log('[Homepage Audit AI] Form data:', formData);

            placeholderEl.classList.add('hidden');
            loadingEl.classList.remove('hidden');

            try {
              const response = await fetch('/api/homepage-audit', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json'
                },
                body: JSON.stringify(formData)
              });

              if (!response.ok) {
                throw new Error('Errore nella risposta API');
              }

              const report = await response.json();

              renderReport(report);

              loadingEl.classList.add('hidden');
              reportEl.classList.remove('hidden');
              successMessage.classList.remove('hidden');

              reportEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
            } catch (error) {
              loadingEl.classList.add('hidden');
              errorEl.classList.remove('hidden');
              placeholderEl.classList.remove('hidden');
              console.error('[Homepage Audit AI] Error:', error);
            }
          });
        </script>
      </form>
    </div>
  </section>

  <section class="py-14 bg-white dark:bg-slate-950">
    <div class="max-w-6xl mx-auto px-6 md:px-8">
      <div class="text-center mb-10">
        <h2 class="text-2xl md:text-3xl font-bold text-slate-900 dark:text-white mb-3">
          Cosa controlla il report
        </h2>
        <p class="text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
          Una prima lettura orientata a chiarezza, conversione, fiducia e presenza locale della homepage.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 xl:grid-cols-4 gap-5">
        <div class="rounded-2xl bg-slate-50 dark:bg-slate-900/50 p-6 ring-1 ring-slate-200 dark:ring-slate-700/40">
          <div class="w-10 h-10 rounded-xl bg-brand-blue/10 flex items-center justify-center mb-4">
            <Icon name="tabler:message-2" class="w-5 h-5 text-brand-blue" />
          </div>
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2">Chiarezza del messaggio</h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Capisce subito cosa fai, per chi lavori e perché contattarti?
          </p>
        </div>

        <div class="rounded-2xl bg-slate-50 dark:bg-slate-900/50 p-6 ring-1 ring-slate-200 dark:ring-slate-700/40">
          <div class="w-10 h-10 rounded-xl bg-brand-blue/10 flex items-center justify-center mb-4">
            <Icon name="tabler:click" class="w-5 h-5 text-brand-blue" />
          </div>
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2">UX e conversione</h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            La homepage guida davvero l’utente verso l’azione giusta?
          </p>
        </div>

        <div class="rounded-2xl bg-slate-50 dark:bg-slate-900/50 p-6 ring-1 ring-slate-200 dark:ring-slate-700/40">
          <div class="w-10 h-10 rounded-xl bg-brand-blue/10 flex items-center justify-center mb-4">
            <Icon name="tabler:map-pin" class="w-5 h-5 text-brand-blue" />
          </div>
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2">SEO locale di base</h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            La pagina comunica bene servizio, zona geografica e intento locale?
          </p>
        </div>

        <div class="rounded-2xl bg-slate-50 dark:bg-slate-900/50 p-6 ring-1 ring-slate-200 dark:ring-slate-700/40">
          <div class="w-10 h-10 rounded-xl bg-brand-blue/10 flex items-center justify-center mb-4">
            <Icon name="tabler:shield-check" class="w-5 h-5 text-brand-blue" />
          </div>
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2">Fiducia e credibilità</h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Sono presenti elementi che rafforzano autorevolezza e rassicurazione?
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white dark:bg-slate-950">
    <div class="max-w-4xl mx-auto px-6 md:px-8 text-center">
      <div class="p-8 md:p-12 rounded-2xl bg-gradient-to-br from-slate-50 to-slate-100 dark:from-slate-900/50 dark:to-slate-900/30 ring-1 ring-slate-200/70 dark:ring-slate-700/30">
        <div id="auditLoading" class="hidden max-w-xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white dark:bg-slate-800 ring-1 ring-slate-200 dark:ring-slate-700 text-sm text-slate-700 dark:text-slate-300 mb-4">
            <Icon name="tabler:loader-2" class="w-4 h-4 animate-spin text-brand-blue" />
            <span>Stiamo analizzando la tua homepage...</span>
          </div>
          <p class="text-slate-600 dark:text-slate-400">
            Valutiamo messaggio, UX, fiducia e segnali locali più evidenti.
          </p>
        </div>

        <div id="auditReportPlaceholder" class="max-w-xl mx-auto">
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 dark:text-white mb-4 flex items-center justify-center gap-2">
            <Icon name="tabler:report-analytics" class="w-6 h-6 text-brand-blue" />
            <span>Il tuo report completo</span>
          </h2>
          <p class="text-slate-600 dark:text-slate-400 mb-6">
            Riceverai un'analisi dettagliata con:
          </p>
          <ul class="space-y-3 text-slate-700 dark:text-slate-300 text-sm">
            <li class="flex items-start gap-2">
              <Icon name="tabler:check" class="w-4 h-4 text-emerald-600 mt-0.5 shrink-0" />
              <span>Punteggio iniziale della homepage</span>
            </li>
            <li class="flex items-start gap-2">
              <Icon name="tabler:check" class="w-4 h-4 text-emerald-600 mt-0.5 shrink-0" />
              <span>3 problemi principali e 3 azioni prioritarie</span>
            </li>
            <li class="flex items-start gap-2">
              <Icon name="tabler:check" class="w-4 h-4 text-emerald-600 mt-0.5 shrink-0" />
              <span>Valutazione su messaggio, UX, SEO locale e fiducia</span>
            </li>
          </ul>
        </div>

        <div id="auditReport" class="hidden max-w-3xl mx-auto text-left">
          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8">
            <div>
              <p class="text-sm uppercase tracking-wide text-slate-500 dark:text-slate-400 mb-2">Risultato iniziale</p>
              <h2 class="text-2xl md:text-3xl font-bold text-slate-900 dark:text-white">Report Homepage Audit AI</h2>
            </div>
            <div class="flex items-center gap-3">
              <div id="overallScore" class="px-4 py-2 rounded-xl bg-brand-blue text-white font-bold text-lg">--</div>
              <div id="overallStatus" class="px-4 py-2 rounded-xl bg-white dark:bg-slate-800 ring-1 ring-slate-200 dark:ring-slate-700 text-sm font-medium text-slate-700 dark:text-slate-300">
                In attesa
              </div>
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-6 mb-8">
            <div class="rounded-2xl bg-white dark:bg-slate-800 p-6 ring-1 ring-slate-200 dark:ring-slate-700">
              <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Problemi principali</h3>
              <ul id="topProblems" class="space-y-3 text-sm text-slate-700 dark:text-slate-300"></ul>
            </div>

            <div class="rounded-2xl bg-white dark:bg-slate-800 p-6 ring-1 ring-slate-200 dark:ring-slate-700">
              <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Interventi prioritari</h3>
              <ul id="priorityActions" class="space-y-3 text-sm text-slate-700 dark:text-slate-300"></ul>
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-6 mb-8">
            <div class="rounded-2xl bg-white dark:bg-slate-800 p-6 ring-1 ring-slate-200 dark:ring-slate-700">
              <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-2">Chiarezza del messaggio</h3>
              <p id="sectionMessage" class="text-sm text-slate-700 dark:text-slate-300"></p>
            </div>

            <div class="rounded-2xl bg-white dark:bg-slate-800 p-6 ring-1 ring-slate-200 dark:ring-slate-700">
              <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-2">UX e conversione</h3>
              <p id="sectionUx" class="text-sm text-slate-700 dark:text-slate-300"></p>
            </div>

            <div class="rounded-2xl bg-white dark:bg-slate-800 p-6 ring-1 ring-slate-200 dark:ring-slate-700">
              <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-2">SEO locale</h3>
              <p id="sectionSeo" class="text-sm text-slate-700 dark:text-slate-300"></p>
            </div>

            <div class="rounded-2xl bg-white dark:bg-slate-800 p-6 ring-1 ring-slate-200 dark:ring-slate-700">
              <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-2">Fiducia e autorevolezza</h3>
              <p id="sectionTrust" class="text-sm text-slate-700 dark:text-slate-300"></p>
            </div>
          </div>

          <div class="rounded-2xl bg-white dark:bg-slate-800 p-6 ring-1 ring-slate-200 dark:ring-slate-700">
            <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-3">Riepilogo finale</h3>
            <p id="finalSummary" class="text-sm text-slate-700 dark:text-slate-300 leading-relaxed"></p>
          </div>
        </div>

        <p id="auditError" class="hidden mt-6 text-sm text-red-600 dark:text-red-400 text-center">
          Non è stato possibile generare il report. Riprova tra poco.
        </p>
      </div>
    </div>
  </section>

  <section class="pb-16 bg-white dark:bg-slate-950">
    <div class="max-w-5xl mx-auto px-6 md:px-8">
      <div class="grid md:grid-cols-3 gap-4 text-sm">
        <div class="rounded-2xl bg-slate-50 dark:bg-slate-900/40 p-5 ring-1 ring-slate-200 dark:ring-slate-700/40">
          <p class="font-medium text-slate-900 dark:text-white mb-1">Pensato per attività locali</p>
          <p class="text-slate-600 dark:text-slate-400">Professionisti, studi, servizi e business territoriali.</p>
        </div>
        <div class="rounded-2xl bg-slate-50 dark:bg-slate-900/40 p-5 ring-1 ring-slate-200 dark:ring-slate-700/40">
          <p class="font-medium text-slate-900 dark:text-white mb-1">Report leggibile e orientato all’azione</p>
          <p class="text-slate-600 dark:text-slate-400">Indicazioni iniziali chiare, senza gergo inutile.</p>
        </div>
        <div class="rounded-2xl bg-slate-50 dark:bg-slate-900/40 p-5 ring-1 ring-slate-200 dark:ring-slate-700/40">
          <p class="font-medium text-slate-900 dark:text-white mb-1">Possibilità di audit manuale successivo</p>
          <p class="text-slate-600 dark:text-slate-400">Dal report iniziale a una revisione professionale più precisa.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>