---
// Riutilizza il layout standard del sito
import Layout from '@/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

// Metadata SEO per il tool
const metadata = {
  title: 'Homepage Audit AI - Analizza la tua pagina gratuitamente',
  description: 'Tool gratuito per analizzare SEO, prestazioni e UX della tua homepage in pochi secondi.'
};
---
<Layout metadata={metadata}>
  <!-- Hero migliorata -->
  <section class="relative py-28 bg-gradient-to-br from-[#f8f9ff] to-[#f0f4ff] dark:from-slate-900 dark:to-slate-950 overflow-hidden">
    <!-- Effetti background -->
    <div class="absolute inset-0 -z  -10 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/4 left-[60%] w-64 h-64 bg-brand-blue/5 rounded-full blur-3xl"></div>
    </div>

    <div class="max-w-4xl mx-auto px-6 md:px-8 text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 mb-6 bg-white/70 dark:bg-white/10 backdrop-blur-sm rounded-full ring-1 ring-brand-ink/10 text-xs text-brand-ink dark:text-slate-300">
        <span class="w-2 h-2 rounded-full bg-brand-blue shrink-0"></span>
        <span>Tool gratuito per business locali</span>
      </div>

      <h1 class="text-4xl md:text-5xl lg:text-[3.5rem] font-extrabold text-slate-900 dark:text-white mb-5 leading-tight">
        Analisi completa della tua homepage
      </h1>
      <p class="text-xl text-slate-600 dark:text-slate-300 mb-8 max-w-2xl mx-auto">
        Verifichiamo insieme punti di forza e aree di miglioramento per aumentare contatti e conversioni
      </p>

      <!-- Micro-benefit -->
      <ul class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm text-slate-600 dark:text-slate-400 mb-10">
        <li class="inline-flex items-center gap-2">
          <Icon name="tabler:check" class="w-4 h-4 text-brand-blue shrink-0" />
          <span>Report chiaro e pratico</span>
        </li>
        <li class="inline-flex items-center gap-2">
          <Icon name="tabler:check" class="w-4 h-4 text-brand-blue shrink-0" />
          <span>Focus su conversione</span>
        </li>
        <li class="inline-flex items-center gap-2">
          <Icon name="tabler:check" class="w-4 h-4 text-brand-blue shrink-0" />
          <span>Ottimizzato per attività locali</span>
        </li>
      </ul>

      <!-- Card form migliorata -->
      <div class="bg-white dark:bg-slate-800 rounded-2xl p-8 shadow-xl ring-1 ring-slate-200/50 dark:ring-slate-700/30 max-w-md mx-auto">
        <p class="text-center text-lg font-medium text-slate-900 dark:text-slate-100 mb-5">
          Inserisci l'URL da analizzare
        </p>
        <div class="flex gap-3">
          <input 
            type="url" 
            placeholder="https://tuesempio.com" 
            class="flex-1 px-5 py-3 rounded-xl border border-slate-200 dark:border-slate-700 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue"
            required
          />
          <button class="px-6 py-3 bg-brand-blue hover:bg-brand-blue/90 text-white font-medium rounded-xl transition-colors shadow-sm">
            Analizza
          </button>
        </div>
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-3 text-center">
          Analisi iniziale gratuita. Nessuna registrazione obbligatoria.
        </p>
      </div>
    </div>
  </section>

  <!-- Placeholder report -->
  <section class="py-16 bg-white dark:bg-slate-950">
    <div class="max-w-4xl mx-auto px-6 md:px-8 text-center">
      <div class="p-8 md:p-12 rounded-2xl bg-slate-50/50 dark:bg-slate-900/30 ring-1 ring-slate-200/50 dark:ring-slate-700/30">
        <h2 class="text-2xl md:text-3xl font-bold text-slate-900 dark:text-white mb-3">
          Il tuo report apparirà qui
        </h2>
        <p class="text-slate-600 dark:text-slate-400 max-w-xl mx-auto">
          Riceverai un'analisi dettagliata con punti di forza e suggerimenti per migliorare la tua homepage in meno di 1 minuto.
        </p>
      </div>
    </div>
  </section>
</Layout>
