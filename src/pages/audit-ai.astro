---
// Riutilizza il layout standard del sito
import Layout from '@/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

// Metadata SEO per il tool
const metadata = {
  title: 'Homepage Audit AI - Analizza la tua pagina gratuitamente',
  description: 'Tool gratuito per analizzare SEO, prestazioni e UX della tua homepage in pochi secondi.'
};
---
<Layout metadata={metadata}>
  <!-- Hero semplificata riusando stili esistenti -->
  <section class="py-16 md:py-20 bg-brand-surface dark:bg-slate-900">
    <div class="max-w-3xl mx-auto px-6 md:px-8 text-center">
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-slate-900 dark:text-white mb-4">
        Homepage Audit AI
      </h1>
      <p class="text-lg text-slate-600 dark:text-slate-300 mb-8">
        Analisi SEO automatizzata per la tua homepage
      </p>
      
      <!-- Qui andrà il form base -->
      <div class="bg-white dark:bg-slate-800 rounded-2xl p-6 shadow-lg max-w-md mx-auto">
        <p class="text-center mb-4">Inserisci URL da analizzare</p>
        <div class="flex gap-2">
          <input 
            type="url" 
            placeholder="https://tuesempio.com" 
            class="flex-1 px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 focus:ring-2 focus:ring-blue-500"
          />
          <button class="px-4 py-2 bg-brand-blue text-white rounded-lg hover:bg-blue-700 transition">
            Analizza
          </button>
        </div>
      </div>
    </div>
  </section>
</Layout>
