---
import Layout from '~/layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import PortfolioFilters from '~/components/PortfolioFilters.astro';


const portfolio = await getCollection('portfolio');
---

<Layout title="Portfolio">
  <section class="container mx-auto px-6 py-12">
    <h1 class="text-4xl font-bold text-center mb-8">Portfolio</h1>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {portfolio.map((project) => (
        <a href={project.data.permalink} class="block rounded-lg shadow-md overflow-hidden transition-transform transform hover:scale-105">
          {project.data.image && project.data.image.src ? (
            <img 
              src={project.data.image.src} 
              alt={project.data.image.alt || project.data.title} 
              width={project.data.image.width || 1200} 
              height={project.data.image.height || 800} 
              class="w-full h-48 object-cover"
            />
          ) : (
            <div class="w-full h-48 bg-gray-300 flex items-center justify-center text-gray-600">
              Nessuna immagine disponibile
            </div>
          )}
          <div class="p-4">
            <h2 class="text-xl font-semibold">{project.data.title}</h2>
            <p class="text-gray-600">{project.data.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
