---
import CallToAction from '@/components/widgets/CallToAction.astro';
import Hero from '@/components/widgets/Hero.astro';
import Layout from '@/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

// ✅ immagine esistente importata come ESM (evita MissingImageDimension)
import servicesHero from '@/assets/images/servizi-seo-grafica-branding-siti-web.webp';

const metadata = {
  title: 'Servizi Web, SEO e Marketing | LS Web Agency',
  description:
    'Siti web performanti, SEO (anche locale) e marketing digitale. Nuovi servizi: Local SEO Booster, Accessibilità avanzata, UX con AI e Web Design Etico.',
  canonical: '/servizi',
  ignoreTitleTemplate: true,
  openGraph: {
    url: '/servizi',
    images: [{ url: servicesHero.src, width: servicesHero.width, height: servicesHero.height }],
    type: 'website',
  },
  twitter: {
    cardType: 'summary_large_image',
  },
};

// URL utili
---

<Layout metadata={metadata}>
  <!-- HERO: background premium con gradient radiale morbido -->
  <section class="relative isolate services-hero overflow-hidden">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[360px] sm:h-[420px] md:h-[460px] dark:hidden"
    >
      <div class="hero-services-bg h-full w-full" />
    </div>

    <Hero
      tagline="Servizi digitali per attività locali e imprese"
      actions={[
        {
          variant: 'primary',
          text: 'Richiedi una consulenza',
          href: '/contatti',
          class: 'px-6 md:px-7 py-3 text-sm md:text-base shadow-sm hover:shadow-md',
        },
        {
          text: 'Scopri i servizi',
          href: '#servizi-principali',
          class: 'px-5 md:px-6 py-3 text-sm md:text-base border border-neutral-300/70 dark:border-neutral-600/70 bg-white/60 dark:bg-neutral-900/40 hover:bg-white dark:hover:bg-neutral-900',
        },
      ]}
      image={{
        src: servicesHero.src,
        alt: 'Servizi web, SEO e marketing digitale',
        width: servicesHero.width,
        height: servicesHero.height,
        class: 'hero-services-image',
      }}
      gradient={false}
    >
      <span slot="title">
        Servizi digitali per far crescere la tua presenza online
      </span>

      <span slot="subtitle">
        Progettiamo siti, SEO, automazioni e soluzioni digitali concrete per attività locali, professionisti e imprese che vogliono più visibilità, più contatti e una presenza online più efficace.
      </span>
    </Hero>
  </section>

  <!-- SERVIZI PRINCIPALI -->
  <section id="servizi-principali" class="container mx-auto max-w-7xl px-6 md:px-8 py-16 scroll-mt-32">
    <div class="mb-12 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Servizi principali</h2>
      <p class="text-lg text-neutral-600 dark:text-neutral-300 max-w-3xl mx-auto">
        I servizi core per costruire e far crescere la tua presenza digitale
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
      <article id="siti-web" class="rounded-2xl p-8 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition scroll-mt-32">
        <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center mb-6">
          <Icon name="tabler:device-desktop" class="w-6 h-6 text-blue-600 dark:text-blue-400" />
        </div>
        <h3 class="font-semibold text-xl mb-3">Creazione siti web</h3>
        <p class="text-neutral-600 dark:text-neutral-300 mb-4 leading-relaxed">
          Siti moderni, veloci e orientati alla conversione per attività locali e professionisti.
        </p>
        <a href="/servizi/creazione-siti-web-sassari" class="inline-flex items-center text-sm font-semibold text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </article>

      <article id="seo" class="rounded-2xl p-8 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition scroll-mt-32">
        <div class="w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-lg flex items-center justify-center mb-6">
          <Icon name="tabler:shopping-cart" class="w-6 h-6 text-green-600 dark:text-green-400" />
        </div>
        <h3 class="font-semibold text-xl mb-3">E-commerce</h3>
        <p class="text-neutral-600 dark:text-neutral-300 mb-4 leading-relaxed">
          Negozi online con WooCommerce o soluzioni headless, checkout ottimizzati per vendere.
        </p>
        <a href="/servizi/realizzazione-siti-ecommerce" class="inline-flex items-center text-sm font-semibold text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </article>

      <article class="rounded-2xl p-8 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center mb-6">
          <Icon name="tabler:chart-line" class="w-6 h-6 text-purple-600 dark:text-purple-400" />
        </div>
        <h3 class="font-semibold text-xl mb-3">Ottimizzazione SEO</h3>
        <p class="text-neutral-600 dark:text-neutral-300 mb-4 leading-relaxed">
          Analisi tecnica, contenuti e strategie per essere trovati su Google dai tuoi clienti.
        </p>
        <a href="/servizi/ottimizzazione-seo-siti-web" class="inline-flex items-center text-sm font-semibold text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </article>

      <article class="rounded-2xl p-8 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-12 h-12 bg-orange-100 dark:bg-orange-900/30 rounded-lg flex items-center justify-center mb-6">
          <Icon name="tabler:palette" class="w-6 h-6 text-orange-600 dark:text-orange-400" />
        </div>
        <h3 class="font-semibold text-xl mb-3">Branding e Grafica</h3>
        <p class="text-neutral-600 dark:text-neutral-300 mb-4 leading-relaxed">
          Identità visiva, logo, materiali promozionali e design coordinato per il tuo brand.
        </p>
        <a href="/servizi/branding-e-grafica-siti-web" class="inline-flex items-center text-sm font-semibold text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </article>

      <article class="rounded-2xl p-8 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-12 h-12 bg-gray-100 dark:bg-gray-900/30 rounded-lg flex items-center justify-center mb-6">
          <Icon name="tabler:settings" class="w-6 h-6 text-gray-600 dark:text-gray-400" />
        </div>
        <h3 class="font-semibold text-xl mb-3">Assistenza e Manutenzione</h3>
        <p class="text-neutral-600 dark:text-neutral-300 mb-4 leading-relaxed">
          Supporto continuativo, aggiornamenti e manutenzione per mantenere il sito sempre efficiente.
        </p>
        <a href="/servizi/assistenza-manutenzione" class="inline-flex items-center text-sm font-semibold text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </article>
    </div>
  </section>

  <!-- SOLUZIONI SPECIALISTICHE -->
  <section id="ai" class="container mx-auto max-w-7xl px-6 md:px-8 py-12 bg-neutral-50/50 dark:bg-neutral-900/20 scroll-mt-32">
    <div class="mb-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-3">Soluzioni specialistiche</h2>
      <p class="text-neutral-600 dark:text-neutral-300 max-w-2xl mx-auto">
        Interventi mirati per esigenze particolari, quando serve qualcosa di più specifico del servizio base.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4 max-w-5xl mx-auto">
      <div class="rounded-xl p-4 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-8 h-8 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center mb-3">
          <Icon name="tabler:layout" class="w-4 h-4 text-blue-600 dark:text-blue-400" />
        </div>
        <h3 class="font-semibold mb-2">Landing Page</h3>
        <p class="text-xs text-neutral-600 dark:text-neutral-300 mb-3">
          Pagine ottimizzate per convertire visitatori in clienti.
        </p>
        <a href="/servizi/landing-page-professionale" class="text-xs font-medium text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </div>

      <div class="rounded-xl p-4 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-8 h-8 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center mb-3">
          <Icon name="tabler:message-chatbot" class="w-4 h-4 text-purple-600 dark:text-purple-400" />
        </div>
        <h3 class="font-semibold mb-2">Assistente AI</h3>
        <p class="text-xs text-neutral-600 dark:text-neutral-300 mb-3">
          FAQ automatiche, prenotazioni e lead qualificati 24/7.
        </p>
        <a href="/servizi/assistente-ai-sito-whatsapp" class="text-xs font-medium text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </div>

      <div class="rounded-xl p-4 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-8 h-8 bg-indigo-100 dark:bg-indigo-900/30 rounded-lg flex items-center justify-center mb-3">
          <Icon name="tabler:wheelchair" class="w-4 h-4 text-indigo-600 dark:text-indigo-400" />
        </div>
        <h3 class="font-semibold mb-2">Accessibilità Digitale</h3>
        <p class="text-xs text-neutral-600 dark:text-neutral-300 mb-3">
          Adeguamenti WCAG/AgID per siti accessibili a tutti.
        </p>
        <a href="/servizi/accessibilita-digitale-avanzata" class="text-xs font-medium text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </div>

      <div class="rounded-xl p-4 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-8 h-8 bg-orange-100 dark:bg-orange-900/30 rounded-lg flex items-center justify-center mb-3">
          <Icon name="tabler:brain" class="w-4 h-4 text-orange-600 dark:text-orange-400" />
        </div>
        <h3 class="font-semibold mb-2">UX con AI</h3>
        <p class="text-xs text-neutral-600 dark:text-neutral-300 mb-3">
          Esperienze personalizzate e dinamiche per ogni utente.
        </p>
        <a href="/servizi/personalizzazione-ux-intelligenza-artificiale" class="text-xs font-medium text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </div>
    </div>
  </section>

  <!-- PACCHETTI RAPIDI -->
  <section class="container mx-auto max-w-7xl px-6 md:px-8 py-12">
    <div class="mb-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-3">Pacchetti rapidi</h2>
      <p class="text-neutral-600 dark:text-neutral-300 max-w-2xl mx-auto">
        Interventi rapidi, circoscritti e orientati al risultato quando hai già un problema chiaro da risolvere.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
      <article class="rounded-2xl p-6 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center mb-4">
          <Icon name="tabler:search" class="w-5 h-5 text-blue-600 dark:text-blue-400" />
        </div>
        <h3 class="font-semibold text-lg mb-1">Audit Rapido Sito Web</h3>
        <p class="text-xs uppercase tracking-wide text-neutral-500 dark:text-neutral-400 mb-1">Da 299 €</p>
        <p class="text-sm text-neutral-600 dark:text-neutral-300 mb-4">
          Diagnosi operativa in 48h su UX, SEO tecnica e performance del sito.
        </p>
        <a href="/servizi/audit-rapido" class="inline-flex items-center text-sm font-semibold text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </article>

      <article class="rounded-2xl p-6 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-10 h-10 bg-green-100 dark:bg-green-900/30 rounded-lg flex items-center justify-center mb-4">
          <Icon name="tabler:tool" class="w-5 h-5 text-green-600 dark:text-green-400" />
        </div>
        <h3 class="font-semibold text-lg mb-2">Fix Performance & SEO</h3>
        <p class="text-sm text-neutral-600 dark:text-neutral-300 mb-4">
          Intervento mirato quando le priorità sono già chiare.
        </p>
        <a href="/servizi/fix-performance-seo" class="inline-flex items-center text-sm font-semibold text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </article>

      <article class="rounded-2xl p-6 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-10 h-10 bg-orange-100 dark:bg-orange-900/30 rounded-lg flex items-center justify-center mb-4">
          <Icon name="tabler:rocket" class="w-5 h-5 text-orange-600 dark:text-orange-400" />
        </div>
        <h3 class="font-semibold text-lg mb-2">Sprint di Ottimizzazione</h3>
        <p class="text-sm text-neutral-600 dark:text-neutral-300 mb-4">
          Audit + fix + misurazione in un percorso breve e strutturato.
        </p>
        <a href="/servizi/sprint-ottimizzazione" class="inline-flex items-center text-sm font-semibold text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </article>
    </div>
  </section>

  <!-- SOLUZIONI PER ESIGENZE SPECIFICHE -->
  <section class="container mx-auto max-w-7xl px-6 md:px-8 py-12 bg-neutral-50/50 dark:bg-neutral-900/20">
    <div class="mb-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-3">Soluzioni per esigenze specifiche</h2>
      <p class="text-neutral-600 dark:text-neutral-300 max-w-2xl mx-auto">
        Percorsi dedicati quando il progetto richiede un focus settoriale o un approccio più verticale.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
      <article class="rounded-2xl p-6 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-lg flex items-center justify-center mb-4">
          <Icon name="tabler:map-pin" class="w-6 h-6 text-green-600 dark:text-green-400" />
        </div>
        <h3 class="font-semibold text-xl mb-3">SEO Locale</h3>
        <p class="text-neutral-600 dark:text-neutral-300 mb-4 leading-relaxed">
          Tutto quello che serve per essere trovati nelle ricerche locali.
        </p>
        <a href="/servizi/seo-locale" class="inline-flex items-center text-sm font-semibold text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri l'approccio →
        </a>
      </article>

      <article class="rounded-2xl p-6 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center mb-4">
          <Icon name="tabler:building-store" class="w-6 h-6 text-purple-600 dark:text-purple-400" />
        </div>
        <h3 class="font-semibold text-xl mb-3">Transizione Digitale Turismo</h3>
        <p class="text-neutral-600 dark:text-neutral-300 mb-4 leading-relaxed">
          Soluzioni specifiche per B&B, agriturismi, hotel e attività turistiche.
        </p>
        <a href="/transizione-digitale-turismo" class="inline-flex items-center text-sm font-semibold text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri il servizio →
        </a>
      </article>
    </div>
  </section>



  <!-- CTA FINALE -->
  <section class="container mx-auto max-w-7xl px-6 md:px-8 py-16">
    <div class="relative isolate overflow-hidden rounded-2xl bg-neutral-950">
      <div class="absolute inset-0 -z-10 opacity-90 bg-[radial-gradient(circle_at_18%_28%,rgba(168,85,247,0.34),transparent_34%),radial-gradient(circle_at_82%_72%,rgba(34,211,238,0.22),transparent_32%),radial-gradient(circle_at_58%_42%,rgba(236,72,153,0.20),transparent_28%),linear-gradient(135deg,rgba(10,10,12,0.96),rgba(5,8,18,0.98))]"></div>
      <div class="max-w-3xl mx-auto text-center px-6 py-12 md:py-16">
        <h2 class="text-2xl md:text-3xl font-bold mb-4 text-white">Non sai da dove partire?</h2>
        <p class="text-neutral-200 mb-6">
          Possiamo aiutarti a capire da quale intervento partire, in base al tuo obiettivo, allo stato del sito e alle priorità del progetto.
        </p>
        <a href="/contatti" class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white bg-indigo-600 hover:bg-indigo-700 rounded-lg transition-colors">
          Richiedi una consulenza
          <Icon name="tabler:arrow-right" class="w-5 h-5 ml-2" />
        </a>
      </div>
    </div>
  </section>
</Layout>
<style>
  .services-hero {
    background-color: #f9fafb;
  }

  .services-hero .hero-services-bg {
    position: relative;
    background-image:
      radial-gradient(circle at 10% 0%, rgba(129, 140, 248, 0.14), transparent 60%),
      radial-gradient(circle at 90% 0%, rgba(236, 72, 153, 0.12), transparent 60%),
      linear-gradient(to bottom, #f9fafb, #ffffff);
    background-size: 120% 120%;
    background-position: 0% 0%;
  }

  :global(.dark) .services-hero {
    background-color: #020617 !important;
    background-image: none !important;
  }

  :global(.dark) .services-hero .hero-services-bg {
    display: none !important;
    background-image: none !important;
    background-color: transparent !important;
  }

  /* Badge/tagline sopra il titolo: pill elegante, più piccola */
  .services-hero
    :global(
      p.text-xs.font-semibold.uppercase.tracking-wide.text-indigo-700\/90.dark\:text-indigo-300
    ) {
    display: inline-flex;
    align-items: center;
    padding: 0.28rem 0.8rem;
    border-radius: 9999px;
    border: 1px solid rgba(129, 140, 248, 0.28);
    background: rgba(249, 250, 251, 0.96);
    color: rgb(55, 48, 163);
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    backdrop-filter: blur(6px);
  }

  .dark
    .services-hero
    :global(
      p.text-xs.font-semibold.uppercase.tracking-wide.text-indigo-700\/90.dark\:text-indigo-300
    ) {
    background: rgba(15, 23, 42, 0.86);
    border-color: rgba(129, 140, 248, 0.5);
    color: rgb(191, 219, 254);
  }

  /* CTA: più respiro e micro-riga informativa più discreta */
  .services-hero :global(.mt-5.flex.flex-wrap.gap-3) {
    margin-top: 1.5rem;
    column-gap: 1rem;
    row-gap: 0.8rem;
  }

  .services-hero :global(.mt-5.flex.flex-wrap.gap-3)::after {
    content: 'Siti web \2022  SEO & visibilità \2022  Automazioni leggere';
    display: block;
    width: 100%;
    margin-top: 0.55rem;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(55, 65, 81, 0.65);
  }

  .dark .services-hero :global(.mt-5.flex.flex-wrap.gap-3)::after {
    color: rgba(209, 213, 219, 0.7);
  }

  /* Contenitore immagine: ring e ombra morbidi e integrati */
  .services-hero :global(img.hero-services-image) {
    border-radius: 1.5rem;
    box-shadow:
      0 22px 45px rgba(15, 23, 42, 0.18),
      0 0 0 1px rgba(148, 163, 184, 0.25);
    background-color: rgba(248, 250, 252, 0.9);
  }

  .dark .services-hero :global(img.hero-services-image) {
    box-shadow:
      0 24px 52px rgba(15, 23, 42, 0.55),
      0 0 0 1px rgba(148, 163, 184, 0.45);
    background-color: transparent;
  }
</style>
