---
import CallToAction from '@/components/widgets/CallToAction.astro';
import Features2 from '@/components/widgets/Features2.astro';
import Hero from '@/components/widgets/Hero.astro';
import Layout from '@/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

// ✅ immagine esistente importata come ESM (evita MissingImageDimension)
import servicesHero from '@/assets/images/servizi-seo-grafica-branding-siti-web.webp';

const metadata = {
  title: 'Servizi Web, SEO e Marketing | LS Web Agency',
  description:
    'Siti web performanti, SEO (anche locale) e marketing digitale. Nuovi servizi: Local SEO Booster, Accessibilità avanzata, UX con AI e Web Design Etico.',
  canonical: '/servizi',
  ignoreTitleTemplate: true,
  openGraph: {
    url: '/servizi',
    images: [{ url: servicesHero.src, width: servicesHero.width, height: servicesHero.height }],
    type: 'website',
  },
  twitter: {
    cardType: 'summary_large_image',
  },
};

// URL utili
const SEO_BOOSTER_URL = '/servizi/seo-locale';
const PAGAMENTI_URL = '/pagamenti';

// ✅ Landing “pacchetto rapido”
const CONTATTI_RAPIDI_URL = '/lp/contatti-rapidi';
const CONTATTI_RAPIDI_CTA = '/contatti?servizio=contatti-rapidi&azione=call';
---

<Layout metadata={metadata}>
  <!-- HERO + bg gradient: più tenue e più basso -->
  <section class="relative isolate">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[340px] sm:h-[400px] md:h-[440px]"
    >
      <div
        class="h-full bg-gradient-to-b from-violet-600/10 via-fuchsia-500/8 to-white
               dark:from-violet-500/20 dark:via-fuchsia-400/10 dark:to-neutral-950"
      />
    </div>

    <Hero
      actions={[
        { variant: 'primary', text: 'Richiedi una consulenza', href: '/contatti' },
        { text: 'Scopri i servizi', href: '#servizi-principali' },
      ]}
      image={{
        src: servicesHero.src,
        alt: 'Servizi web, SEO e marketing digitale',
        width: servicesHero.width,
        height: servicesHero.height,
      }}
    >
      <span slot="title">
        Servizi digitali per far crescere la tua presenza online
      </span>

      <span slot="subtitle">
        Progettiamo siti, SEO, automazioni e soluzioni digitali concrete per attività locali, professionisti e imprese che vogliono più visibilità, più contatti e una presenza online più efficace.
      </span>
    </Hero>
  </section>

  <!-- SERVIZI PRINCIPALI -->
  <section id="servizi-principali" class="container mx-auto max-w-7xl px-6 md:px-8 py-16">
    <div class="mb-12 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Servizi principali</h2>
      <p class="text-lg text-neutral-600 dark:text-neutral-300 max-w-3xl mx-auto">
        I servizi core per costruire e far crescere la tua presenza digitale
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
      <article class="rounded-2xl p-8 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center mb-6">
          <Icon name="tabler:device-desktop" class="w-6 h-6 text-blue-600 dark:text-blue-400" />
        </div>
        <h3 class="font-semibold text-xl mb-3">Creazione siti web</h3>
        <p class="text-neutral-600 dark:text-neutral-300 mb-4 leading-relaxed">
          Siti moderni, veloci e orientati alla conversione per attività locali e professionisti.
        </p>
        <a href="/servizi/creazione-siti-web-sassari" class="inline-flex items-center text-sm font-semibold text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </article>

      <article class="rounded-2xl p-8 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-lg flex items-center justify-center mb-6">
          <Icon name="tabler:shopping-cart" class="w-6 h-6 text-green-600 dark:text-green-400" />
        </div>
        <h3 class="font-semibold text-xl mb-3">E-commerce</h3>
        <p class="text-neutral-600 dark:text-neutral-300 mb-4 leading-relaxed">
          Negozi online con WooCommerce o soluzioni headless, checkout ottimizzati per vendere.
        </p>
        <a href="/servizi/realizzazione-siti-ecommerce" class="inline-flex items-center text-sm font-semibold text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </article>

      <article class="rounded-2xl p-8 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center mb-6">
          <Icon name="tabler:chart-line" class="w-6 h-6 text-purple-600 dark:text-purple-400" />
        </div>
        <h3 class="font-semibold text-xl mb-3">Ottimizzazione SEO</h3>
        <p class="text-neutral-600 dark:text-neutral-300 mb-4 leading-relaxed">
          Analisi tecnica, contenuti e strategie per essere trovati su Google dai tuoi clienti.
        </p>
        <a href="/servizi/ottimizzazione-seo-siti-web" class="inline-flex items-center text-sm font-semibold text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </article>

      <article class="rounded-2xl p-8 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-12 h-12 bg-orange-100 dark:bg-orange-900/30 rounded-lg flex items-center justify-center mb-6">
          <Icon name="tabler:palette" class="w-6 h-6 text-orange-600 dark:text-orange-400" />
        </div>
        <h3 class="font-semibold text-xl mb-3">Branding e Grafica</h3>
        <p class="text-neutral-600 dark:text-neutral-300 mb-4 leading-relaxed">
          Identità visiva, logo, materiali promozionali e design coordinato per il tuo brand.
        </p>
        <a href="/servizi/branding-e-grafica-siti-web" class="inline-flex items-center text-sm font-semibold text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </article>

      <article class="rounded-2xl p-8 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-12 h-12 bg-gray-100 dark:bg-gray-900/30 rounded-lg flex items-center justify-center mb-6">
          <Icon name="tabler:settings" class="w-6 h-6 text-gray-600 dark:text-gray-400" />
        </div>
        <h3 class="font-semibold text-xl mb-3">Assistenza e Manutenzione</h3>
        <p class="text-neutral-600 dark:text-neutral-300 mb-4 leading-relaxed">
          Supporto continuativo, aggiornamenti e manutenzione per mantenere il sito sempre efficiente.
        </p>
        <a href="/servizi/assistenza-manutenzione" class="inline-flex items-center text-sm font-semibold text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </article>
    </div>
  </section>

  <!-- SERVIZI SPECIALISTICI -->
  <section class="container mx-auto max-w-7xl px-6 md:px-8 py-16 bg-neutral-50/50 dark:bg-neutral-900/20">
    <div class="mb-12 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Servizi specialistici</h2>
      <p class="text-lg text-neutral-600 dark:text-neutral-300 max-w-3xl mx-auto">
        Soluzioni avanzate per esigenze specifiche e progetti più complessi
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      <article class="rounded-2xl p-6 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center mb-4">
          <Icon name="tabler:layout" class="w-5 h-5 text-blue-600 dark:text-blue-400" />
        </div>
        <h3 class="font-semibold text-lg mb-2">Landing Page</h3>
        <p class="text-sm text-neutral-600 dark:text-neutral-300 mb-4">
          Pagine ottimizzate per convertire visitatori in clienti.
        </p>
        <a href="/servizi/landing-page-professionale" class="inline-flex items-center text-sm font-semibold text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </article>

      <article class="rounded-2xl p-6 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-10 h-10 bg-green-100 dark:bg-green-900/30 rounded-lg flex items-center justify-center mb-4">
          <Icon name="tabler:rocket" class="w-5 h-5 text-green-600 dark:text-green-400" />
        </div>
        <h3 class="font-semibold text-lg mb-2">WordPress Slim</h3>
        <p class="text-sm text-neutral-600 dark:text-neutral-300 mb-4">
          Siti statici e headless: veloci, sicuri e SEO-ready.
        </p>
        <a href="/servizi/wordpress-slim-siti-statici-headless" class="inline-flex items-center text-sm font-semibold text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </article>

      <article class="rounded-2xl p-6 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-10 h-10 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center mb-4">
          <Icon name="tabler:message-chatbot" class="w-5 h-5 text-purple-600 dark:text-purple-400" />
        </div>
        <h3 class="font-semibold text-lg mb-2">Assistente AI</h3>
        <p class="text-sm text-neutral-600 dark:text-neutral-300 mb-4">
          FAQ automatiche, prenotazioni e lead qualificati 24/7.
        </p>
        <a href="/servizi/assistente-ai-sito-whatsapp" class="inline-flex items-center text-sm font-semibold text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </article>

      <article class="rounded-2xl p-6 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-10 h-10 bg-orange-100 dark:bg-orange-900/30 rounded-lg flex items-center justify-center mb-4">
          <Icon name="tabler:brain" class="w-5 h-5 text-orange-600 dark:text-orange-400" />
        </div>
        <h3 class="font-semibold text-lg mb-2">UX con AI</h3>
        <p class="text-sm text-neutral-600 dark:text-neutral-300 mb-4">
          Esperienze personalizzate e dinamiche per ogni utente.
        </p>
        <a href="/servizi/personalizzazione-ux-intelligenza-artificiale" class="inline-flex items-center text-sm font-semibold text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </article>

      <article class="rounded-2xl p-6 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-10 h-10 bg-red-100 dark:bg-red-900/30 rounded-lg flex items-center justify-center mb-4">
          <Icon name="tabler:article" class="w-5 h-5 text-red-600 dark:text-red-400" />
        </div>
        <h3 class="font-semibold text-lg mb-2">AI Blog Engine</h3>
        <p class="text-sm text-neutral-600 dark:text-neutral-300 mb-4">
          Contenuti blog generati e ottimizzati con intelligenza artificiale.
        </p>
        <a href="/servizi/ai-blog-engine" class="inline-flex items-center text-sm font-semibold text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </article>

      <article class="rounded-2xl p-6 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-10 h-10 bg-indigo-100 dark:bg-indigo-900/30 rounded-lg flex items-center justify-center mb-4">
          <Icon name="tabler:wheelchair" class="w-5 h-5 text-indigo-600 dark:text-indigo-400" />
        </div>
        <h3 class="font-semibold text-lg mb-2">Accessibilità Digitale</h3>
        <p class="text-sm text-neutral-600 dark:text-neutral-300 mb-4">
          Adeguamenti WCAG/AgID per siti accessibili a tutti.
        </p>
        <a href="/servizi/accessibilita-digitale-avanzata" class="inline-flex items-center text-sm font-semibold text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </article>

      <article class="rounded-2xl p-6 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-10 h-10 bg-green-100 dark:bg-green-900/30 rounded-lg flex items-center justify-center mb-4">
          <Icon name="tabler:leaf" class="w-5 h-5 text-green-600 dark:text-green-400" />
        </div>
        <h3 class="font-semibold text-lg mb-2">Web Design Etico</h3>
        <p class="text-sm text-neutral-600 dark:text-neutral-300 mb-4">
          Siti sostenibili: performance, privacy e leggerezza.
        </p>
        <a href="/servizi/web-design-etico-sostenibile" class="inline-flex items-center text-sm font-semibold text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </article>
    </div>
  </section>

  <!-- PACCHETTI RAPIDI -->
  <section class="container mx-auto max-w-7xl px-6 md:px-8 py-16">
    <div class="mb-12 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Pacchetti rapidi</h2>
      <p class="text-lg text-neutral-600 dark:text-neutral-300 max-w-3xl mx-auto">
        Soluzioni veloci e mirate per chi ha bisogno di un intervento specifico e circoscritto
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      <article class="rounded-2xl p-6 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center mb-4">
          <Icon name="tabler:search" class="w-5 h-5 text-blue-600 dark:text-blue-400" />
        </div>
        <h3 class="font-semibold text-lg mb-2">Audit Rapido</h3>
        <p class="text-sm text-neutral-600 dark:text-neutral-300 mb-4">
          Diagnosi operativa in 48h: baseline, priorità e prossimi passi.
        </p>
        <a href="/servizi/audit-rapido" class="inline-flex items-center text-sm font-semibold text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </article>

      <article class="rounded-2xl p-6 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-10 h-10 bg-green-100 dark:bg-green-900/30 rounded-lg flex items-center justify-center mb-4">
          <Icon name="tabler:tool" class="w-5 h-5 text-green-600 dark:text-green-400" />
        </div>
        <h3 class="font-semibold text-lg mb-2">Fix Performance & SEO</h3>
        <p class="text-sm text-neutral-600 dark:text-neutral-300 mb-4">
          Intervento mirato quando le priorità sono già chiare.
        </p>
        <a href="/servizi/fix-performance-seo" class="inline-flex items-center text-sm font-semibold text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </article>

      <article class="rounded-2xl p-6 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-10 h-10 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center mb-4">
          <Icon name="tabler:map-pin" class="w-5 h-5 text-purple-600 dark:text-purple-400" />
        </div>
        <h3 class="font-semibold text-lg mb-2">Local SEO Booster</h3>
        <p class="text-sm text-neutral-600 dark:text-neutral-300 mb-4">
          Pacchetto operativo per risultati locali misurabili.
        </p>
        <a href="/servizi/local-seo-booster" class="inline-flex items-center text-sm font-semibold text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </article>

      <article class="rounded-2xl p-6 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-10 h-10 bg-orange-100 dark:bg-orange-900/30 rounded-lg flex items-center justify-center mb-4">
          <Icon name="tabler:rocket" class="w-5 h-5 text-orange-600 dark:text-orange-400" />
        </div>
        <h3 class="font-semibold text-lg mb-2">Sprint di Ottimizzazione</h3>
        <p class="text-sm text-neutral-600 dark:text-neutral-300 mb-4">
          Audit + fix + misurazione in un percorso breve e strutturato.
        </p>
        <a href="/servizi/sprint-ottimizzazione" class="inline-flex items-center text-sm font-semibold text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Scopri di più →
        </a>
      </article>
    </div>
  </section>

  <!-- SOLUZIONI PER ESIGENZE SPECIFICHE -->
  <section class="container mx-auto max-w-7xl px-6 md:px-8 py-16 bg-neutral-50/50 dark:bg-neutral-900/20">
    <div class="mb-12 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Soluzioni per esigenze specifiche</h2>
      <p class="text-lg text-neutral-600 dark:text-neutral-300 max-w-3xl mx-auto">
        Percorsi dedicati e soluzioni verticali per settori e necessità particolari
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto">
      <article class="rounded-2xl p-8 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center mb-6">
          <Icon name="tabler:device-desktop" class="w-6 h-6 text-blue-600 dark:text-blue-400" />
        </div>
        <h3 class="font-semibold text-xl mb-3">Hub Siti Web</h3>
        <p class="text-neutral-600 dark:text-neutral-300 mb-4 leading-relaxed">
          Panoramica completa di tutti i servizi per la creazione di siti web.
        </p>
        <a href="/servizi/siti-web" class="inline-flex items-center text-sm font-semibold text-indigo-700 hover:text-indigo-800 dark:text-indigo-300">
          Esplora i servizi →
        </a>
      </article>

      <article class="rounded-2xl p-8 ring-1 ring-neutral-200 dark:ring-neutral-800 bg-white/80 dark:bg-neutral-900/50 shadow-sm hover:shadow-md transition">
        <div class="w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-lg flex items-center justify-center mb-6">
          <Icon name="tabler:map-pin" class="w-6 h-6 text-green-600 dark:text-green-400" />
        </div>
