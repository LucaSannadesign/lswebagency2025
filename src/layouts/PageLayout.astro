---
import Document from '@/layouts/Layout.astro';
import Header from '@/components/widgets/Header.astro';
import Footer from '@/components/widgets/Footer.astro';
import CookieBanner from '@/components/CookieBanner.astro'; // ✅ ADD
import SiteAssistant from '@/components/SiteAssistant';
import type { MetaData } from '@/types';

export interface Props { metadata?: MetaData }
const metadata = (Astro.props.metadata ?? {}) as MetaData;

// Assistente di sito (widget flottante): montato globalmente UNA sola volta, idratazione lazy.
// Escluso dalla pagina che ha già demo + assistente inline (evita sovraccarico): la decisione
// usa il pathname reale lato server, così il componente NON viene proprio renderizzato lì
// (nessuna logica client per nasconderlo dopo il caricamento).
const pathname = Astro.url.pathname;
const hideSiteAssistant =
  pathname === '/servizi/assistente-ai-sito-whatsapp' ||
  pathname === '/servizi/assistente-ai-sito-whatsapp/';
// WhatsApp: solo la variabile PUBLIC_ già usata nel progetto (ChatWidget, pagina servizio).
// Se assente, il componente funziona senza WhatsApp (nessun numero hardcoded, nessuna env server).
const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER || undefined;
---

<Document metadata={metadata}>
  <Header />

  <main id="main" class="min-h-screen">
    <slot />
  </main>

  <Footer />

  <!-- ✅ Cookie banner / preferenze -->
  <CookieBanner />

  <!-- Scroll to top -->
  <button
    id="scrollToTop"
    type="button"
    aria-label="Torna su"
    class="fixed bottom-20 right-6 z-[65]
           h-12 w-12 rounded-full
           bg-primary/95 text-white
           shadow-lg ring-1 ring-white/10
           backdrop-blur
           opacity-0 translate-y-2 pointer-events-none
           transition-all duration-300 ease-in-out
           hover:bg-secondary
           focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/60 focus-visible:ring-offset-2
           dark:bg-violet-300/95 dark:text-brand-ink dark:ring-white/10 dark:hover:bg-violet-200
           md:bottom-24 md:right-8"
  >
    <span aria-hidden="true" class="text-xl leading-none">↑</span>
  </button>

  <script is:inline>
    (() => {
      const btn = document.getElementById('scrollToTop');
      if (!btn) return;

      const SHOW_AT = 300;
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      const onScroll = () => {
        const y = window.scrollY || document.documentElement.scrollTop || 0;
        if (y > SHOW_AT) {
          btn.classList.remove('opacity-0', 'translate-y-2', 'pointer-events-none');
          btn.classList.add('opacity-100', 'translate-y-0');
        } else {
          btn.classList.add('opacity-0', 'translate-y-2', 'pointer-events-none');
          btn.classList.remove('opacity-100', 'translate-y-0');
        }
      };

      btn.addEventListener('click', () => {
        try {
          window.scrollTo({ 
            top: 0, 
            behavior: prefersReducedMotion ? 'auto' : 'smooth' 
          });
        } catch {
          window.scrollTo(0, 0);
        }
      });

      // Keyboard navigation support
      btn.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          btn.click();
        }
      });

      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    })();
  </script>

  <!-- Assistente di sito: una sola istanza, idratazione lazy (client:idle). Non montato sulla
       pagina che ha già demo + assistente inline. Re-mount alla navigazione ClientRouter accettato
       (la conversazione è volutamente solo nello stato React). -->
  {!hideSiteAssistant && <SiteAssistant client:idle whatsappNumber={whatsappNumber} />}
</Document>